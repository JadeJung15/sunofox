              <div class="mv-option-grid">
                <label class="mv-field">
                  <span>언어</span>
                  <select id="mv-language">
                    <option value="ko">한국어</option>
                    <option value="en">English</option>
                  </select>
                </label>
                <label class="mv-field">
                  <span>스토리 방식</span>
                  <select id="mv-focus">
                    <option value="lyrics-strict">가사 순서 중심</option>
                    <option value="emotional-arc">감정 성장 중심</option>
                    <option value="performance">리듬 연출 중심</option>
                  </select>
                </label>
              <label class="mv-field">
                <span>Niji 버전</span>
                <select id="mv-niji">
                  <option value="7">Niji 7 · profile 적용</option>
                  <option value="5">Niji 5 · profile 제외</option>
