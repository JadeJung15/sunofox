---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import {
  artistLinks,
  latestChannelVideo,
  latestNovelEpisode,
  musicArchive,
  novelProject,
  structuredData
} from '../data/siteContent.js';

const keyVisual = '/assets/release-desk/mask-good-girl.jpg';

const posterLinks = [
  { label: '음악', title: '음악 아카이브', description: 'OST와 앨범 공개 기록', href: musicArchive.href },
  { label: '스토리', title: novelProject.title, description: '완결 미니시즌 정주행', href: novelProject.season.startHref },
  { label: 'MV Studio', title: 'MV 스튜디오', description: '소유자 제작실', href: '/login?next=/mv-studio' }
];

const latestEpisodeLabel = `${latestNovelEpisode.label} · ${latestNovelEpisode.title}`;
---

<Layout
  title="SunoFox | Anime OST Studio"
  description="SunoFox는 애니메이션 감성의 OST, 웹소설, 영상 제작 흐름을 단순하고 아름답게 연결하는 공식 홈입니다."
  image="https://sunofox.com/assets/release-desk/mask-good-girl.jpg"
  imageAlt={latestChannelVideo.thumbnailAlt}
  imageWidth={1200}
  imageHeight={675}
  jsonLd={structuredData}
>
  <SiteChrome active="home" />

  <main id="main-content" class="site-main anime-home poster-home">
    <section class="poster-hero reveal" aria-labelledby="posterHomeTitle">
      <img
        class="poster-bg"
        src={keyVisual}
        alt="Mask of a Good Girl OST를 상징하는 SunoFox 애니메이션 키비주얼"
        width="1200"
        height="900"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />

      <div class="poster-shell">
        <div class="poster-content">
          <p class="poster-kicker">애니 OST 스튜디오</p>
          <h1 id="posterHomeTitle"><span>Suno</span><span>Fox</span></h1>
          <p class="poster-lead">감정을 노래하고, 이야기를 장면으로 남깁니다.</p>
          <div class="poster-actions" aria-label="SunoFox 주요 링크">
            <a class="poster-button poster-button-primary" href={latestChannelVideo.youtubeHref} target="_blank" rel="noopener noreferrer">최신 OST 듣기</a>
            <a class="poster-button" href={novelProject.season.startHref}>소설 보기</a>
          </div>
        </div>

        <a class="poster-now" href={latestChannelVideo.youtubeHref} target="_blank" rel="noopener noreferrer" aria-label={`${latestChannelVideo.title} YouTube에서 듣기`}>
          <span class="poster-play-icon" aria-hidden="true"></span>
          <span class="poster-track">
            <span class="poster-now-label">지금 재생 중 · 최신 공개 영상</span>
            <strong>{latestChannelVideo.title}</strong>
            <small>{latestChannelVideo.englishTitle} · {latestChannelVideo.date} · Anime OST</small>
          </span>
          <span class="poster-progress" aria-hidden="true"><span></span></span>
          <span class="poster-listen-link">YouTube에서 듣기</span>
        </a>
      </div>
    </section>

    <section class="poster-panel reveal" aria-label="SunoFox 시작 경로">
      <div class="poster-panel-head">
        <strong>시작하기</strong>
      </div>

      <nav class="poster-links" aria-label="SunoFox 주요 경로">
        {posterLinks.map((item) => (
          <a href={item.href}>
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <small>{item.description}</small>
          </a>
        ))}
      </nav>

      <a class="poster-latest" href={latestNovelEpisode.href}>
        <span>최근 회차</span>
        <strong>{latestEpisodeLabel}</strong>
      </a>
    </section>

    <section class="poster-social reveal" aria-label="SunoFox 외부 및 보조 링크">
      <a href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">유튜브</a>
    </section>
  </main>
</Layout>

<style>
  .anime-home {
    --anime-bg: #050509;
    --anime-ink: #fff7fb;
    --anime-muted: #d8cfdd;
    --anime-soft: #aa9ab4;
    --anime-line: rgba(255, 247, 251, 0.16);
    --anime-accent: #ff6f9f;
    --anime-title-soft: #f1e7f3;
    --anime-warm: #f6b86a;
    min-height: 100svh;
    overflow: hidden;
    background: var(--anime-bg);
    color: var(--anime-ink);
  }

  .poster-hero {
    position: relative;
    display: grid;
    min-height: 90svh;
    align-items: center;
    overflow: hidden;
    padding: 112px 0 72px;
    isolation: isolate;
  }

  .poster-hero::before,
  .poster-hero::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    pointer-events: none;
  }

  .poster-hero::before {
    background:
      linear-gradient(90deg, rgba(5, 5, 9, 0.96), rgba(5, 5, 9, 0.62) 44%, rgba(5, 5, 9, 0.16)),
      linear-gradient(180deg, rgba(5, 5, 9, 0.16), rgba(5, 5, 9, 0.08) 45%, rgba(5, 5, 9, 0.9));
  }

  .poster-hero::after {
    background:
      linear-gradient(rgba(255, 247, 251, 0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 247, 251, 0.028) 1px, transparent 1px);
    background-size: 56px 56px, 56px 56px;
    opacity: 0.45;
  }

  .poster-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 64% 42%;
    filter: saturate(1.12) contrast(1.08);
  }

  .poster-shell,
  .poster-panel,
  .poster-social {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .poster-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: 56px;
    align-items: end;
  }

  .poster-content {
    display: grid;
    gap: 18px;
    min-width: 0;
    padding-top: 82px;
  }

  .poster-kicker {
    margin: 0;
    color: var(--anime-warm);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0;
  }

  .poster-content h1 {
    display: grid;
    max-width: 8ch;
    margin: 0;
    color: var(--anime-ink);
    font-size: 8.8rem;
    font-weight: 950;
    line-height: 0.86;
    letter-spacing: 0;
    overflow-wrap: anywhere;
    text-shadow: 0 0 34px rgba(255, 111, 159, 0.24);
  }

  .poster-content h1 span:last-child {
    color: var(--anime-accent);
  }

  .poster-content h1 span:first-child {
    color: var(--anime-title-soft);
  }

  .poster-lead {
    max-width: 420px;
    margin: 0;
    color: var(--anime-muted);
    font-size: 1.08rem;
    font-weight: 680;
    line-height: 1.75;
    word-break: keep-all;
  }

  .poster-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 4px;
  }

  .poster-button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--anime-line);
    border-radius: 999px;
    padding: 0 20px;
    background: rgba(5, 5, 9, 0.36);
    color: var(--anime-ink);
    font-size: 0.94rem;
    font-weight: 900;
    backdrop-filter: blur(12px);
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
    white-space: nowrap;
  }

  .poster-button:hover,
  .poster-button:focus-visible {
    border-color: var(--anime-accent);
    background: rgba(255, 111, 159, 0.12);
    transform: translateY(-1px);
  }

  .poster-button-primary {
    border-color: var(--anime-accent);
    background: var(--anime-accent);
    color: #1d0711;
  }

  .poster-now {
    display: grid;
    grid-template-columns: 52px minmax(0, 1fr);
    gap: 10px;
    min-width: 0;
    align-self: end;
    border: 1px solid rgba(255, 247, 251, 0.18);
    border-radius: 8px;
    padding: 20px;
    background:
      linear-gradient(145deg, rgba(255, 111, 159, 0.16), transparent 52%),
      rgba(5, 5, 9, 0.48);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(18px);
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .poster-now:hover,
  .poster-now:focus-visible {
    border-color: rgba(255, 111, 159, 0.56);
    background:
      linear-gradient(145deg, rgba(255, 111, 159, 0.2), transparent 52%),
      rgba(5, 5, 9, 0.58);
    transform: translateY(-1px);
  }

  .poster-play-icon {
    position: relative;
    display: inline-flex;
    width: 52px;
    height: 52px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 247, 251, 0.2);
    border-radius: 50%;
    background: var(--anime-accent);
    box-shadow: 0 14px 34px rgba(255, 111, 159, 0.22);
  }

  .poster-play-icon::before {
    width: 0;
    height: 0;
    margin-left: 4px;
    border-top: 9px solid transparent;
    border-bottom: 9px solid transparent;
    border-left: 14px solid #1d0711;
    content: "";
  }

  .poster-track {
    display: grid;
    min-width: 0;
    gap: 5px;
  }

  .poster-now-label,
  .poster-links span,
  .poster-latest span,
  .poster-social a {
    color: var(--anime-soft);
    font-size: 0.78rem;
    font-weight: 860;
  }

  .poster-now-label {
    color: var(--anime-warm);
  }

  .poster-track strong {
    color: var(--anime-ink);
    font-size: 1.38rem;
    font-weight: 950;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .poster-track small {
    color: var(--anime-muted);
    font-size: 0.9rem;
    font-weight: 720;
    line-height: 1.45;
    word-break: keep-all;
  }

  .poster-progress {
    grid-column: 1 / -1;
    display: block;
    height: 4px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 247, 251, 0.13);
  }

  .poster-progress span {
    display: block;
    width: 42%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--anime-accent), var(--anime-warm));
  }

  .poster-listen-link {
    grid-column: 1 / -1;
    display: inline-flex;
    width: fit-content;
    min-height: 32px;
    align-items: center;
    border-bottom: 1px solid rgba(255, 111, 159, 0.6);
    color: var(--anime-accent);
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 900;
  }

  .poster-panel {
    display: grid;
    gap: 14px;
    margin-top: -28px;
    padding: 0;
    position: relative;
    z-index: 2;
  }

  .poster-panel-head {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .poster-panel-head strong {
    color: var(--anime-ink);
    font-size: 1.15rem;
    font-weight: 950;
    line-height: 1.2;
  }

  .poster-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .poster-links a {
    display: grid;
    gap: 6px;
    min-width: 0;
    min-height: 118px;
    align-content: center;
    border: 1px solid var(--anime-line);
    border-radius: 8px;
    padding: 17px;
    background: rgba(5, 5, 9, 0.58);
    backdrop-filter: blur(18px);
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .poster-links a:hover,
  .poster-links a:focus-visible {
    border-color: rgba(255, 111, 159, 0.44);
    background: rgba(255, 111, 159, 0.12);
    transform: translateY(-1px);
  }

  .poster-links strong {
    color: var(--anime-ink);
    font-size: 1.05rem;
    font-weight: 930;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .poster-links small,
  .poster-latest span {
    color: var(--anime-muted);
    font-size: 0.78rem;
    font-weight: 720;
    line-height: 1.35;
    word-break: keep-all;
  }

  .poster-latest {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    min-width: 0;
    min-height: 44px;
    align-items: center;
    border-bottom: 1px solid rgba(255, 247, 251, 0.12);
    padding: 10px 0 4px;
    backdrop-filter: blur(18px);
  }

  .poster-latest:hover strong,
  .poster-latest:focus-visible strong {
    color: var(--anime-accent);
  }

  .poster-latest strong {
    color: var(--anime-muted);
    font-size: 0.9rem;
    font-weight: 850;
    overflow-wrap: anywhere;
  }

  .poster-social {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    justify-content: center;
    padding: 26px 0 46px;
  }

  .poster-social a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
  }

  .poster-social a:hover,
  .poster-social a:focus-visible {
    color: var(--anime-accent);
  }

  @media (max-width: 980px) {
    .poster-shell {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
      gap: 32px;
    }

    .poster-content h1 {
      font-size: 6.8rem;
    }
  }

  @media (max-width: 760px) {
    .poster-hero {
      min-height: 92svh;
      align-items: end;
      padding: 76px 0 24px;
    }

    .poster-hero::before {
      background:
        linear-gradient(180deg, rgba(5, 5, 9, 0.12), rgba(5, 5, 9, 0.16) 36%, rgba(5, 5, 9, 0.96)),
        linear-gradient(90deg, rgba(5, 5, 9, 0.38), transparent 68%);
    }

    .poster-bg {
      object-position: 56% 50%;
    }

    .poster-shell,
    .poster-panel,
    .poster-social {
      width: calc(100% - 28px);
    }

    .poster-shell {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .poster-content {
      padding-top: 22svh;
    }

    .poster-content h1 {
      max-width: 7ch;
      font-size: 4.45rem;
      line-height: 0.88;
    }

    .poster-lead {
      font-size: 1rem;
      line-height: 1.65;
    }

    .poster-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .poster-button {
      width: 100%;
    }

    .poster-now {
      grid-template-columns: 46px minmax(0, 1fr);
      padding: 16px;
    }

    .poster-play-icon {
      width: 46px;
      height: 46px;
    }

    .poster-track strong {
      font-size: 1.08rem;
    }

    .poster-track small {
      font-size: 0.82rem;
    }

    .poster-panel {
      grid-template-columns: 1fr;
      margin-top: 0;
      padding-top: 22px;
    }

    .poster-links {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .poster-links a {
      min-height: 96px;
      padding: 14px;
    }

    .poster-social {
      padding-bottom: 34px;
    }
  }

  @media (max-width: 380px) {
    .poster-content h1 {
      font-size: 3.85rem;
    }

    .poster-content {
      padding-top: 16svh;
    }

    .poster-now {
      grid-template-columns: 42px minmax(0, 1fr);
      gap: 8px;
      padding: 14px;
    }

    .poster-play-icon {
      width: 42px;
      height: 42px;
    }

    .poster-play-icon::before {
      border-top-width: 8px;
      border-bottom-width: 8px;
      border-left-width: 12px;
    }

    .poster-track {
      gap: 4px;
    }

    .poster-track strong {
      font-size: 1rem;
    }

    .poster-listen-link {
      min-height: 28px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .poster-button,
    .poster-now,
    .poster-links a {
      transition: none;
    }
  }
</style>
