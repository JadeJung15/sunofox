</style>

<script>
  const revealItems = document.querySelectorAll('.bg-reveal');
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.16 });
    revealItems.forEach((item) => observer.observe(item));
  } else {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  }

  const pageRoot = document.documentElement;
  const heroStage = document.querySelector('.bg-hero-stage');
  const journey = document.querySelector('.bg-journey');
  const mobileMenu = document.querySelector('.bg-menu');
  const mobilePanel = document.querySelector('.bg-mobile-panel');

  function clamp(value, min = 0, max = 1) {
    return Math.min(max, Math.max(min, value));
  }

  function updateScrollDetails() {
    const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
    pageRoot.style.setProperty('--scroll-progress', String(clamp(window.scrollY / maxScroll)));

    if (heroStage) {
      const rect = heroStage.getBoundingClientRect();
      const heroProgress = clamp((window.innerHeight - rect.top) / (window.innerHeight + rect.height));
      heroStage.style.setProperty('--hero-progress', heroProgress.toFixed(3));
    }

    if (journey) {
      const rect = journey.getBoundingClientRect();
      const journeyProgress = clamp((window.innerHeight - rect.top) / (window.innerHeight + rect.height));
      journey.style.setProperty('--journey-progress', journeyProgress.toFixed(3));
    }
  }

  updateScrollDetails();
  window.addEventListener('scroll', updateScrollDetails, { passive: true });
  window.addEventListener('resize', updateScrollDetails);

  if (mobileMenu && mobilePanel) {
    const setMobileMenu = (isOpen) => {
      mobileMenu.classList.toggle('is-open', isOpen);
      mobilePanel.classList.toggle('is-open', isOpen);
      mobilePanel.hidden = !isOpen;
      mobileMenu.setAttribute('aria-expanded', String(isOpen));
      document.body.classList.toggle('bg-mobile-menu-open', isOpen);
    };

    mobileMenu.addEventListener('click', () => {
      setMobileMenu(!mobileMenu.classList.contains('is-open'));
    });

    mobilePanel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMobileMenu(false));
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setMobileMenu(false);
      }
    });
  }

  document.querySelectorAll('.bg-tilt').forEach((card) => {
    card.addEventListener('pointermove', (event) => {
      const rect = card.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width - 0.5) * 8;
      const y = ((event.clientY - rect.top) / rect.height - 0.5) * -8;
      card.style.transform = `perspective(900px) rotateX(${y}deg) rotateY(${x}deg)`;
    });
    card.addEventListener('pointerleave', () => {
      card.style.transform = '';
    });
  });
</script>
