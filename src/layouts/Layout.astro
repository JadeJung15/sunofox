---
import '../styles/global.css';
import '../styles/official-shell.css';
import '@phosphor-icons/web/bold';
import { footerItems } from '../data/navigationContent.js';

const {
  title = 'SunoFox 수노폭스 Music to Novel',
  description = 'SunoFox 수노폭스 음악에서 시작한 감정을 웹소설로 확장하는 공식 웹사이트.',
  shareTitle = title,
  shareDescription = description,
  canonical = 'https://sunofox.com/',
  image = 'https://sunofox.com/assets/sunofox-app-icon-512.png',
  imageAlt = 'SunoFox',
  imageWidth = 512,
  imageHeight = 512,
  author = 'SunoFox',
  type = 'website',
  publishedTime = '',
  modifiedTime = '',
  robots = 'index, follow',
  keywords = '',
  articleSection = '',
  articleTags = [],
  jsonLd
} = Astro.props;

const jsonLdString = jsonLd ? JSON.stringify(jsonLd) : '';
const keywordContent = Array.isArray(keywords) ? keywords.filter(Boolean).join(', ') : keywords;
const normalizedArticleTags = Array.isArray(articleTags) ? articleTags.filter(Boolean) : articleTags ? [articleTags] : [];
const imageType = image.match(/\.jpe?g($|\?)/i)
  ? 'image/jpeg'
  : image.match(/\.png($|\?)/i)
    ? 'image/png'
    : image.match(/\.webp($|\?)/i)
      ? 'image/webp'
      : '';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#03030a" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    <meta name="robots" content={robots} />
    <meta property="og:title" content={shareTitle} />
    <meta property="og:description" content={shareDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="SunoFox 수노폭스" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={image} />
    <meta property="og:image:secure_url" content={image} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content={String(imageWidth)} />
    <meta property="og:image:height" content={String(imageHeight)} />
    {imageType && <meta property="og:image:type" content={imageType} />}
    {modifiedTime && <meta property="og:updated_time" content={modifiedTime} />}
    {type === 'article' && <meta property="article:author" content={author} />}
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === 'article' && articleSection && <meta property="article:section" content={articleSection} />}
    {type === 'article' && normalizedArticleTags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@sunofox" />
    <meta name="twitter:domain" content="sunofox.com" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={shareTitle} />
    <meta name="twitter:description" content={shareDescription} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/assets/sunofox-app-icon-192.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/sunofox-app-icon-192.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700;800;900&family=Noto+Serif+KR:wght@500;600;700&display=swap" rel="stylesheet" />
    {jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}
    <slot name="head" />
  </head>
  <body class="page-enter min-h-screen overflow-x-hidden bg-[#050509] text-white">
    <a class="skip-link" href="#main-content">본문으로 건너뛰기</a>
    <slot />
    <footer class="site-footer" aria-label="SunoFox footer">
      <strong>SunoFox</strong>
      <span>© 2026 SunoFox. All rights reserved.</span>
      <nav class="site-footer-nav" aria-label="Footer navigation">
        {footerItems.map((item) => (
          <a href={item.href} data-footer-key={item.key}>{item.label}</a>
        ))}
      </nav>
    </footer>
  </body>
</html>
