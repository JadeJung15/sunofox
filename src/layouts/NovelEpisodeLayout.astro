---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from './Layout.astro';
import {
  createEpisodeStructuredData,
  getEpisodeOst,
  latestNovelEpisode,
  novelEpisodes,
  novelProject
} from '../data/siteContent.js';

const { frontmatter } = Astro.props;

const {
  title = '1화',
  subtitle = '',
  description = '',
  canonical = 'https://sunofox.com/novels/',
  episodeLabel = 'EPISODE 01',
  publishedAt = '',
  readTime = '',
  seriesTitle = '악녀는 첫 장에서 웃었다',
  backHref = '/novels/',
  backLabel = 'NOVEL',
  previousHref = '',
  previousLabel = '이전 화',
  nextHref = '',
  nextLabel = '다음 화'
} = frontmatter;

const currentEpisode = novelEpisodes.find((episode) => episode.href && canonical.endsWith(episode.href)) || novelEpisodes[0];
const currentEpisodeIndex = novelEpisodes.findIndex((episode) => episode === currentEpisode);
const publishedEpisodes = novelEpisodes.filter((episode) => episode.href);
const currentPublishedIndex = publishedEpisodes.findIndex((episode) => episode === currentEpisode);
const currentEpisodeOst = getEpisodeOst(currentEpisode);
const episodePosition = currentPublishedIndex >= 0 ? currentPublishedIndex + 1 : currentEpisodeIndex + 1;
const previousEpisode = currentEpisodeIndex > 0 ? novelEpisodes[currentEpisodeIndex - 1] : null;
const followingEpisode = currentEpisodeIndex >= 0 ? novelEpisodes[currentEpisodeIndex + 1] : null;
const isLatestEpisode = currentEpisode.href === latestNovelEpisode.href;
const resolvedPreviousHref = previousHref || previousEpisode?.href || '';
const resolvedPreviousLabel = previousEpisode ? `${previousEpisode.label} · ${previousEpisode.title}` : previousLabel;
const resolvedNextHref = nextHref || followingEpisode?.href || '';
const resolvedNextLabel = followingEpisode ? `${followingEpisode.label} · ${followingEpisode.title}` : nextLabel;
const isSeasonFinalEpisode = currentEpisode.href === novelProject.season.finalHref;
const nextDisabledText = followingEpisode
  ? `${followingEpisode.label} 준비중 · ${followingEpisode.title}`
  : isSeasonFinalEpisode
    ? `${novelProject.season.label} 완결`
    : '다음 화 준비중';
const episodeMetaKeywords = Array.from(new Set([
  novelProject.title,
  novelProject.genre,
  currentEpisode.label,
  currentEpisode.title,
  ...novelProject.keywords,
  ...(currentEpisode.shareTags || [])
]));
const episodeShareTitle =
  currentEpisode.shareTitle || `${currentEpisode.label}. ${currentEpisode.title} | ${novelProject.title}`;
const episodeShareDescription = currentEpisode.shareDescription || currentEpisode.update || description;
const episodeShareImageAlt = currentEpisode.shareImageAlt || novelProject.coverAlt;
const episodeJsonLd = createEpisodeStructuredData(currentEpisode);
const episodeSummaryItems = [
  { label: '회차 위치', value: `${episodePosition}/${publishedEpisodes.length}` },
  { label: '시즌', value: `${novelProject.season.label} · ${novelProject.season.status}` },
  { label: '공개일', value: publishedAt || currentEpisode.publishedAt },
  { label: '읽기 시간', value: readTime || currentEpisode.readTime }
].filter((item) => item.value);
const episodeRailItems = publishedEpisodes.map((episode) => ({
  ...episode,
  isCurrent: episode.href === currentEpisode.href
}));
const episodeProgressPercent = publishedEpisodes.length > 0
  ? Math.round((episodePosition / publishedEpisodes.length) * 100)
  : 0;
const episodeProgressStyle = `--episode-progress: ${episodeProgressPercent}%`;
const completionActions = [
  { label: '소설 목록', href: backHref, action: 'completion-list' },
  { label: '필모그래피', href: '/#filmography', action: 'completion-music' },
  { label: 'SunoFox 소개', href: '/#about', action: 'completion-profile' }
];
---

<Layout
  title={`${title} | SunoFox 수노폭스`}
  description={episodeShareDescription}
  shareTitle={episodeShareTitle}
  shareDescription={episodeShareDescription}
  canonical={canonical}
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={episodeShareImageAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  type="article"
  publishedTime={currentEpisode.isoDate}
  modifiedTime={currentEpisode.isoDate}
  keywords={episodeMetaKeywords}
  articleSection={novelProject.genre}
  articleTags={episodeMetaKeywords}
  jsonLd={episodeJsonLd}
>
  <SiteChrome active="novels" />

  <main id="main-content" class="site-main anime-home novel-reader-page novel-episode-page">
    <nav class="novel-reader-topbar" aria-label="Episode quick navigation">
      <a href={backHref} data-reader-action="series">{seriesTitle}</a>
      <span>{episodeLabel}</span>
      <a href={currentEpisodeOst.href} target="_blank" rel="noopener noreferrer" data-reader-action="top-ost">OST</a>
    </nav>

    <article class="novel-reader" aria-labelledby="episodeTitle">
      <header class="novel-reader-header reveal">
        <a class="micro-button micro-button-muted novel-reader-back" href={backHref} data-reader-action="back">{backLabel}</a>
        <p class="section-kicker">{episodeLabel}</p>
        <h1 id="episodeTitle">{title}</h1>
        {subtitle && <p class="novel-reader-subtitle">{subtitle}</p>}
        <div class="novel-reader-meta">
          {publishedAt && <span>{publishedAt}</span>}
          {readTime && <span>{readTime}</span>}
          <span>WEB NOVEL</span>
          {isLatestEpisode && <span class="reader-latest-badge">최신화</span>}
        </div>

        <dl class="novel-reader-summary" aria-label="회차 읽기 요약">
          {episodeSummaryItems.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>

        <div class="novel-reader-progress" aria-label={`${novelProject.season.label} 회차 진행`}>
          <div>
            <span>{novelProject.season.label}</span>
            <strong>{episodePosition}/{publishedEpisodes.length}</strong>
          </div>
          <span
            class="novel-reader-progress-bar"
            role="progressbar"
            aria-label={`${currentEpisode.label} 진행 위치`}
            aria-valuemin="1"
            aria-valuemax={publishedEpisodes.length}
            aria-valuenow={episodePosition}
            style={episodeProgressStyle}
          >
            <i aria-hidden="true"></i>
          </span>
        </div>

        <nav class="novel-reader-quicklinks" aria-label="회차 내부 이동">
          <a href="#episodeBody" data-reader-action="quick-body">본문 읽기</a>
          <a href="#episodeIndex" data-reader-action="quick-index">회차 목록</a>
          <a href="#episodeOst" data-reader-action="quick-ost">회차 OST</a>
        </nav>

        <nav class="novel-reader-jumpbar" aria-label="회차 빠른 이동">
          {resolvedPreviousHref ? (
            <a href={resolvedPreviousHref} data-reader-action="jump-previous">
              <span>이전</span>
              <strong>{resolvedPreviousLabel}</strong>
            </a>
          ) : (
            <span aria-disabled="true" data-reader-action="jump-previous-disabled">
              <span>이전</span>
              <strong>첫 화</strong>
            </span>
          )}
          <a href={backHref} data-reader-action="jump-list">
            <span>목록</span>
            <strong>소설 목록</strong>
          </a>
          {resolvedNextHref ? (
            <a href={resolvedNextHref} data-reader-action="jump-next">
              <span>다음</span>
              <strong>{resolvedNextLabel}</strong>
            </a>
          ) : (
            <span aria-disabled="true" data-reader-action="jump-next-disabled" data-reader-state={isSeasonFinalEpisode ? 'season-final' : 'next-pending'}>
              <span>다음</span>
              <strong>{nextDisabledText}</strong>
            </span>
          )}
        </nav>
      </header>

      <section id="episodeBody" class="novel-reader-body" aria-label={`${title} 본문`}>
        <slot />
      </section>

      <section id="episodeIndex" class="novel-reader-index reveal" aria-labelledby="episodeIndexTitle">
        <div>
          <p class="section-kicker">EPISODE INDEX</p>
          <h2 id="episodeIndexTitle">전체 회차</h2>
        </div>
        <nav class="novel-reader-index-links" aria-label="전체 회차 이동">
          {episodeRailItems.map((episode) => (
            <a
              class:list={[episode.isCurrent && 'is-current']}
              href={episode.href}
              aria-current={episode.isCurrent ? 'page' : undefined}
            >
              <span>{episode.label}</span>
              <strong>{episode.title}</strong>
            </a>
          ))}
        </nav>
      </section>

      <section id="episodeOst" class="novel-reader-ost reveal" aria-labelledby="episodeOstTitle">
        <a class="novel-reader-ost-thumb" href={currentEpisodeOst.href} target="_blank" rel="noopener noreferrer" aria-label={`${currentEpisodeOst.title} 감상하기`}>
          <img
            src={currentEpisodeOst.thumbnail}
            alt={currentEpisodeOst.thumbnailAlt}
            width="480"
            height="360"
            loading="lazy"
            decoding="async"
          />
          <span>{currentEpisodeOst.type}</span>
        </a>

        <div class="novel-reader-ost-copy">
          <p class="section-kicker">회차 OST</p>
          <h2 id="episodeOstTitle">{currentEpisodeOst.title}</h2>
          <p>{currentEpisodeOst.summary}</p>
        </div>

        <div class="novel-reader-ost-actions" aria-label="Episode OST links">
          <a class="main-button" href={currentEpisodeOst.href} target="_blank" rel="noopener noreferrer" data-reader-action="ost-primary">OST 감상</a>
          <a class="main-button main-button-muted" href="/#filmography" data-reader-action="music-archive">필모그래피</a>
          <a class="main-button main-button-muted" href={backHref} data-reader-action="work-info">작품 정보</a>
        </div>
      </section>

      <nav class="novel-reader-actions reveal" aria-label="Episode navigation">
        {resolvedPreviousHref && <a class="main-button main-button-muted" href={resolvedPreviousHref} data-reader-action="action-previous">{resolvedPreviousLabel}</a>}
        <a class="main-button main-button-muted" href={backHref} data-reader-action="action-list">목록으로</a>
        <a class="main-button main-button-muted" href={currentEpisodeOst.href} target="_blank" rel="noopener noreferrer" data-reader-action="action-ost">OST 감상</a>
        {resolvedNextHref ? (
          <a class="main-button" href={resolvedNextHref} data-reader-action="action-next">{resolvedNextLabel}</a>
        ) : (
          <span class="main-button novel-next-disabled" aria-disabled="true" data-reader-action="action-next-disabled" data-reader-state={isSeasonFinalEpisode ? 'season-final' : 'next-pending'}>{nextDisabledText}</span>
        )}
      </nav>

      {isSeasonFinalEpisode && (
        <section
          class="novel-reader-completion reveal"
          aria-labelledby="episodeCompletionTitle"
          data-reader-state="season-complete"
        >
          <p class="section-kicker">SEASON COMPLETE</p>
          <h2 id="episodeCompletionTitle">{novelProject.season.title}</h2>
          <p>{novelProject.season.nextPlan}</p>
          <div class="novel-reader-completion-actions" aria-label="미니시즌 완료 후 이동">
            {completionActions.map((action) => (
              <a
                class:list={['main-button', action.action !== 'completion-list' && 'main-button-muted']}
                href={action.href}
                data-reader-action={action.action}
              >
                {action.label}
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </main>
</Layout>
