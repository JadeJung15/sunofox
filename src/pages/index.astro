---
import Layout from '../layouts/Layout.astro';
import SiteChrome from '../components/SiteChrome.astro';
import {
  archiveAlbum,
  artistLinks,
  featuredStoryOst,
  latestChannelVideo,
  latestStoryOst,
  musicArchive,
  novelProject,
  structuredData
} from '../data/siteContent.js';

const latestVideos = musicArchive.videos.slice(0, 4);
const featuredVideo = latestChannelVideo;
const videoTypeLabels = {
  'Web Novel OST': '웹소설 OST',
  'Live Archive': '라이브 아카이브',
  'Anime OP': '애니메이션 오프닝',
  'Anime OST': '애니메이션 OST',
  'Emotional Pop': '이별 감성 팝',
  'Isekai Anime OP': '이세계 애니메이션 오프닝',
  'Dark Fantasy OST': '다크 판타지 OST'
};
const getVideoTypeLabel = (type) => videoTypeLabels[type] || type;
const streamingLinks = [
  { label: 'YouTube Music', href: artistLinks.youtubeMusic, priority: 'primary' },
  { label: 'Spotify', href: artistLinks.spotify, priority: 'primary' },
  { label: 'Apple Music', href: artistLinks.appleMusic, priority: 'primary' },
  { label: 'Melon', href: artistLinks.melon },
  { label: 'Bugs', href: artistLinks.bugs },
  { label: 'VIBE', href: artistLinks.vibe },
  { label: 'FLO', href: artistLinks.flo },
  { label: 'SoundCloud', href: artistLinks.soundcloud }
];
const seriesItems = [
  {
    title: '웹소설 OST',
    text: '웹소설 장면을 위한 보컬 OST와 캐릭터 테마.',
    href: featuredStoryOst.youtubeHref
  },
  {
    title: '애니메이션 오프닝',
    text: '애니메이션 오프닝처럼 빠르게 진입하는 곡과 영상.',
    href: musicArchive.videos.find((video) => video.type.includes('Anime OP'))?.href || artistLinks.youtube
  },
  {
    title: '라이브 아카이브',
    text: '공개곡과 비공개곡을 이어 듣는 긴 호흡의 플레이리스트.',
    href: musicArchive.videos.find((video) => video.type === 'Live Archive')?.href || artistLinks.youtubePlaylists
  }
];
---

<Layout
  title="수노폭스(SunoFox) | 애니메이션 OST와 웹소설 OST"
  description="SunoFox는 애니메이션 장면을 위한 오리지널 OST와 뮤직비디오를 만들고, YouTube와 주요 음원 플랫폼으로 공개하는 음악 채널/스튜디오입니다."
  image={`https://sunofox.com${featuredVideo.thumbnail}`}
  imageAlt={featuredVideo.thumbnailAlt}
  imageWidth={1200}
  imageHeight={675}
  keywords="수노폭스, 애니메이션 OST, 웹소설 OST, 오리지널 OST, SunoFox, Anime OST, YouTube Music, Spotify"
  jsonLd={structuredData}
>
  <SiteChrome active="home" />

  <main id="main-content" class="renewal-home" aria-labelledby="homeTitle">
    <section id="watch" class="funnel-hero" aria-label="수노폭스 애니메이션 OST 대표 영역">
      <div class="funnel-hero-copy">
        <p class="funnel-kicker">애니메이션 OST / 뮤직비디오 스튜디오</p>
        <h1 id="homeTitle">
          <span>오리지널</span>
          <span>애니메이션 OST</span>
        </h1>
        <p class="funnel-lead">
          애니메이션 장면을 위한 오리지널 OST와 뮤직비디오를 만듭니다.
        </p>
        <div class="funnel-hero-actions" aria-label="주요 이동">
          <a class="funnel-button funnel-button-youtube" href={artistLinks.youtubeSubscribe} target="_blank" rel="noopener noreferrer">
            유튜브 구독하기
          </a>
          <a class="funnel-button funnel-button-streaming" href="#listen">
            음원 바로 듣기
          </a>
          <a class="funnel-button funnel-button-ghost" href="#latest">
            최신 영상 보기
          </a>
        </div>
      </div>

      <a class="funnel-featured-video" href={featuredVideo.youtubeHref} target="_blank" rel="noopener noreferrer" aria-label={`${featuredVideo.title} YouTube에서 보기`}>
        <img
          src={featuredVideo.thumbnail}
          alt={featuredVideo.thumbnailAlt}
          width="1200"
          height="675"
          loading="eager"
          decoding="async"
        />
        <span>{getVideoTypeLabel(featuredVideo.type)}</span>
        <strong>{featuredVideo.title}</strong>
        <em>유튜브에서 보기</em>
      </a>
    </section>

    <section id="listen" class="streaming-strip" aria-labelledby="listenTitle">
      <div>
        <p class="funnel-kicker">주요 음원 플랫폼</p>
        <h2 id="listenTitle">음원 바로 듣기</h2>
      </div>
      <nav class="streaming-links" aria-label="음원 플랫폼">
        {streamingLinks.map((link) => (
          <a class:list={['streaming-link', link.priority === 'primary' && 'is-primary']} href={link.href} target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
      </nav>
    </section>

    <section id="latest" class="latest-videos-section" aria-labelledby="latestTitle">
      <div class="funnel-section-head">
        <p class="funnel-kicker">최신 OST/MV</p>
        <h2 id="latestTitle">최신 영상</h2>
        <a href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">유튜브 채널</a>
      </div>

      <div class="latest-video-grid">
        {latestVideos.map((video, index) => (
          <a class:list={['video-card', index === 0 && 'is-featured']} href={video.href} target="_blank" rel="noopener noreferrer">
            <img src={video.thumbnail} alt={video.thumbnailAlt} width="640" height="360" loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
            <span>{getVideoTypeLabel(video.type)}</span>
            <strong>{video.title}</strong>
            <p>{video.meta}</p>
            <em>{video.date}</em>
          </a>
        ))}
      </div>
    </section>

    <section class="featured-release-section" aria-labelledby="releaseTitle">
      <a class="release-cover" href={archiveAlbum.href} aria-label={`${archiveAlbum.title} 앨범 상세 보기`}>
        <img src={archiveAlbum.image} alt={archiveAlbum.imageAlt} width="1600" height="1600" loading="lazy" decoding="async" />
      </a>
      <div class="release-copy">
        <p class="funnel-kicker">대표 OST</p>
        <h2 id="releaseTitle">{archiveAlbum.title}</h2>
        <p>{archiveAlbum.summary}</p>
        <div class="release-actions">
          <a class="funnel-button funnel-button-streaming" href={archiveAlbum.externalHref} target="_blank" rel="noopener noreferrer">지니 앨범</a>
          <a class="funnel-button funnel-button-ghost" href={artistLinks.youtubeMusic} target="_blank" rel="noopener noreferrer">YouTube Music</a>
          <a class="funnel-button funnel-button-ghost" href={artistLinks.spotify} target="_blank" rel="noopener noreferrer">Spotify</a>
        </div>
      </div>
    </section>

    <section class="series-section" aria-labelledby="seriesTitle">
      <div class="funnel-section-head">
        <p class="funnel-kicker">시리즈</p>
        <h2 id="seriesTitle">시리즈 둘러보기</h2>
      </div>
      <div class="series-grid">
        {seriesItems.map((item) => (
          <a class="series-card" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="story-preview-section" aria-labelledby="storyTitle">
      <div>
        <p class="funnel-kicker">음악에서 이야기로</p>
        <h2 id="storyTitle">{novelProject.title}</h2>
        <p>{novelProject.shortSummary}</p>
      </div>
      <div class="story-actions">
        <a class="funnel-button funnel-button-ghost" href={latestStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">OST 감상</a>
        <a class="funnel-button funnel-button-ghost" href={novelProject.season.startHref}>1화 읽기</a>
        <a class="funnel-button funnel-button-ghost" href="/novels/">웹소설 보기</a>
      </div>
    </section>

    <footer class="funnel-footer" aria-label="수노폭스 공개 사이트 하단">
      <span>© SUNOFOX</span>
      <nav aria-label="하단 링크">
        <a href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">유튜브</a>
        <a href="/music/">OST 아카이브</a>
        <a href="/updates/">업데이트</a>
        <a href="/profile/">소개</a>
      </nav>
    </footer>

    <nav class="mobile-sticky-cta" aria-label="모바일 주요 이동">
      <a href={artistLinks.youtubeSubscribe} target="_blank" rel="noopener noreferrer">유튜브 구독</a>
      <a href="#listen">음원 듣기</a>
    </nav>
  </main>
</Layout>

<style>
  :global(body:has(.renewal-home)) {
    margin: 0;
    background: #03030a;
    color: #f8fafc;
    overflow-x: hidden;
  }

  :global(body:has(.renewal-home) .site-footer) {
    display: none;
  }

  :global(body:has(.renewal-home) .site-header) {
    border-bottom: 1px solid rgba(42, 46, 61, 0.72);
    background: rgba(3, 3, 10, 0.92);
    color: #f8fafc;
    backdrop-filter: blur(16px);
    box-sizing: border-box;
    max-width: 100vw;
  }

  :global(body:has(.renewal-home) .site-logo),
  :global(body:has(.renewal-home) .menu-trigger) {
    color: #f8fafc;
  }

  :global(body:has(.renewal-home) .menu-trigger-lines span) {
    background: #f8fafc;
  }

  .renewal-home {
    --bg-base: #03030a;
    --bg-elevated: #0b0d14;
    --bg-raised: #121622;
    --border-subtle: #2a2e3d;
    --text-primary: #f8fafc;
    --text-secondary: #a7adba;
    --text-muted: #6f7687;
    --youtube: #ff0033;
    --streaming: #f5b84b;
    --ost: #4fd8ff;
    display: grid;
    gap: 0;
    min-height: 100svh;
    padding: 0 min(56px, 4.2vw) 54px;
    background:
      radial-gradient(circle at 76% 12%, rgba(255, 0, 51, 0.18), transparent 30rem),
      radial-gradient(circle at 12% 72%, rgba(79, 216, 255, 0.12), transparent 28rem),
      var(--bg-base);
    color: var(--text-primary);
    font-family: Pretendard, "Noto Sans KR", system-ui, sans-serif;
    box-sizing: border-box;
  }

  .renewal-home *,
  .renewal-home *::before,
  .renewal-home *::after {
    box-sizing: border-box;
  }

  .renewal-home :where(h1, h2, h3, p, a, span, strong, em) {
    letter-spacing: 0;
  }

  .renewal-home a {
    color: inherit;
  }

  .renewal-home a:focus-visible {
    outline: 2px solid var(--ost);
    outline-offset: 5px;
  }

  .funnel-hero,
  .streaming-strip,
  .latest-videos-section,
  .featured-release-section,
  .series-section,
  .story-preview-section,
  .funnel-footer {
    width: min(1180px, 100%);
    margin-inline: auto;
  }

  .funnel-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(380px, 0.82fr);
    min-height: min(820px, 100svh);
    align-items: center;
    gap: clamp(34px, 5vw, 72px);
    padding: clamp(112px, 15vh, 148px) 0 72px;
  }

  .funnel-kicker {
    margin: 0;
    color: var(--ost);
    font-family: "Roboto Condensed", sans-serif;
    font-size: 12px;
    font-weight: 900;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .funnel-hero h1,
  .funnel-section-head h2,
  .release-copy h2,
  .story-preview-section h2 {
    margin: 0;
    color: var(--text-primary);
    font-family: "Roboto Condensed", Pretendard, sans-serif;
    font-weight: 900;
    text-transform: uppercase;
  }

  .funnel-hero h1 {
    max-width: 720px;
    margin-top: 18px;
    font-size: clamp(52px, 6.8vw, 86px);
    line-height: 0.95;
    overflow-wrap: break-word;
    word-break: keep-all;
  }

  .funnel-hero h1 span {
    display: block;
  }

  .funnel-lead {
    max-width: 560px;
    margin: 24px 0 0;
    color: var(--text-secondary);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.6;
    overflow-wrap: anywhere;
    word-break: keep-all;
  }

  .funnel-hero-actions,
  .release-actions,
  .story-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .funnel-button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: 0 18px;
    font-size: 14px;
    font-weight: 900;
    line-height: 1;
    text-decoration: none;
  }

  .funnel-button-youtube {
    border-color: transparent;
    background: linear-gradient(135deg, #ff0033, #b91c3c);
    box-shadow: 0 12px 32px rgba(255, 0, 51, 0.24);
    color: #ffffff;
  }

  .funnel-button-streaming {
    border-color: transparent;
    background: linear-gradient(135deg, #f5b84b, #ffdd8a);
    box-shadow: 0 12px 32px rgba(245, 184, 75, 0.22);
    color: #03030a;
  }

  .funnel-button-ghost {
    background: rgba(255, 255, 255, 0.035);
    color: var(--text-primary);
  }

  .funnel-featured-video,
  .video-card,
  .release-cover,
  .series-card {
    border: 1px solid rgba(42, 46, 61, 0.9);
    border-radius: 8px;
    background: rgba(11, 13, 20, 0.84);
    text-decoration: none;
  }

  .funnel-featured-video {
    display: grid;
    overflow: hidden;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
  }

  .funnel-featured-video img,
  .video-card img,
  .release-cover img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .funnel-featured-video img,
  .video-card img {
    aspect-ratio: 16 / 9;
  }

  .funnel-featured-video span,
  .funnel-featured-video strong,
  .funnel-featured-video em {
    margin-inline: 18px;
  }

  .funnel-featured-video span,
  .video-card span,
  .video-card em {
    color: var(--text-muted);
    font-family: "Roboto Condensed", sans-serif;
    font-size: 12px;
    font-style: normal;
    font-weight: 900;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .funnel-featured-video span {
    margin-top: 18px;
  }

  .funnel-featured-video strong {
    margin-top: 8px;
    color: var(--text-primary);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 900;
    line-height: 1.22;
    word-break: keep-all;
  }

  .funnel-featured-video em {
    margin-top: 16px;
    margin-bottom: 18px;
    color: var(--ost);
  }

  .streaming-strip,
  .latest-videos-section,
  .featured-release-section,
  .series-section,
  .story-preview-section {
    border-top: 1px solid var(--border-subtle);
    padding: 72px 0;
  }

  .streaming-strip {
    display: grid;
    grid-template-columns: minmax(180px, 0.28fr) minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  .streaming-strip h2,
  .funnel-section-head h2,
  .release-copy h2,
  .story-preview-section h2 {
    margin-top: 8px;
    font-size: clamp(34px, 4.2vw, 56px);
    line-height: 1;
  }

  .streaming-links {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }

  .streaming-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 900;
    text-decoration: none;
  }

  .streaming-link.is-primary {
    border-color: rgba(245, 184, 75, 0.55);
    color: var(--text-primary);
  }

  .funnel-section-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 14px;
    align-items: end;
    margin-bottom: 26px;
  }

  .funnel-section-head .funnel-kicker {
    grid-column: 1 / -1;
  }

  .funnel-section-head a {
    color: var(--ost);
    font-size: 14px;
    font-weight: 900;
    text-decoration: none;
  }

  .latest-video-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .video-card {
    display: grid;
    overflow: hidden;
    min-width: 0;
  }

  .video-card span,
  .video-card strong,
  .video-card p,
  .video-card em {
    margin-inline: 14px;
  }

  .video-card span {
    margin-top: 14px;
  }

  .video-card strong {
    margin-top: 8px;
    color: var(--text-primary);
    font-size: 18px;
    font-weight: 900;
    line-height: 1.3;
    word-break: keep-all;
  }

  .video-card p {
    margin-top: 8px;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 650;
    line-height: 1.55;
    word-break: keep-all;
  }

  .video-card em {
    margin-top: 14px;
    margin-bottom: 14px;
  }

  .featured-release-section {
    display: grid;
    grid-template-columns: minmax(220px, 340px) minmax(0, 1fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }

  .release-cover {
    display: block;
    overflow: hidden;
  }

  .release-copy p:not(.funnel-kicker),
  .story-preview-section p {
    max-width: 640px;
    margin: 18px 0 0;
    color: var(--text-secondary);
    font-size: 16px;
    font-weight: 650;
    line-height: 1.68;
    word-break: keep-all;
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .series-card {
    display: grid;
    min-height: 150px;
    align-content: space-between;
    padding: 18px;
  }

  .series-card strong {
    color: var(--text-primary);
    font-size: 22px;
    font-weight: 900;
    line-height: 1.16;
  }

  .series-card span {
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 650;
    line-height: 1.55;
    word-break: keep-all;
  }

  .story-preview-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
  }

  .story-actions {
    justify-content: flex-end;
    margin-top: 0;
  }

  .funnel-footer {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    border-top: 1px solid var(--border-subtle);
    padding-top: 22px;
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 900;
  }

  .funnel-footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .funnel-footer a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .mobile-sticky-cta {
    display: none;
  }

  @media (max-width: 1024px) {
    .funnel-hero {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .streaming-strip,
    .featured-release-section,
    .story-preview-section {
      grid-template-columns: 1fr;
    }

    .latest-video-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .story-actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 760px) {
    :global(body:has(.renewal-home) .site-header) {
      padding: 10px 16px;
    }

    :global(body:has(.renewal-home) .menu-trigger) {
      position: fixed;
      top: 10px;
      right: 16px;
      z-index: 85;
      display: inline-flex;
      flex: 0 0 auto;
      gap: 10px;
      min-width: 0;
    }

    :global(body:has(.renewal-home) .menu-trigger-label) {
      display: inline;
      font-size: 12px;
      line-height: 1;
    }

    :global(body:has(.renewal-home) .menu-trigger-lines) {
      width: 28px;
    }

    .renewal-home {
      padding: 0 18px calc(88px + env(safe-area-inset-bottom));
    }

    .funnel-hero {
      gap: 24px;
      padding: 94px 0 52px;
    }

    .funnel-hero h1 {
      max-width: 100%;
      font-size: clamp(34px, 10.2vw, 40px);
      line-height: 0.98;
      overflow-wrap: break-word;
      word-break: keep-all;
    }

    .funnel-lead {
      max-width: 320px;
      margin-top: 18px;
      font-size: 15px;
      word-break: normal;
    }

    .funnel-hero-actions {
      display: grid;
      grid-template-columns: 1fr;
      margin-top: 22px;
    }

    .funnel-hero-actions .funnel-button {
      width: 100%;
      min-width: 0;
    }

