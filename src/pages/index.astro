---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import {
  archiveAlbum,
  artistLinks,
  latestNovelEpisode,
  latestStoryOst,
  musicArchive,
  novelProject,
  publishedNovelEpisodes,
  structuredData
} from '../data/siteContent.js';

const signalAssets = {
  stage: '/assets/release-desk/mask-good-girl.jpg',
  archive: '/assets/release-desk/cozy-drift.jpg',
  console: '/assets/release-desk/control-deck.jpg'
};

const channelDeck = [
  {
    number: '01',
    key: 'ost',
    label: 'OST',
    title: latestStoryOst.title,
    text: '최신 공개곡을 바로 재생합니다.',
    href: latestStoryOst.youtubeHref,
    external: true,
    image: latestStoryOst.thumbnail,
    alt: latestStoryOst.thumbnailAlt
  },
  {
    number: '02',
    key: 'story',
    label: 'Story',
    title: novelProject.title,
    text: `${publishedNovelEpisodes.length}화 미니시즌을 순서대로 읽습니다.`,
    href: '/novels/',
    image: novelProject.coverImage,
    alt: novelProject.coverAlt
  },
  {
    number: '03',
    key: 'archive',
    label: 'Archive',
    title: archiveAlbum.title,
    text: '공개된 음악과 영상을 다시 찾을 수 있게 보관합니다.',
    href: musicArchive.href,
    image: signalAssets.archive,
    alt: 'SunoFox Cozy Drift 앨범 자켓'
  },
  {
    number: '04',
    key: 'studio',
    label: 'Studio',
    title: 'Owner MV Studio',
    text: '제작과 업로드 흐름은 승인된 사용자만 입장합니다.',
    href: '/login?next=/mv-studio',
    image: signalAssets.console,
    alt: 'SunoFox 제작 흐름을 상징하는 미디어 콘솔'
  }
];

const latestVideos = musicArchive.videos.slice(0, 4);
const episodeRail = publishedNovelEpisodes.slice(0, 6);
const latestEpisodeLabel = `${latestNovelEpisode.label} · ${latestNovelEpisode.title}`;
---

<Layout
  title="SunoFox Signal Room | Anime OST Story Studio"
  description="SunoFox Signal Room은 Anime OST, 웹소설 세계관, 음악 아카이브, MV Studio 입구를 라디오 콘솔형 감상 경험으로 연결하는 공식 홈입니다."
  image={`https://sunofox.com${latestStoryOst.thumbnail}`}
  imageAlt={latestStoryOst.thumbnailAlt}
  imageWidth={1200}
  imageHeight={675}
  jsonLd={structuredData}
>
  <SiteChrome active="home" />

  <main id="main-content" class="site-main signal-home">
    <section class="signal-stage reveal" aria-labelledby="signalTitle">
      <img
        class="signal-stage-art"
        src={signalAssets.stage}
        alt="Mask of a Good Girl OST를 상징하는 SunoFox 애니메이션 장면"
        width="1200"
        height="900"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />

      <div class="signal-shell">
        <nav class="signal-frequency" aria-label="SunoFox channels">
          <span class="signal-label">CHANNELS</span>
          {channelDeck.map((channel) => (
            <a
              href={channel.href}
              class:list={['frequency-link', channel.key === 'ost' && 'is-active']}
              target={channel.external ? '_blank' : undefined}
              rel={channel.external ? 'noopener noreferrer' : undefined}
            >
              <span class="frequency-number">{channel.number}</span>
              <span class="frequency-name">{channel.label}</span>
            </a>
          ))}
        </nav>

        <a
          class="signal-turntable"
          href={latestStoryOst.youtubeHref}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${latestStoryOst.title} 감상하기`}
        >
          <span class="turntable-orbit" aria-hidden="true"></span>
          <img
            src={latestStoryOst.thumbnail}
            alt={latestStoryOst.thumbnailAlt}
            width="720"
            height="720"
            loading="eager"
            decoding="async"
          />
          <span class="turntable-core">
            <span>PLAY</span>
            <strong>OST</strong>
          </span>
        </a>

        <div class="signal-copy">
          <p class="signal-label">SIGNAL ROOM</p>
          <h1 id="signalTitle">SunoFox</h1>
          <p>
            첫 화면을 안내문이 아니라 감상 콘솔로 바꿨습니다. OST를 틀고, 소설 회차를 따라가고, 아카이브와 제작실로 바로 이동하는 구조입니다.
          </p>
          <div class="signal-actions">
            <a class="signal-button signal-button-primary" href={latestStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">최신 OST 재생</a>
            <a class="signal-button" href={novelProject.season.startHref}>1화부터 읽기</a>
          </div>
        </div>
      </div>

      <ol class="signal-episode-sequence" aria-label="Story episode sequence">
        {episodeRail.map((episode) => (
          <li>
            <a href={episode.href}>
              <span>{episode.label}</span>
              <strong>{episode.title}</strong>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="broadcast-flow reveal" aria-labelledby="broadcastFlowTitle">
      <div class="broadcast-heading">
        <p class="signal-label">BROADCAST MAP</p>
        <h2 id="broadcastFlowTitle">방문자는 채널을 고르듯 이동합니다.</h2>
        <p>홈의 목적은 설명을 길게 읽히는 것이 아니라, 지금 보고 들을 것을 빠르게 선택하게 만드는 것입니다.</p>
      </div>

      <div class="broadcast-board">
        {channelDeck.map((channel) => (
          <a
            class="broadcast-row"
            href={channel.href}
            target={channel.external ? '_blank' : undefined}
            rel={channel.external ? 'noopener noreferrer' : undefined}
          >
            <img src={channel.image} alt={channel.alt} width="220" height="160" loading="lazy" decoding="async" />
            <span>{channel.number}</span>
            <strong>{channel.title}</strong>
            <p>{channel.text}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="story-console reveal" aria-labelledby="storyConsoleTitle">
      <div class="story-console-copy">
        <p class="signal-label">STORY INPUT</p>
        <h2 id="storyConsoleTitle">{novelProject.title}</h2>
        <p>{novelProject.shortSummary}</p>
        <p class="story-status">{novelProject.season.status} · 최신 {latestEpisodeLabel}</p>
        <div class="signal-actions">
          <a class="signal-button signal-button-primary" href="/novels/">작품 세계관</a>
          <a class="signal-button" href={latestNovelEpisode.href}>완결화 읽기</a>
          <a class="signal-button" href={latestStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">연결 OST</a>
        </div>
      </div>

      <img
        class="story-console-cover"
        src={novelProject.coverImage}
        alt={novelProject.coverAlt}
        width="720"
        height="960"
        loading="lazy"
        decoding="async"
      />
    </section>

    <section class="archive-reel reveal" aria-labelledby="archiveReelTitle">
      <div class="archive-reel-copy">
        <p class="signal-label">ARCHIVE REEL</p>
        <h2 id="archiveReelTitle">공개곡은 목록이 아니라 릴로 쌓입니다.</h2>
        <p>영상 썸네일과 앨범 자켓을 한 화면에서 이어 보여 주어, 음악 아카이브가 단순 게시판처럼 보이지 않게 했습니다.</p>
        <a class="signal-button signal-button-primary" href={musicArchive.href}>음악 아카이브 열기</a>
      </div>

      <div class="reel-collage" aria-label="Latest SunoFox videos">
        <a class="reel-album" href={archiveAlbum.href}>
          <img src={signalAssets.archive} alt="SunoFox Cozy Drift 앨범 자켓" width="640" height="640" loading="lazy" decoding="async" />
          <span>{archiveAlbum.title}</span>
        </a>
        {latestVideos.map((video) => (
          <a class="reel-video" href={video.href} target="_blank" rel="noopener noreferrer">
            <img src={video.thumbnail} alt={video.thumbnailAlt} width="360" height="270" loading="lazy" decoding="async" />
            <span>{video.date}</span>
            <strong>{video.title}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="owner-console reveal" aria-labelledby="ownerConsoleTitle">
      <img
        class="owner-console-image"
        src={signalAssets.console}
        alt="SunoFox 제작 흐름을 상징하는 버튼형 미디어 컨트롤 패널"
        width="960"
        height="720"
        loading="lazy"
        decoding="async"
      />

      <div class="owner-console-copy">
        <p class="signal-label">OWNER OUTPUT</p>
        <h2 id="ownerConsoleTitle">제작실은 무대 뒤에 둡니다.</h2>
        <p>공개 홈은 감상과 읽기에 집중하고, 업로드·스토리보드·MV 제작은 승인된 사용자만 Studio에서 이어갑니다.</p>
        <div class="signal-actions">
          <a class="signal-button signal-button-primary" href="/login?next=/mv-studio">MV Studio 로그인</a>
          <a class="signal-button" href="/updates/">업데이트 로그</a>
          <a class="signal-button" href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">YouTube 채널</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .signal-home {
    --signal-bg: #05080c;
    --signal-ink: #f8fafc;
    --signal-muted: #b8c4d3;
    --signal-soft: #7f90a4;
    --signal-line: rgba(255, 255, 255, 0.18);
    --signal-line-strong: rgba(255, 255, 255, 0.38);
    --signal-panel: rgba(8, 13, 21, 0.82);
    --signal-orange: #ff8a2b;
    --signal-teal: #32d6bc;
    --signal-rose: #f05c7f;
    min-height: 100svh;
    background:
      linear-gradient(180deg, #05080c 0%, #0a0f17 44%, #111820 74%, #f4f2ed 100%);
    color: var(--signal-ink);
  }

  .signal-stage {
    position: relative;
    isolation: isolate;
    min-height: calc(100svh - 1px);
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    background: var(--signal-bg);
  }

  .signal-stage::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background:
      linear-gradient(90deg, rgba(5, 8, 12, 0.98) 0%, rgba(5, 8, 12, 0.72) 48%, rgba(5, 8, 12, 0.28) 100%),
      linear-gradient(180deg, rgba(5, 8, 12, 0.12) 0%, rgba(5, 8, 12, 0.92) 100%),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 88px);
  }

  .signal-stage-art {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 72% 44%;
    filter: saturate(1.05) contrast(1.06);
  }

  .signal-shell {
    display: grid;
    grid-template-columns: 154px minmax(260px, 430px) minmax(0, 1fr);
    gap: 42px;
    align-items: center;
    width: min(1180px, calc(100% - 40px));
    min-height: calc(100svh - 138px);
    margin: 0 auto;
    padding: 112px 0 168px;
  }

  .signal-frequency {
    display: grid;
    gap: 9px;
    min-width: 0;
  }

  .signal-label {
    display: block;
    margin: 0;
    color: var(--signal-orange);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
  }

  .frequency-link {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 10px;
    min-height: 48px;
    align-items: center;
    border-left: 2px solid var(--signal-line);
    padding-left: 12px;
    color: var(--signal-muted);
    transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .frequency-link:hover,
  .frequency-link:focus-visible,
  .frequency-link.is-active {
    border-left-color: var(--signal-orange);
    color: #ffffff;
    transform: translateX(4px);
  }

  .frequency-number,
  .frequency-name {
    min-width: 0;
    color: inherit;
    font-weight: 900;
  }

  .frequency-number {
    color: var(--signal-soft);
    font-size: 0.78rem;
  }

  .frequency-name {
    font-size: 1rem;
  }

  .signal-turntable {
    position: relative;
    display: grid;
    width: min(100%, 430px);
    aspect-ratio: 1;
    place-items: center;
    justify-self: center;
    border-radius: 50%;
    background:
      repeating-radial-gradient(circle, rgba(255, 255, 255, 0.15) 0 1px, transparent 1px 17px),
      linear-gradient(145deg, rgba(255, 138, 43, 0.2), rgba(50, 214, 188, 0.08));
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.16),
      0 32px 90px rgba(0, 0, 0, 0.42);
    transition: transform 180ms ease;
  }

  .signal-turntable:hover,
  .signal-turntable:focus-visible {
    transform: translateY(-4px);
  }

  .turntable-orbit {
    position: absolute;
    inset: 8%;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 50%;
  }

  .signal-turntable img {
    width: 68%;
    aspect-ratio: 1;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 50%;
    object-fit: cover;
    animation: turntableSpin 24s linear infinite;
  }

  .turntable-core {
    position: absolute;
    display: grid;
    width: 112px;
    height: 112px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 50%;
    background: rgba(5, 8, 12, 0.82);
    color: #ffffff;
    text-align: center;
    backdrop-filter: blur(10px);
  }

  .turntable-core span,
  .turntable-core strong {
    color: #ffffff;
    line-height: 1;
  }

  .turntable-core span {
    align-self: end;
    font-size: 0.74rem;
    font-weight: 900;
  }

  .turntable-core strong {
    align-self: start;
    color: var(--signal-orange);
    font-size: 1.28rem;
    font-weight: 950;
  }

  .signal-copy {
    display: grid;
    gap: 16px;
    min-width: 0;
    align-content: center;
  }

  .signal-copy h1,
  .broadcast-heading h2,
  .story-console-copy h2,
  .archive-reel-copy h2,
  .owner-console-copy h2 {
    margin: 0;
    color: #ffffff;
    font-size: 5.4rem;
    font-weight: 950;
    line-height: 0.96;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .signal-copy p,
  .broadcast-heading p,
  .story-console-copy p,
  .archive-reel-copy p,
  .owner-console-copy p,
  .broadcast-row p {
    max-width: 640px;
    margin: 0;
    color: var(--signal-muted);
    font-size: 1.04rem;
    font-weight: 560;
    line-height: 1.72;
    overflow-wrap: anywhere;
    word-break: keep-all;
  }

  .signal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .signal-button {
    display: inline-flex;
    min-width: 0;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--signal-line);
    border-radius: 8px;
    padding: 0 16px;
    background: rgba(8, 13, 21, 0.74);
    color: #ffffff;
    font-size: 0.94rem;
    font-weight: 850;
    text-align: center;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .signal-button:hover,
  .signal-button:focus-visible {
    border-color: var(--signal-orange);
    background: rgba(255, 138, 43, 0.17);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .signal-button-primary {
    border-color: var(--signal-orange);
    background: var(--signal-orange);
    color: #170b03;
  }

  .signal-button-primary:hover,
  .signal-button-primary:focus-visible {
    border-color: var(--signal-teal);
    background: var(--signal-teal);
    color: #03110f;
  }

  .signal-episode-sequence {
    position: absolute;
    right: max(20px, calc((100% - 1180px) / 2));
    bottom: 28px;
    left: max(20px, calc((100% - 1180px) / 2));
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0;
    margin: 0;
    border-top: 1px solid var(--signal-line);
    border-bottom: 1px solid var(--signal-line);
    padding: 0;
    background: rgba(5, 8, 12, 0.68);
    backdrop-filter: blur(14px);
    list-style: none;
  }

  .signal-episode-sequence a {
    display: grid;
    gap: 7px;
    min-height: 90px;
    align-content: center;
    border-right: 1px solid var(--signal-line);
    padding: 14px;
    color: #ffffff;
  }

  .signal-episode-sequence li:last-child a {
    border-right: 0;
  }

  .signal-episode-sequence span,
  .story-status,
  .reel-collage span,
  .broadcast-row span {
    color: var(--signal-orange);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .signal-episode-sequence strong,
  .broadcast-row strong,
  .reel-video strong {
    color: #ffffff;
    font-size: 0.92rem;
    font-weight: 850;
    line-height: 1.34;
  }

  .broadcast-flow,
  .story-console,
  .archive-reel,
  .owner-console {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .broadcast-flow {
    display: grid;
    grid-template-columns: minmax(260px, 360px) minmax(0, 1fr);
    gap: 44px;
    align-items: start;
    padding: 82px 0 74px;
  }

  .broadcast-heading,
  .story-console-copy,
  .archive-reel-copy,
  .owner-console-copy {
    display: grid;
    gap: 16px;
    min-width: 0;
  }

  .broadcast-heading h2,
  .story-console-copy h2,
  .archive-reel-copy h2,
  .owner-console-copy h2 {
    font-size: 3.55rem;
  }

  .broadcast-board {
    display: grid;
    border-top: 1px solid var(--signal-line);
  }

  .broadcast-row {
    display: grid;
    grid-template-columns: 112px 44px minmax(160px, 0.7fr) minmax(0, 1fr);
    gap: 18px;
    align-items: center;
    min-width: 0;
    border-bottom: 1px solid var(--signal-line);
    padding: 16px 0;
  }

  .broadcast-row img {
    width: 112px;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    object-fit: cover;
  }

  .broadcast-row:hover strong,
  .broadcast-row:focus-visible strong {
    color: var(--signal-teal);
  }

  .story-console {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(230px, 320px);
    gap: 38px;
    align-items: center;
    padding: 58px 0;
    border-top: 1px solid var(--signal-line);
    border-bottom: 1px solid var(--signal-line);
  }

  .story-console-cover {
    width: 100%;
    aspect-ratio: 3 / 4;
    border: 1px solid var(--signal-line);
    border-radius: 8px;
    object-fit: cover;
    box-shadow: 0 28px 76px rgba(0, 0, 0, 0.35);
  }

  .archive-reel {
    display: grid;
    grid-template-columns: minmax(270px, 340px) minmax(0, 1fr);
    gap: 34px;
    align-items: start;
    padding: 82px 0 86px;
  }

  .archive-reel-copy .signal-button {
    width: fit-content;
  }

  .reel-collage {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-auto-rows: 146px;
    gap: 12px;
  }

  .reel-album,
  .reel-video {
    position: relative;
    display: block;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--signal-line);
    border-radius: 8px;
    background: var(--signal-panel);
  }

  .reel-album {
    grid-column: span 2;
    grid-row: span 2;
  }

  .reel-album img,
  .reel-video img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .reel-album::after,
  .reel-video::after {
    position: absolute;
    inset: auto 0 0;
    height: 58%;
    content: "";
    background: linear-gradient(180deg, rgba(5, 8, 12, 0), rgba(5, 8, 12, 0.86));
  }

  .reel-album span,
  .reel-video span,
  .reel-video strong {
    position: absolute;
    right: 12px;
    left: 12px;
    z-index: 1;
  }

  .reel-album span,
  .reel-video strong {
    bottom: 12px;
  }

  .reel-video span {
    bottom: 42px;
  }

  .reel-album:hover img,
  .reel-album:focus-visible img,
  .reel-video:hover img,
  .reel-video:focus-visible img {
    transform: scale(1.035);
  }

  .owner-console {
    display: grid;
    grid-template-columns: minmax(280px, 430px) minmax(0, 1fr);
    gap: 42px;
    align-items: center;
    padding: 56px 0 98px;
    border-top: 1px solid var(--signal-line);
  }

  .owner-console-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--signal-line);
    border-radius: 8px;
    object-fit: cover;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.32);
  }

  @keyframes turntableSpin {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 1040px) {
    .signal-shell {
