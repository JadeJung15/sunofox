---
import { menuItems } from '../data/navigationContent.js';
---

<header class="site-header" aria-label="SunoFox header">
  <div class="site-header-inner">
    <a class="site-logo" href="/" aria-label="SunoFox 홈">SunoFox</a>
    <nav class="site-nav" aria-label="주요 메뉴">
      {menuItems.map((item) => (
        <a href={item.href} data-nav-key={item.key}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
