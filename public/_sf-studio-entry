              <label class="mv-field">
                <span>연속 생성 속도</span>
                <select id="mv-batch-speed">
                  <option value="fast" selected>빠름</option>
                  <option value="normal">보통</option>
                  <option value="slow">느림</option>
                </select>
              </label>
