---
import ReleaseCard from '../components/ReleaseCard.astro';
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { archiveVol1, artistLinks, releases } from '../data/siteContent.js';
---

<Layout title="Songs / Novels | SunoFox Anime OST Studio">
  <SiteChrome active="songs" />

  <main class="site-main category-page">
    <section class="category-hero reveal" aria-labelledby="songsTitle">
      <p class="section-kicker">SONGS / NOVELS</p>
      <h1 id="songsTitle">ARCHIVE vol.1</h1>
      <p>
        각 곡은 하나의 장면, 하나의 캐릭터, 하나의 세계관에서 시작됩니다.
        SunoFox의 첫 정규 아카이브를 한 페이지에서 확인하세요.
      </p>
    </section>

    <section class="category-content" aria-label="SunoFox release archive">
      <div class="archive-toolbar reveal">
        <div>
          <span>{archiveVol1.releaseDate} · {archiveVol1.tracks} TRACKS · {archiveVol1.duration}</span>
          <strong>{archiveVol1.title}</strong>
          <p>{archiveVol1.summary}</p>
        </div>
        <a class="main-button" href={artistLinks.youtubePlaylists} target="_blank" rel="noopener noreferrer" data-track="songs_youtube_playlist">
          PLAYLIST
        </a>
      </div>

      <div class="release-grid">
        {releases.map((release) => <ReleaseCard release={release} />)}
      </div>
    </section>
  </main>
</Layout>
