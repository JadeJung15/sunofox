---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import {
  categorizedSiteUpdates,
  novelProject,
  pinnedUpdateNotice,
  plannedContentHubs,
  siteUpdates,
  siteUpdatesStructuredData,
  updateCategories
} from '../data/siteContent.js';

const visibleSiteUpdates = siteUpdates.slice(0, 12);
const hiddenUpdateCount = Math.max(0, siteUpdates.length - visibleSiteUpdates.length);
---

<Layout
  title="SunoFox Updates | Official Log"
  description="SunoFox 공식 사이트의 웹소설, OST, Music Archive, 운영 개선 이력을 정리한 업데이트 로그입니다."
  canonical="https://sunofox.com/updates/"
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  jsonLd={siteUpdatesStructuredData}
>
  <SiteChrome active="updates" />

  <main id="main-content" class="site-main category-page updates-page">
    <section class="category-hero" aria-labelledby="updatesTitle">
      <p class="section-kicker">업데이트</p>
      <h1 id="updatesTitle">업데이트 로그</h1>
      <p>웹소설 공개, OST 연결, 음악 아카이브, 사이트 운영 개선 이력을 한 곳에 기록합니다.</p>
    </section>

    <section class="updates-pinned-section reveal" aria-labelledby="updatesPinnedTitle">
      <div>
        <p class="section-kicker">{pinnedUpdateNotice.kicker}</p>
        <h2 id="updatesPinnedTitle">{pinnedUpdateNotice.title}</h2>
        <p>{pinnedUpdateNotice.summary}</p>
      </div>
      <span>{pinnedUpdateNotice.status}</span>
      <div class="updates-pinned-actions">
        {pinnedUpdateNotice.links.map((link) => (
          <a class="micro-button micro-button-muted" href={link.href}>{link.label}</a>
        ))}
      </div>
    </section>

    <section class="updates-hub-section reveal" aria-labelledby="updatesHubTitle">
      <div class="novel-section-head">
        <p class="section-kicker">공지 허브</p>
        <h2 id="updatesHubTitle">운영 카테고리</h2>
        <span>{updateCategories.length}개 분류</span>
      </div>

      <div class="updates-hub-grid">
        {updateCategories.map((category) => (
          <article>
            <span>{category.label}</span>
            <strong>{category.countLabel}</strong>
            <p>{category.summary}</p>
            <a class="micro-button micro-button-muted" href={category.href}>{category.cta}</a>
          </article>
        ))}
      </div>
    </section>

    <section id="content-roadmap" class="updates-roadmap-section reveal" aria-labelledby="contentRoadmapTitle">
      <div class="novel-section-head">
        <p class="section-kicker">콘텐츠 허브</p>
        <h2 id="contentRoadmapTitle">확장 현황</h2>
        <span>{plannedContentHubs.length}개 허브</span>
      </div>

      <div class="updates-roadmap-grid">
        {plannedContentHubs.map((hub) => (
          <article
            class:list={['updates-roadmap-card', !hub.href && 'is-waiting']}
            data-hub-key={hub.key}
            data-hub-visibility={hub.visibility}
          >
            <span>{hub.status}</span>
            <strong>{hub.label}</strong>
            <p>{hub.summary}</p>
            <small class="updates-roadmap-visibility">{hub.visibility}</small>
            <p class="updates-roadmap-next">{hub.nextAction}</p>
            {hub.confirmBeforePublish?.length > 0 && (
              <div class="updates-roadmap-checklist" aria-label={`${hub.label} 공개 전 확인 필요`} data-hub-checklist={hub.key}>
                <span>확인 필요</span>
                <ul>
                  {hub.confirmBeforePublish.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            )}
            {hub.href ? (
              <a class="micro-button micro-button-muted" href={hub.href}>{hub.cta}</a>
            ) : (
              <span class="micro-button micro-button-muted updates-roadmap-disabled" aria-disabled="true" data-hub-state="waiting">{hub.cta}</span>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="updates-log" class="updates-log-section reveal" aria-labelledby="updatesLogTitle">
      <div class="novel-section-head">
        <p class="section-kicker">공식 기록</p>
        <h2 id="updatesLogTitle">최근 업데이트</h2>
        <span>최근 {visibleSiteUpdates.length}건 / 전체 {siteUpdates.length}건</span>
      </div>
      <p class="updates-log-intro">
        공개 페이지에서는 최근 변경만 빠르게 확인하도록 압축했습니다.
        {hiddenUpdateCount > 0 && <> 이전 {hiddenUpdateCount}건은 아래 카테고리별 기록에서 이어서 확인할 수 있습니다.</>}
      </p>

      <ol class="updates-log-list">
        {visibleSiteUpdates.map((item) => (
          <li>
            <div class="updates-log-meta">
              <time datetime={item.date.replaceAll('.', '-')}>{item.date}</time>
              <span>{item.type}</span>
            </div>
            <div class="updates-log-copy">
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <div class="updates-log-actions">
                {item.links.map((link) => (
                  <a href={link.href} class="micro-button micro-button-muted" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="updates-category-section reveal" aria-labelledby="updatesCategoryTitle">
      <div class="novel-section-head">
        <p class="section-kicker">카테고리 기록</p>
        <h2 id="updatesCategoryTitle">카테고리별 기록</h2>
        <span>{categorizedSiteUpdates.length}개 활성 분류</span>
      </div>

      <div class="updates-category-grid">
        {categorizedSiteUpdates.map((category) => (
          <article id={`updates-category-${category.key}`}>
            <div class="updates-category-head">
              <span>{category.label}</span>
              <strong>{category.countLabel}</strong>
            </div>
            <ol>
              {category.updates.slice(0, 6).map((item) => (
                <li>
                  <time datetime={item.date.replaceAll('.', '-')}>{item.date}</time>
                  <a href={item.links[0]?.href || '#updates-log'}>{item.title}</a>
                </li>
              ))}
            </ol>
            {category.updates.length > 6 && (
              <p class="updates-category-more">이전 {category.updates.length - 6}건은 운영 로그 데이터에 보관됩니다.</p>
            )}
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
