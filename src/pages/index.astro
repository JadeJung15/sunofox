---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { artistLinks, media, news, releases, series, structuredData } from '../data/siteContent.js';

const wordmark = 'SUNOFOX'.split('');
const heroParticles = Array.from({ length: 42 });
const featuredRelease = releases[0];
const featuredSeries = series.slice(0, 2);
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <SiteChrome active="home" />

  <main class="site-main landing-main">
    <section class="hero-stage hero-stage-landing" aria-labelledby="heroTitle">
      <div class="hero-particle-layer" aria-hidden="true">
        {heroParticles.map((_, index) => (
          <span style={`--particle-index: ${index + 1}`}></span>
        ))}
      </div>

      <div class="hero-center reveal">
        <p class="hero-kicker">ANIME OST STUDIO</p>
        <h1 id="heroTitle" class="hero-wordmark sign-wordmark" aria-label="SUNOFOX">
          {wordmark.map((letter, index) => (
            <span aria-hidden="true" style={`--letter-index: ${index}`}>{letter}</span>
          ))}
        </h1>
        <p class="hero-tagline">
          Animation soundtracks painted with emotion.
        </p>
        <p class="hero-subcopy">
          Each release begins as a scene, then becomes a song, a character, and a world.
        </p>
      </div>

      <div class="hero-side-actions" aria-label="SunoFox quick actions">
        <a class="main-button" href="/profile" data-track="home_profile">PROFILE</a>
        <a class="main-button main-button-muted" href={artistLinks.youtubeSubscribe} target="_blank" rel="noopener noreferrer" data-track="home_youtube_subscribe">SUBSCRIBE</a>
      </div>

      <p class="landing-note">SCROLL DOWN</p>
    </section>

    <section class="home-section home-subscribe-panel reveal" aria-label="Subscribe to SunoFox updates">
      <div>
        <p class="section-kicker">JOIN THE STORY</p>
        <h2>SUBSCRIBE</h2>
      </div>
      <p>신곡, 영상, 시리즈 업데이트를 YouTube에서 가장 먼저 확인해 주세요.</p>
      <a class="main-button" href={artistLinks.youtubeSubscribe} target="_blank" rel="noopener noreferrer" data-track="home_subscribe_panel">YOUTUBE</a>
    </section>

    <section class="home-section home-community-panel reveal" aria-label="SunoFox fan community">
      <div>
        <p class="section-kicker">FAN BOARD</p>
        <h2>COMMUNITY</h2>
      </div>
      <p>듣고 싶은 분위기, 장르, 캐릭터 아이디어를 함께 모으는 팬 소통 공간을 준비하고 있습니다.</p>
      <div class="home-community-actions">
        <a class="main-button" href="/community" data-track="home_community">FAN BOARD</a>
        <a class="main-button main-button-muted" href="/contact" data-track="home_send_idea">SEND IDEA</a>
      </div>
    </section>

    <section class="home-section home-news-media" aria-labelledby="homeNewsTitle">
      <div class="home-duo-grid">
        <article class="home-panel reveal">
          <div class="home-panel-head">
            <p class="section-kicker">NEWS</p>
            <h2 id="homeNewsTitle">NEWS</h2>
          </div>
          <div class="home-news-list">
            {news.slice(0, 3).map((item) => (
              <a class="home-news-item" href={item.href}>
                <time datetime={item.isoDate}>{item.date}</time>
                <strong>{item.title}</strong>
                <span>{item.body}</span>
              </a>
            ))}
          </div>
          <a class="main-button home-more-button" href="/news">MORE</a>
        </article>

        <article class="home-panel reveal">
          <div class="home-panel-head">
            <p class="section-kicker">MEDIA</p>
            <h2>MEDIA</h2>
          </div>
          <div class="home-media-list">
            {media.map((item) => (
              <a class="home-media-item" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                <span>{item.label}</span>
                <strong>{item.title}</strong>
              </a>
            ))}
          </div>
          <a class="main-button home-more-button" href="/media">MORE</a>
        </article>
      </div>
    </section>

    <section class="home-section home-songs-series" aria-labelledby="homeSongsTitle">
      <div class="home-feature-grid">
        <div class="home-feature-heading reveal">
          <p class="section-kicker">SONGS / NOVELS</p>
          <h2 id="homeSongsTitle">ARCHIVE vol.1</h2>
          <p>Each track begins as a scene, a character, and a world.</p>
          <a class="main-button" href="/songs">SONGS</a>
        </div>

        <a class="home-feature-release reveal" href="/songs" aria-label={`${featuredRelease.title} 상세 보기`}>
          <img src={featuredRelease.image} alt={`${featuredRelease.title} album artwork`} loading="lazy" />
          <div>
            <span>LATEST RELEASE</span>
            <strong>{featuredRelease.title}</strong>
            <p>{featuredRelease.tag}</p>
          </div>
        </a>

        <div class="home-series-mini reveal" aria-label="SunoFox series preview">
          {featuredSeries.map((item) => (
            <a href="/series">
              <span>{item.number}</span>
              <strong>{item.title}</strong>
              <p>{item.ko}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
