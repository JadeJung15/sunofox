---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import {
  artistLinks,
  featuredStoryOst,
  latestNovelEpisode,
  musicArchive,
  novelEpisodes,
  novelProject,
  publishedNovelEpisodes,
  novelStructuredData
} from '../data/siteContent.js';

const novelListCta = '소설 보러가기';
const latestEpisodeTitle = `${latestNovelEpisode.label} · ${latestNovelEpisode.title}`;
const firstNovelEpisode = publishedNovelEpisodes[0];
const seasonStatus = novelProject.season;
const totalReadMinutes = publishedNovelEpisodes.reduce((sum, episode) => {
  const minutes = Number(episode.readTime?.match(/\d+/)?.[0] || 0);
  return sum + minutes;
}, 0);
const novelListPrimaryActions = [
  { label: '1화부터 읽기', href: firstNovelEpisode?.href || seasonStatus.startHref, primary: true },
  { label: '완결화 보기', href: seasonStatus.finalHref },
  { label: 'OST 감상', href: artistLinks.featuredOst, external: true }
];
const novelListSummaryItems = [
  { label: '공개 회차', value: `${publishedNovelEpisodes.length}화` },
  { label: '예상 읽기', value: `약 ${totalReadMinutes}분` },
  { label: '최신 공개', value: latestNovelEpisode.publishedAt },
  { label: '현재 상태', value: `${latestNovelEpisode.label}까지 공개` }
];
const seasonStatusItems = [
  { label: '구성', value: `${seasonStatus.label} · ${publishedNovelEpisodes.length}화` },
  { label: '상태', value: seasonStatus.status },
  { label: '완결일', value: seasonStatus.completedAt }
];
const worldAnchorItems = novelProject.world.pillars.map((item) => ({
  label: item.label,
  href: item.href || '#world'
}));
const characterAnchorItems = novelProject.characters.map((character) => ({
  label: character.name,
  href: character.href || '#characters'
}));
---

<Layout
  title={`${novelProject.title} | SunoFox`}
  description={novelProject.shortSummary}
  canonical="https://sunofox.com/novels/"
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  jsonLd={novelStructuredData}
>
  <SiteChrome active="novels" />

  <main id="main-content" class="site-main novel-detail-page">
    <section class="novel-detail-hero reveal" aria-labelledby="novelsTitle">
      <div class="novel-detail-cover">
        <img
          src={novelProject.coverImage}
          alt={novelProject.coverAlt}
          width={novelProject.coverWidth}
          height={novelProject.coverHeight}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>

      <div class="novel-detail-copy">
        <p class="section-kicker">{novelProject.type}</p>
        <h1 id="novelsTitle">{novelProject.title}</h1>
        <p class="novel-platform-en">{novelProject.englishTitle}</p>
        <p class="novel-detail-summary">{novelProject.summary}</p>

        <dl class="novel-info-list">
          {novelProject.infoRows.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>

        <div class="novel-platform-actions">
          <a class="main-button" href="#episodes">{novelListCta}</a>
          <a class="main-button main-button-muted" href={musicArchive.href}>음악 아카이브</a>
          <a class="main-button main-button-muted" href="/mv-studio">스튜디오</a>
        </div>
      </div>
    </section>

    <section class="novel-detail-tabs reveal" aria-label="작품 탭">
      <a href="#episodes">소설 목록</a>
      <a href="#world">세계관</a>
      <a href="#characters">인물</a>
    </section>

    <section id="episodes" class="novel-episode-list reveal" aria-labelledby="episodeListTitle">
      <div class="novel-section-head">
        <p class="section-kicker">EPISODES</p>
        <h2 id="episodeListTitle">소설 목록</h2>
        <span>{publishedNovelEpisodes.length}화 공개 · 최신 {latestEpisodeTitle}</span>
      </div>

      <div class="novel-list-toolbar" aria-label="소설 빠른 이동">
        <div class="novel-list-toolbar-copy">
          <p class="section-kicker">READ ORDER</p>
          <h3>1화부터 바로 읽기</h3>
          <p>첫 미니시즌은 6화 완결입니다. 처음부터 읽거나 완결화로 바로 이동하세요.</p>
        </div>
        <a class="novel-list-featured" href={latestNovelEpisode.href} aria-label={`${latestEpisodeTitle} 바로 읽기`}>
          <span>완결화</span>
          <strong>{latestEpisodeTitle}</strong>
          <small>{latestNovelEpisode.readTime}</small>
        </a>
        <div class="novel-list-actions">
          {novelListPrimaryActions.map((action) => (
            <a
              class:list={['micro-button', !action.primary && 'micro-button-muted']}
              href={action.href}
              target={action.external ? '_blank' : undefined}
              rel={action.external ? 'noopener noreferrer' : undefined}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>

      <dl class="novel-list-summary" aria-label="소설 공개 요약">
        {novelListSummaryItems.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>

      <section class="novel-season-status" aria-labelledby="seasonStatusTitle">
        <div class="novel-season-copy">
          <p class="section-kicker">MINI SEASON</p>
          <h3 id="seasonStatusTitle">{seasonStatus.title}</h3>
          <p>{seasonStatus.summary}</p>
        </div>
        <dl class="novel-season-facts" aria-label="미니시즌 상태">
          {seasonStatusItems.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd>{item.value}</dd>
            </div>
          ))}
        </dl>
        <div class="novel-season-actions">
          <a class="micro-button" href={seasonStatus.startHref}>1화부터 정주행</a>
          <a class="micro-button micro-button-muted" href={seasonStatus.finalHref}>완결화 보기</a>
        </div>
      </section>

      <section class="novel-reading-path" aria-labelledby="readingPathTitle">
        <div class="novel-reading-path-head">
          <p class="section-kicker">READING PATH</p>
          <h3 id="readingPathTitle">읽는 흐름</h3>
        </div>
        <div class="novel-reading-grid">
          {novelProject.readingPath.map((path) => (
            <a class="novel-reading-card" href={path.href} aria-label={`${path.range} ${path.title}부터 읽기`}>
              <span>{path.range}</span>
              <strong>{path.title}</strong>
              <p>{path.text}</p>
            </a>
          ))}
        </div>
      </section>

      <div class="novel-episode-rows">
        {novelEpisodes.map((episode) => (
          episode.href ? (
            <a
              class:list={['novel-episode-row', episode === latestNovelEpisode && 'is-latest']}
              href={episode.href}
              aria-label={`${episode.label} ${episode.title} 읽기`}
            >
              <span>{episode.number}</span>
              <div>
                <strong>{episode.title}</strong>
                <p>{episode.hook}</p>
                <small class="novel-episode-meta">
                  <span>{episode.status}</span>
                  {episode.readTime && <span>{episode.readTime}</span>}
                  {episode === latestNovelEpisode && <span>최신화</span>}
                </small>
                <span class="novel-episode-tags" aria-label={`${episode.label} 키워드`}>
                  {episode.shareTags.map((tag) => <i>{tag}</i>)}
                </span>
              </div>
              <em>{episode.publishedAt}</em>
              <b>{episode === latestNovelEpisode ? '완결화 읽기' : '읽기'}</b>
            </a>
          ) : (
            <article class="novel-episode-row is-upcoming" aria-disabled="true">
              <span>{episode.number}</span>
              <div>
                <strong>{episode.title}</strong>
                <p>{episode.hook}</p>
                <small class="novel-episode-meta">
                  <span>{episode.status}</span>
                  {episode.readTime && <span>{episode.readTime}</span>}
                </small>
                {episode.shareTags && (
                  <span class="novel-episode-tags" aria-label={`${episode.label} 키워드`}>
                    {episode.shareTags.map((tag) => <i>{tag}</i>)}
                  </span>
                )}
              </div>
              <em>{episode.publishedAt}</em>
              <b>{episode.status}</b>
            </article>
          )
        ))}
      </div>
    </section>

    <section id="about" class="novel-detail-info reveal" aria-label="작품 정보">
      <div>
        <p class="section-kicker">ABOUT</p>
        <h2>원작의 첫 장을 깨는 악녀</h2>
      </div>
      <p>{novelProject.shortSummary}</p>
      <blockquote>{novelProject.systemLine}</blockquote>
    </section>

    <section id="world" class="novel-world-section reveal" aria-labelledby="novelWorldTitle">
      <div class="novel-section-head">
        <p class="section-kicker">세계관</p>
        <h2 id="novelWorldTitle">{novelProject.world.title}</h2>
        <span>{novelProject.world.pillars.length}개 포인트</span>
      </div>
      <p class="novel-world-summary">{novelProject.world.summary}</p>
      <nav class="novel-anchor-strip" aria-label="세계관 빠른 이동">
        {worldAnchorItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
      <div class="novel-world-grid">
        {novelProject.world.pillars.map((item) => (
          <article id={item.id}>
            <a class="novel-card-anchor" href={item.href} aria-label={`${item.label} 세계관 카드로 이동`}>{item.label}</a>
            <strong>{item.title}</strong>
            {item.status && <small>{item.status}</small>}
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="characters" class="novel-character-section reveal" aria-labelledby="novelCharacterTitle">
      <div class="novel-section-head">
        <p class="section-kicker">주요 인물</p>
        <h2 id="novelCharacterTitle">첫 장을 흔드는 사람들</h2>
        <span>{novelProject.characters.length}명</span>
      </div>
      <nav class="novel-anchor-strip" aria-label="주요 인물 빠른 이동">
        {characterAnchorItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
      <div class="novel-character-grid">
        {novelProject.characters.map((character) => (
          <article id={character.id}>
            <a class="novel-card-anchor" href={character.href} aria-label={`${character.name} 인물 카드로 이동`}>{character.role}</a>
            <h3>{character.name}</h3>
            {(character.status || character.firstSeen) && (
              <small>{[character.status, character.firstSeen].filter(Boolean).join(' · ')}</small>
            )}
            <p>{character.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="ost" class="novel-ost-panel reveal" aria-label="작품 OST">
      <a class="novel-ost-thumb" href={featuredStoryOst.href} target="_blank" rel="noopener noreferrer" aria-label={`${featuredStoryOst.title} 감상하기`}>
        <img
          src={featuredStoryOst.thumbnail}
          alt={featuredStoryOst.thumbnailAlt}
          width="480"
          height="360"
          loading="lazy"
          decoding="async"
        />
        <span>{featuredStoryOst.type}</span>
      </a>
      <div>
        <p class="section-kicker">OST</p>
        <h2>{featuredStoryOst.title}</h2>
      </div>
      <p>{featuredStoryOst.summary}</p>
      <div class="novel-ost-actions">
        <a class="main-button" href={artistLinks.featuredOst} target="_blank" rel="noopener noreferrer">OST 감상하기</a>
        <a class="main-button main-button-muted" href={musicArchive.href}>음악 아카이브</a>
      </div>
    </section>

    <section id="keywords" class="novel-keyword-row novel-keyword-section reveal" aria-label="작품 키워드">
      {novelProject.keywords.map((keyword) => <span>{keyword}</span>)}
    </section>
  </main>
</Layout>
