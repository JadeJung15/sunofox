---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { media, platformLinks, releases } from '../data/siteContent.js';

const latestRelease = releases[0];
const latestEmbed = `https://www.youtube.com/embed/${latestRelease.youtubeId}`;
---

<Layout title="Media | SunoFox Anime OST Studio">
  <SiteChrome active="media" />

  <main class="site-main category-page">
    <section class="category-hero reveal" aria-labelledby="mediaTitle">
      <p class="section-kicker">MEDIA</p>
      <h1 id="mediaTitle">MEDIA</h1>
      <p>최신 영상, 스트리밍, 국내 음원 플랫폼을 빠르게 확인합니다.</p>
    </section>

    <section class="category-content" aria-label="SunoFox media links">
      <div class="media-feature reveal">
        <div class="media-feature-copy">
          <span>LATEST VIDEO</span>
          <h2>{latestRelease.title}</h2>
          <p>{latestRelease.desc}</p>
        </div>
        <div class="media-player-frame">
          <iframe
            src={latestEmbed}
            title={`${latestRelease.title} YouTube player`}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="media-grid media-grid-page">
        {media.map((item) => (
          <a class="media-card reveal" href={item.href} target="_blank" rel="noopener noreferrer">
            <span>{item.label}</span>
            <strong>{item.title}</strong>
          </a>
        ))}
      </div>

      <div class="platform-strip reveal" aria-label="SunoFox platform links">
        {platformLinks.map((item) => (
          <a href={item.href} target="_blank" rel="noopener noreferrer" data-track={`media_${item.label.toLowerCase().replaceAll(' ', '_')}`}>
            <span>{item.label}</span>
            <strong>{item.title}</strong>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
