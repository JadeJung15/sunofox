---
import SiteChrome from '../../components/SiteChrome.astro';
import Layout from '../../layouts/Layout.astro';
import { communityPosts } from '../../data/siteContent.js';

const initialPostsJson = JSON.stringify(communityPosts).replace(/</g, '\\u003c');
---

<Layout
  title="Community Post | SunoFox Anime OST Studio"
  description="SunoFox 팬게시판 게시글 상세 보기입니다."
  canonical="https://sunofox.com/community/post/"
>
  <SiteChrome active="community" />

  <main class="site-main category-page community-page community-detail-page">
    <section class="category-hero reveal" aria-labelledby="communityPostTitle">
      <p class="section-kicker">COMMUNITY</p>
      <h1 id="communityPostTitle">POST DETAIL</h1>
      <p>팬게시판의 글, 댓글, 반응을 한 화면에서 확인합니다.</p>
    </section>

    <section class="community-detail-shell reveal" aria-live="polite">
      <a class="community-back-link" href="/community/">← FAN BOARD</a>
      <div class="community-board-message" data-detail-message>게시글을 불러오는 중입니다.</div>

      <article class="community-detail-post" data-detail-post hidden>
        <div class="community-post-meta">
          <span data-detail-board>COMMUNITY</span>
          <time data-detail-date></time>
        </div>
        <div class="community-post-main">
          <h2 data-detail-title></h2>
          <p data-detail-body></p>
          <div>
            <span data-detail-author></span>
            <span data-detail-comments></span>
            <span class="community-status-chip" data-detail-status></span>
          </div>
          <div class="community-post-actions">
            <button type="button" data-detail-reaction data-value="1">LIKE <strong data-detail-likes>0</strong></button>
            <button type="button" data-detail-report-post>REPORT</button>
          </div>
          <p class="community-sample-note" data-detail-sample-note hidden>SAMPLE 게시글은 팬게시판 운영 예시입니다. 실제 댓글, 좋아요, 신고는 가입 승인된 계정과 실제 게시글에서 사용할 수 있습니다.</p>
        </div>
      </article>

      <section class="community-comments community-detail-comments" data-detail-comments-panel hidden>
        <div class="community-comment-head">
          <div>
            <span>COMMENTS</span>
            <h2>팬들의 의견</h2>
          </div>
          <p>승인된 계정으로 로그인하면 게시글에 댓글을 남길 수 있습니다.</p>
        </div>
        <div class="community-comments-list" data-detail-comments-list>
          <p>댓글을 불러오는 중입니다.</p>
        </div>
        <form class="community-comment-form" data-detail-comment-form>
          <textarea name="body" rows="3" maxlength="1200" required placeholder="댓글을 입력해 주세요. 승인된 계정만 작성할 수 있습니다."></textarea>
          <div class="community-comment-actions">
            <button type="submit">COMMENT</button>
            <a href="/login?next=/community/post/" data-detail-login-link>LOGIN</a>
            <a href="/signup">JOIN</a>
          </div>
        </form>
        <p class="community-comment-message" data-detail-comment-message role="status" aria-live="polite"></p>
      </section>
    </section>
  </main>

  <div class="community-report-modal" data-community-report-modal hidden>
    <div class="community-report-card" role="dialog" aria-modal="true" aria-labelledby="communityReportTitle">
      <form data-community-report-form>
        <div class="community-report-head">
          <span>REPORT</span>
          <h2 id="communityReportTitle">신고 사유 선택</h2>
          <button type="button" data-community-report-close aria-label="신고 창 닫기">×</button>
        </div>
        <label>
          <span>신고 사유</span>
          <select name="reason" required>
            <option value="">선택해 주세요</option>
            <option value="스팸 또는 광고">스팸 또는 광고</option>
            <option value="욕설 또는 비방">욕설 또는 비방</option>
            <option value="개인정보 노출">개인정보 노출</option>
            <option value="저작권 문제">저작권 문제</option>
            <option value="부적절한 내용">부적절한 내용</option>
            <option value="기타">기타</option>
          </select>
        </label>
        <label>
          <span>상세 내용</span>
          <textarea name="detail" rows="4" maxlength="1000" placeholder="운영자가 확인할 수 있도록 필요한 내용만 간단히 적어 주세요."></textarea>
        </label>
        <div class="community-report-actions">
          <button type="button" data-community-report-cancel>취소</button>
          <button type="submit">신고 접수</button>
        </div>
      </form>
    </div>
  </div>

  <script id="communityInitialPosts" type="application/json" set:html={initialPostsJson}></script>
  <script is:inline>
    function initCommunityPostDetail() {
      const params = new URLSearchParams(window.location.search);
      const postId = params.get('id') || '';
      const initialPosts = JSON.parse(document.getElementById('communityInitialPosts')?.textContent || '[]');
      const message = document.querySelector('[data-detail-message]');
      const postRoot = document.querySelector('[data-detail-post]');
      const commentsPanel = document.querySelector('[data-detail-comments-panel]');
      const commentsList = document.querySelector('[data-detail-comments-list]');
      const commentForm = document.querySelector('[data-detail-comment-form]');
      const commentMessage = document.querySelector('[data-detail-comment-message]');
      const reactionButton = document.querySelector('[data-detail-reaction]');
      const postReportButton = document.querySelector('[data-detail-report-post]');
      const sampleNote = document.querySelector('[data-detail-sample-note]');
      const detailLoginLinks = [...document.querySelectorAll('[data-detail-login-link]')];
      const reportModal = document.querySelector('[data-community-report-modal]');
      const reportForm = document.querySelector('[data-community-report-form]');
      const reportCloseButtons = [...document.querySelectorAll('[data-community-report-close], [data-community-report-cancel]')];
      let activePostId = postId;
      let pendingReport = null;
      let reportReturnFocus = null;
      let communityToastTimer = 0;

      detailLoginLinks.forEach((link) => {
        link.href = `/login?next=${encodeURIComponent(`${window.location.pathname}${window.location.search}`)}`;
      });

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function formatDate(value) {
        if (!value) return '';
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return String(value);
        return new Intl.DateTimeFormat('ko-KR', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit'
        }).format(parsed).replace(/\s/g, '');
      }

      function normalizePost(post) {
        return {
          id: post.id || '',
          category: post.boardName || post.category || 'COMMUNITY',
          title: post.title || '',
          body: post.body || post.excerpt || '',
          author: post.authorName || post.author || 'Fan',
          date: formatDate(post.createdAt || post.date),
          comments: Number(post.commentCount ?? post.comments ?? 0),
          likes: Number(post.likeCount || 0),
          status: post.pinned ? 'PINNED' : (post.status || 'PUBLISHED'),
          isSample: String(post.status || '').toUpperCase() === 'SAMPLE' || String(post.id || '').startsWith('idea-')
        };
      }

      function setMessage(text, type) {
        if (!message) return;
        message.hidden = !text;
        message.textContent = text || '';
        message.dataset.type = type || 'info';
      }

      function setCommentMessage(text, type) {
        if (!commentMessage) return;
        commentMessage.textContent = text || '';
        commentMessage.dataset.type = type || 'info';
      }

      function showCommunityToast(text, type, title) {
        let toast = document.getElementById('communityToast');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'communityToast';
          toast.className = 'community-toast';
          document.body.appendChild(toast);
        }
        const toastType = type || 'success';
        const toastTitle = title || (toastType === 'error' ? 'CHECK REQUIRED' : 'DONE');
        toast.dataset.type = toastType;
        toast.setAttribute('role', toastType === 'error' ? 'alert' : 'status');
        toast.setAttribute('aria-live', toastType === 'error' ? 'assertive' : 'polite');
        toast.innerHTML = `
          <span class="community-toast-icon" aria-hidden="true">${toastType === 'error' ? '!' : '✓'}</span>
          <span class="community-toast-copy">
            <strong>${escapeHtml(toastTitle)}</strong>
            <span>${escapeHtml(text)}</span>
          </span>
          <button type="button" aria-label="알림 닫기">닫기</button>
        `;
        toast.hidden = false;
        window.requestAnimationFrame(() => {
          toast.classList.add('is-visible');
        });
        toast.querySelector('button')?.addEventListener('click', hideCommunityToast);
        window.clearTimeout(communityToastTimer);
        communityToastTimer = window.setTimeout(hideCommunityToast, toastType === 'error' ? 7000 : 4600);
      }

      function hideCommunityToast() {
        const toast = document.getElementById('communityToast');
        if (!toast) return;
        toast.classList.remove('is-visible');
        window.clearTimeout(communityToastTimer);
        communityToastTimer = window.setTimeout(() => {
          toast.hidden = true;
        }, 220);
      }

      function closeReportModal(result) {
        if (!reportModal) return;
        reportModal.hidden = true;
        document.body.classList.remove('community-report-is-open');
        if (pendingReport) {
          pendingReport.resolve(result || null);
          pendingReport = null;
        }
        if (reportReturnFocus && typeof reportReturnFocus.focus === 'function') {
          reportReturnFocus.focus();
        }
        reportReturnFocus = null;
      }

      function openReportModal(button) {
        if (!reportModal || !reportForm) {
          setCommentMessage('신고 창을 열 수 없습니다. 새로고침 후 다시 시도해 주세요.', 'error');
          return Promise.resolve(null);
        }
        if (pendingReport) closeReportModal(null);
        reportForm.reset();
        reportReturnFocus = button || document.activeElement;
        reportModal.hidden = false;
        document.body.classList.add('community-report-is-open');
        window.setTimeout(() => reportForm.querySelector('select')?.focus(), 0);
        return new Promise((resolve) => {
          pendingReport = { resolve };
        });
      }

      reportForm?.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(reportForm);
        const reason = String(data.get('reason') || '').trim();
        const detail = String(data.get('detail') || '').trim();
        if (!reason) return;
        closeReportModal({ reason, detail });
      });

      reportCloseButtons.forEach((button) => {
        button.addEventListener('click', () => closeReportModal(null));
      });

      reportModal?.addEventListener('click', (event) => {
        if (event.target === reportModal) closeReportModal(null);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && reportModal && !reportModal.hidden) {
          closeReportModal(null);
        }
      });

      function renderPost(post) {
        const normalized = normalizePost(post);
        activePostId = normalized.id;
        document.querySelector('[data-detail-board]').textContent = normalized.category;
        document.querySelector('[data-detail-date]').textContent = normalized.date;
        document.querySelector('[data-detail-title]').textContent = normalized.title;
        document.querySelector('[data-detail-body]').textContent = normalized.body;
        document.querySelector('[data-detail-author]').textContent = normalized.author;
        document.querySelector('[data-detail-comments]').textContent = `${normalized.comments} COMMENTS`;
        const statusTarget = document.querySelector('[data-detail-status]');
        statusTarget.textContent = normalized.status.toUpperCase();
        statusTarget.classList.toggle('is-sample', normalized.isSample);
        statusTarget.classList.toggle('is-pinned', normalized.status === 'PINNED');
        document.querySelector('[data-detail-likes]').textContent = String(normalized.likes);
        if (sampleNote) sampleNote.hidden = !normalized.isSample;
        postRoot.hidden = false;
        commentsPanel.hidden = false;
      }

      function renderComments(comments) {
        if (!comments.length) {
          commentsList.innerHTML = '<p>아직 댓글이 없습니다. 첫 댓글을 남겨 주세요.</p>';
          return;
        }
        commentsList.innerHTML = comments.map((comment) => `
          <article class="community-comment-row">
            <strong>${escapeHtml(comment.authorName || 'Fan')}</strong>
            <time datetime="${escapeHtml(comment.createdAt || '')}">${escapeHtml(formatDate(comment.createdAt))}</time>
            <p>${escapeHtml(comment.body || '')}</p>
            <button type="button" data-detail-report-comment data-comment-id="${escapeHtml(comment.id)}">REPORT</button>
          </article>
        `).join('');
      }

      async function submitReport(targetType, targetId, button) {
        if (!targetId || targetId.startsWith('idea-') || targetId.startsWith('notice-')) {
          const text = 'SAMPLE 게시글은 신고할 수 없습니다. 실제 팬 게시글에서 신고 기능을 사용할 수 있습니다.';
          setCommentMessage(text, 'error');
          showCommunityToast(text, 'error');
          return;
        }

        const report = await openReportModal(button);
        if (!report) return;

        if (button) button.disabled = true;
        setCommentMessage('신고를 접수하는 중입니다.', 'info');
        try {
          const response = await fetch('/api/community/reports', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ targetType, targetId, reason: report.reason, detail: report.detail })
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.ok) throw new Error(data.message || '신고를 접수하지 못했습니다.');
          const text = data.duplicate ? '이미 신고가 접수되어 있습니다.' : '신고가 접수되었습니다. 운영자가 확인하겠습니다.';
          setCommentMessage(text, 'success');
          showCommunityToast(text, 'success', data.duplicate ? 'REPORT EXISTS' : 'REPORT RECEIVED');
        } catch (error) {
          const text = `${error.message} 로그인 또는 가입 승인이 필요할 수 있습니다.`;
          setCommentMessage(text, 'error');
          showCommunityToast(text, 'error');
        } finally {
          if (button) button.disabled = false;
        }
      }

      async function loadComments() {
        if (!activePostId || activePostId.startsWith('idea-') || activePostId.startsWith('notice-')) {
          renderComments([]);
          setCommentMessage('SAMPLE 게시글은 댓글 작성이 제한됩니다. 실제 팬 게시글에서 댓글을 남길 수 있습니다.', 'info');
          return;
        }
        const response = await fetch(`/api/community/comments?postId=${encodeURIComponent(activePostId)}`);
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.ok) throw new Error(data.message || '댓글을 불러오지 못했습니다.');
        renderComments(data.comments || []);
      }

      async function loadPost() {
        if (!postId) {
          setMessage('게시글 ID가 없습니다. 팬게시판 목록에서 다시 선택해 주세요.', 'error');
          return;
        }

        const fallback = initialPosts.find((post) => post.id === postId);
        try {
          const response = await fetch(`/api/community/posts?id=${encodeURIComponent(postId)}&view=1`);
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.ok) throw new Error(data.message || '게시글을 불러오지 못했습니다.');
          renderPost(data.post);
          setMessage('', 'success');
          await loadComments();
        } catch (error) {
          if (!fallback) {
            setMessage(error.message, 'error');
            return;
          }
          renderPost(fallback);
          setMessage('현재 SAMPLE 안내용 게시글 상세를 표시하고 있습니다.', 'info');
          renderComments([]);
        }
      }

      reactionButton?.addEventListener('click', async () => {
        if (!activePostId || activePostId.startsWith('idea-') || activePostId.startsWith('notice-')) {
          const text = 'SAMPLE 게시글에는 좋아요를 남길 수 없습니다. 실제 팬 게시글에서 반응을 남겨 주세요.';
          setCommentMessage(text, 'error');
          showCommunityToast(text, 'error');
          return;
        }
        reactionButton.disabled = true;
        try {
          const response = await fetch('/api/community/reactions', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ postId: activePostId, value: 1 })
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.ok) throw new Error(data.message || '추천을 처리하지 못했습니다.');
          document.querySelector('[data-detail-likes]').textContent = String(data.post?.likeCount || 0);
          reactionButton.classList.toggle('is-active', Number(data.activeValue || 0) === 1);
        } catch (error) {
          const text = `${error.message} 로그인 또는 가입 승인이 필요할 수 있습니다.`;
          setCommentMessage(text, 'error');
          showCommunityToast(text, 'error');
        } finally {
          reactionButton.disabled = false;
        }
      });

      postReportButton?.addEventListener('click', async () => {
        await submitReport('post', activePostId, postReportButton);
      });

      commentsList?.addEventListener('click', async (event) => {
        const reportButton = event.target.closest('[data-detail-report-comment]');
        if (!reportButton) return;
        await submitReport('comment', reportButton.dataset.commentId || '', reportButton);
      });

      commentForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!activePostId || activePostId.startsWith('idea-') || activePostId.startsWith('notice-')) {
          const text = 'SAMPLE 게시글에는 댓글을 남길 수 없습니다. 가입 승인 후 실제 팬 게시글에서 댓글을 남겨 주세요.';
          setCommentMessage(text, 'error');
          showCommunityToast(text, 'error');
          return;
        }
        const button = commentForm.querySelector('button[type="submit"]');
        button.disabled = true;
        setCommentMessage('댓글을 등록하는 중입니다.', 'info');
        try {
          const formData = new FormData(commentForm);
          const response = await fetch('/api/community/comments', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ postId: activePostId, body: formData.get('body') })
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.ok) throw new Error(data.message || '댓글을 등록하지 못했습니다.');
          commentForm.reset();
          setCommentMessage('댓글이 등록되었습니다.', 'success');
          showCommunityToast('댓글이 등록되었습니다.', 'success', 'COMMENT POSTED');
          await loadComments();
        } catch (error) {
          const text = `${error.message} 로그인 또는 가입 승인이 필요할 수 있습니다.`;
          setCommentMessage(text, 'error');
          showCommunityToast(text, 'error');
        } finally {
          button.disabled = false;
        }
      });

      loadPost();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCommunityPostDetail, { once: true });
    } else {
      initCommunityPostDetail();
    }
  </script>
</Layout>
