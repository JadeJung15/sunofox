---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { artistLinks, novelProject, structuredData, sunofoxProfile } from '../data/siteContent.js';
---

<Layout
  title="SunoFox 소개 | Anime OST Studio"
  description="SunoFox는 이야기 기반 Anime OST와 웹소설 OST를 YouTube, 음악 아카이브, Story IP로 확장하는 스튜디오입니다."
  canonical="https://sunofox.com/profile/"
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  jsonLd={structuredData}
>
  <SiteChrome active="profile" />

  <main id="main-content" class="site-main category-page about-page">
    <section class="category-hero" aria-labelledby="profileTitle">
      <p class="section-kicker">애니 OST 스튜디오</p>
      <h1 id="profileTitle">SunoFox</h1>
      <p>SunoFox는 이야기 기반 애니 OST와 웹소설 OST를 유튜브, 음악 아카이브, 스토리 IP로 확장하는 스튜디오입니다.</p>
    </section>

    <section class="category-content about-compact" aria-label="SunoFox profile">
      <p class="about-lead">
        먼저 유튜브에서 장면과 선율을 공개하고, 선택된 감정선을 웹소설과 영상 패키징으로 확장합니다.
      </p>

      <div class="about-route-grid" aria-label="SunoFox operating routes">
        <a href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">
          <span>01</span>
          <strong>유튜브 / MV</strong>
          <p>애니 OST와 웹소설 OST를 먼저 공개하는 SunoFox의 중심 채널입니다.</p>
        </a>
        <a href="/music/">
          <span>02</span>
          <strong>음악 아카이브</strong>
          <p>대표 OST, 최신 영상, 앨범과 재생목록을 한 곳에서 이어 봅니다.</p>
        </a>
        <a href="/novels/">
          <span>03</span>
          <strong>스토리 IP</strong>
          <p>첫 작품 《{novelProject.title}》의 작품 정보와 회차를 공개합니다.</p>
        </a>
        <a class="about-route-private" href="/login?next=/mv-studio">
          <span>04</span>
          <strong>제작실 로그인</strong>
          <p>소유자 계정으로만 입장하는 내부 제작 공간입니다.</p>
        </a>
      </div>

      <ul class="about-line-list">
        <li>현재 공개 흐름의 첫 진입점은 유튜브 / MV와 음악 아카이브입니다.</li>
        <li>스토리 IP는 OST에서 시작한 장면을 웹소설 회차와 제작 흐름으로 확장합니다.</li>
        <li>공개 전인 회차와 확장 콘텐츠는 준비 상태가 확정된 뒤만 안내합니다.</li>
      </ul>
    </section>

    <section class="profile-snapshot-section reveal" aria-labelledby="profileSnapshotTitle">
      <div class="profile-snapshot-head">
        <p class="section-kicker">공식 허브</p>
        <h2 id="profileSnapshotTitle">현재 공개 흐름</h2>
        <p>유튜브, 음악 아카이브, 스토리 IP를 중심으로 공개 흐름을 정리하고, 제작실은 소유자 전용 내부 도구로 분리했습니다.</p>
      </div>

      <div class="profile-snapshot-grid">
        {sunofoxProfile.highlights.map((item) => (
          <a
            class:list={['profile-snapshot-card', item.key === 'studio' && 'is-private-tool']}
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <small>{item.status}</small>
            <p>{item.summary}</p>
            <em>{item.cta}</em>
          </a>
        ))}
      </div>

      <div class="profile-current-actions" aria-label="SunoFox quick links">
        {sunofoxProfile.quickActions.map((action) => (
          <a class="micro-button micro-button-muted" href={action.href}>{action.label}</a>
        ))}
      </div>
    </section>

    <section class="profile-detail-section reveal" aria-labelledby="profileDetailTitle">
      <div class="profile-detail-head">
        <p class="section-kicker">공개 정보</p>
        <h2 id="profileDetailTitle">SunoFox 상세 소개</h2>
        <p>공개 웹, 유튜브 채널, 음원 플랫폼에서 확인한 수노폭스 정보를 필모그래피처럼 정리했습니다.</p>
        <span>확인 기준 {sunofoxProfile.researchDate}</span>
      </div>

      <nav class="profile-detail-tabs" aria-label="SunoFox detail tabs">
        {sunofoxProfile.tabs.map((tab) => (
          <a href={`#${tab.id}`}>{tab.label}</a>
        ))}
      </nav>

      <div class="profile-detail-panels">
        {sunofoxProfile.tabs.map((tab) => (
          <article id={tab.id} class="profile-detail-panel">
            <div class="profile-detail-panel-copy">
              <p class="section-kicker">{tab.kicker}</p>
              <h3>{tab.title}</h3>
              <p>{tab.summary}</p>
            </div>

            <dl class="profile-fact-grid">
              {tab.facts.map((fact) => (
                <div>
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))}
            </dl>

            {tab.tracks && (
              <ol class="profile-track-list" aria-label={`${tab.title} track list`}>
                {tab.tracks.map((track) => <li>{track}</li>)}
              </ol>
            )}

            {tab.videos && (
              <div class="profile-video-list" aria-label={`${tab.title} latest videos`}>
                <p class="profile-section-label">최근 영상</p>
                <ol>
                  {tab.videos.map((video) => (
                    <li>
                      <a href={video.href} target="_blank" rel="noopener noreferrer">
                        <span>{video.date}</span>
                        <strong>{video.title}</strong>
                        <p>{video.meta}</p>
                        <em>{video.stats}</em>
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            )}

            <div class="profile-source-actions" aria-label={`${tab.label} links`}>
              {tab.links.map((link) => (
                <a class="main-button main-button-muted" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                  {link.label}
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="profile-source-strip" aria-label="SunoFox public sources">
        <span>출처</span>
        {sunofoxProfile.sources.map((source) => (
          <a href={source.href} target="_blank" rel="noopener noreferrer">{source.label}</a>
        ))}
      </div>
      <p class="profile-source-note">
        채널 구독자, 조회수, 영상 수처럼 변동되는 지표는 공개 조회 시점 기준입니다.
      </p>
    </section>
  </main>
</Layout>
