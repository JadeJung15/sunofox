              <button data-costume="school-uniform" type="button">교복</button>
              <button data-costume="stage-outfit" type="button">시네마틱 의상</button>
              <button class="active" data-costume="fantasy-light" type="button">라이트 판타지</button>
              <button data-costume="minimal-white" type="button">미니멀 화이트</button>
              <button data-costume="custom" type="button">직접 입력</button>
            </div>
            <input id="mv-costume-note" class="mv-costume-note" type="text" placeholder="의상 직접 입력" hidden>
