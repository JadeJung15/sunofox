                </select>
              </label>
              <label class="mv-field">
                <span>세계관</span>
                <select id="mv-world">
                  <option value="grounded-fantasy">현실+상징</option>
                  <option value="grounded">현실세계</option>
                  <option value="fantasy" selected>판타지</option>
                  <option value="surreal">초현실</option>
                </select>
