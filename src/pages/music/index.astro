---
import SiteChrome from '../../components/SiteChrome.astro';
import Layout from '../../layouts/Layout.astro';
import {
  artistLinks,
  archiveAlbum,
  featuredStoryOst,
  latestNovelEpisode,
  latestStoryOst,
  musicArchive,
  musicArchiveStructuredData,
  novelProject
} from '../../data/siteContent.js';

const currentEpisode = latestNovelEpisode;
const primaryVideo = musicArchive.videos[0];
const latestStoryVideo = musicArchive.videos.find((video) => video.videoId === latestStoryOst.videoId) || primaryVideo;
const videoTypes = Array.from(new Set(musicArchive.videos.map((video) => video.type))).slice(0, 4);
const videoAnchorItems = Array.from(
  new Map(
    musicArchive.videos.map((video) => [
      video.type,
      {
        label: video.type,
        href: `#music-video-${video.videoId}`
      }
    ])
  ).values()
);
const latestVideoDate = latestStoryVideo?.date || musicArchive.researchDate;
const oldestVideoDate = musicArchive.videos.at(-1)?.date || latestVideoDate;
const musicHeroActions = [
  { label: '최신 영상 감상', href: latestStoryVideo.href, external: true, primary: true },
  { label: '유튜브 채널', href: artistLinks.youtube, external: true },
  { label: '재생목록', href: artistLinks.youtubePlaylists, external: true },
  { label: '스토리 IP', href: '/novels/' },
  { label: '대표 OST', href: featuredStoryOst.href, external: true }
];
const videoDirectActions = [
  { key: 'latest', label: '최신 영상 감상', href: latestStoryVideo.href, external: true, primary: true },
  { key: 'channel', label: '유튜브 채널', href: artistLinks.youtube, external: true },
  { key: 'playlists', label: '재생목록 보기', href: artistLinks.youtubePlaylists, external: true }
];
const videoSummaryItems = [
  { label: '영상 수', value: `${musicArchive.videos.length}편` },
  { label: '최근 공개', value: latestVideoDate },
  { label: '대표 분류', value: videoTypes.join(' · ') },
  { label: '기록 범위', value: `${oldestVideoDate} - ${latestVideoDate}` }
];
---

<Layout
  title="SunoFox Music Archive | Anime OST Studio"
  description={musicArchive.summary}
  canonical="https://sunofox.com/music/"
  image={`https://sunofox.com${archiveAlbum.image}`}
  imageAlt={archiveAlbum.imageAlt}
  imageWidth={512}
  imageHeight={512}
  jsonLd={musicArchiveStructuredData}
>
  <SiteChrome active="music" />

  <main id="main-content" class="site-main music-archive-page">
    <section class="music-archive-hero reveal" aria-labelledby="musicArchiveTitle">
      <a class="album-back-link" href="/profile/#discography">SunoFox 소개</a>

      <div class="music-archive-copy">
        <p class="section-kicker">음악 아카이브</p>
        <h1 id="musicArchiveTitle">음악 아카이브</h1>
        <p>
          유튜브에서 공개되는 애니 OST, 웹소설 OST, 라이브 아카이브를 한 곳에서 이어 봅니다.
          음악 아카이브는 SunoFox의 영상 중심 IP 흐름을 정리하는 공개 허브입니다.
        </p>
        <span>최신 OST {latestStoryVideo.date} · 확인 기준 {musicArchive.researchDate}</span>
        <div class="music-archive-actions" aria-label="음악 아카이브 빠른 이동">
          {musicHeroActions.map((action) => (
            <a
              class:list={['main-button', !action.primary && 'main-button-muted']}
              href={action.href}
              target={action.external ? '_blank' : undefined}
              rel={action.external ? 'noopener noreferrer' : undefined}
            >
              {action.label}
            </a>
          ))}
        </div>
      </div>

      <dl class="music-archive-facts">
        {musicArchive.facts.map((fact) => (
          <div>
            <dt>{fact.label}</dt>
            <dd>{fact.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="music-flow-section reveal" aria-labelledby="musicFlowTitle">
      <div class="novel-section-head">
        <p class="section-kicker">스토리 IP 흐름</p>
        <h2 id="musicFlowTitle">음악에서 IP로 이어지는 방식</h2>
        <span>3단계</span>
      </div>

      <div class="music-flow-grid">
        {musicArchive.flow.map((item) => (
          <article>
            <span>{item.step}</span>
            <strong>{item.title}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="music-featured-ost-section reveal" aria-labelledby="musicFeaturedOstTitle">
      <a class="music-featured-thumb" href={featuredStoryOst.href} target="_blank" rel="noopener noreferrer" aria-label={`${featuredStoryOst.title} 감상하기`}>
        <img
          src={featuredStoryOst.thumbnail}
          alt={featuredStoryOst.thumbnailAlt}
          width="480"
          height="360"
          loading="lazy"
          decoding="async"
        />
      </a>
      <div class="music-featured-copy">
        <p class="section-kicker">대표 OST</p>
        <h2 id="musicFeaturedOstTitle">{featuredStoryOst.title}</h2>
        <p>{featuredStoryOst.summary}</p>
        <div class="music-story-actions">
          <a class="main-button" href={featuredStoryOst.href} target="_blank" rel="noopener noreferrer">OST 감상</a>
          <a class="main-button main-button-muted" href="/novels/">작품 정보</a>
          <a class="main-button main-button-muted" href={currentEpisode.href}>{currentEpisode.label} 읽기</a>
        </div>
      </div>
    </section>

    <section class="music-release-section reveal" aria-labelledby="musicReleaseTitle">
      <div class="novel-section-head">
        <p class="section-kicker">앨범 기록</p>
        <h2 id="musicReleaseTitle">공개 앨범</h2>
        <span>{musicArchive.releases.length} release</span>
      </div>

      <div class="music-release-grid">
        {musicArchive.releases.map((release) => (
          <article class="music-release-card">
            <a class="music-release-cover" href={release.href} aria-label={`${release.title} 상세 보기`}>
              <img src={release.image} alt={release.imageAlt} width="512" height="512" loading="lazy" decoding="async" />
              <span>{release.type}</span>
            </a>
            <div class="music-release-copy">
              <p>{release.releaseDate}</p>
              <h3>{release.title}</h3>
              <strong>{release.summary}</strong>
              <dl>
                <div>
                  <dt>수록</dt>
                  <dd>{release.tracks.length}곡</dd>
                </div>
                <div>
                  <dt>기획/발매</dt>
                  <dd>{release.agency} / {release.distributor}</dd>
                </div>
                <div>
                  <dt>장르</dt>
                  <dd>{release.genre}</dd>
                </div>
              </dl>
              <ol>
                {release.tracks.slice(0, 5).map((track) => (
                  <li>{track.position}. {track.title}</li>
                ))}
              </ol>
              <div class="music-release-actions">
                <a class="main-button" href={release.href}>상세 보기</a>
                {release.links.map((link) => (
                  <a class="main-button main-button-muted" href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="music-video-section reveal" aria-labelledby="musicVideoTitle">
      <div class="novel-section-head">
        <p class="section-kicker">영상 허브</p>
        <h2 id="musicVideoTitle">유튜브 / MV</h2>
        <span>{musicArchive.videos.length}편</span>
      </div>

      <div class="music-video-direct-actions" aria-label="유튜브 바로가기">
        {videoDirectActions.map((action) => (
          <a
            class:list={['main-button', !action.primary && 'main-button-muted']}
            href={action.href}
            target={action.external ? '_blank' : undefined}
            rel={action.external ? 'noopener noreferrer' : undefined}
            data-video-action={action.key}
          >
            {action.label}
          </a>
        ))}
      </div>

      <div class="music-video-hub" aria-label="유튜브 및 MV 허브">
        <a
          class="music-video-feature"
          href={primaryVideo.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${primaryVideo.title} 감상하기`}
          data-video-feature={primaryVideo.videoId}
          data-video-type={primaryVideo.type}
        >
          <img
            src={primaryVideo.thumbnail}
            alt={primaryVideo.thumbnailAlt}
            width="480"
            height="360"
            loading="lazy"
            decoding="async"
          />
          <span>{primaryVideo.date}</span>
          <strong>{primaryVideo.title}</strong>
          <p>{primaryVideo.meta}</p>
          <em>{primaryVideo.type}</em>
        </a>

        <div class="music-video-hub-copy">
          <p class="section-kicker">영상 큐레이션</p>
          <h3>{musicArchive.videoHub.title}</h3>
          <p>{musicArchive.videoHub.summary}</p>
          <dl>
            {musicArchive.videoHub.facts.map((fact) => (
              <div>
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </dl>
          <div class="music-video-hub-actions">
            {musicArchive.videoHub.links.map((link) => (
              <a class="main-button main-button-muted" href={link.href} target="_blank" rel="noopener noreferrer" data-video-hub-link={link.label}>{link.label}</a>
            ))}
          </div>
        </div>
      </div>

      <dl class="music-video-summary" aria-label="유튜브 및 MV 요약">
        {videoSummaryItems.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>

      <nav class="music-video-anchor-strip" aria-label="영상 유형 빠른 이동">
        {videoAnchorItems.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>

      <ol class="music-video-grid">
        {musicArchive.videos.map((video) => (
          <li
            id={`music-video-${video.videoId}`}
            data-video-id={video.videoId}
            data-video-type={video.type}
            data-video-date={video.date}
          >
            <a href={video.href} target="_blank" rel="noopener noreferrer" data-video-card={video.videoId}>
              <img
                src={video.thumbnail}
                alt={video.thumbnailAlt}
                width="480"
                height="360"
                loading="lazy"
                decoding="async"
              />
              <span>{video.date}</span>
              <strong>{video.title}</strong>
              <p>{video.meta}</p>
              <em>{video.type}</em>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="music-story-section reveal" aria-labelledby="musicStoryTitle">
      <div>
        <p class="section-kicker">스토리 IP</p>
        <h2 id="musicStoryTitle">웹소설로 이어진 첫 작품</h2>
      </div>
      <div>
        <p>
          현재 음악에서 웹소설로 확장된 대표 프로젝트는 《{novelProject.title}》입니다.
          OST에서 출발한 정서가 작품 소개와 최신 공개 화로 이어지도록 연결했습니다.
        </p>
        <div class="music-story-actions">
          <a class="main-button" href="/novels/">작품 정보</a>
          <a class="main-button main-button-muted" href={currentEpisode.href}>{currentEpisode.label} 읽기</a>
          <a class="main-button main-button-muted" href={artistLinks.featuredOst} target="_blank" rel="noopener noreferrer">OST 감상</a>
        </div>
      </div>
    </section>

    <section class="album-source-panel reveal" aria-label="Music archive sources">
      <span>출처</span>
      {musicArchive.sources.map((source) => (
        <a href={source.href} target="_blank" rel="noopener noreferrer">{source.label}</a>
      ))}
    </section>
  </main>
</Layout>
