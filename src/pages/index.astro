---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import {
  artistLinks,
  latestNovelEpisode,
  latestStoryOst,
  musicArchive,
  novelProject,
  structuredData
} from '../data/siteContent.js';

const keyVisual = '/assets/release-desk/mask-good-girl.jpg';

const posterLinks = [
  { label: 'OST', title: latestStoryOst.title, href: latestStoryOst.youtubeHref, external: true },
  { label: 'Story', title: novelProject.title, href: novelProject.season.startHref },
  { label: 'Archive', title: musicArchive.title, href: musicArchive.href },
  { label: 'Studio', title: 'MV Studio', href: '/login?next=/mv-studio' }
];

const latestEpisodeLabel = `${latestNovelEpisode.label} · ${latestNovelEpisode.title}`;
---

<Layout
  title="SunoFox | Anime OST Studio"
  description="SunoFox는 애니메이션 감성의 OST, 웹소설, 영상 제작 흐름을 단순하고 아름답게 연결하는 공식 홈입니다."
  image={`https://sunofox.com${latestStoryOst.thumbnail}`}
  imageAlt={latestStoryOst.thumbnailAlt}
  imageWidth={1200}
  imageHeight={675}
  jsonLd={structuredData}
>
  <SiteChrome active="home" />

  <main id="main-content" class="site-main anime-home poster-home">
    <section class="poster-hero reveal" aria-labelledby="posterHomeTitle">
      <img
        class="poster-bg"
        src={keyVisual}
        alt="Mask of a Good Girl OST를 상징하는 SunoFox 애니메이션 키비주얼"
        width="1200"
        height="900"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />

      <div class="poster-content">
        <p class="poster-kicker">ANIME OST STUDIO</p>
        <h1 id="posterHomeTitle">SunoFox</h1>
        <p class="poster-lead">감정을 노래하고, 이야기를 장면으로 남깁니다.</p>
        <div class="poster-actions" aria-label="SunoFox primary links">
          <a class="poster-button poster-button-primary" href={latestStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">OST 듣기</a>
          <a class="poster-button" href={novelProject.season.startHref}>소설 보기</a>
        </div>
      </div>

      <a class="poster-now" href={latestStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">
        <span>NOW PLAYING</span>
        <strong>{latestStoryOst.title}</strong>
        <small>{latestStoryOst.englishTitle} · {latestStoryOst.date}</small>
      </a>
    </section>

    <section class="poster-panel reveal" aria-label="SunoFox featured routes">
      <nav class="poster-links" aria-label="SunoFox main links">
        {posterLinks.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            <span>{item.label}</span>
            <strong>{item.title}</strong>
          </a>
        ))}
      </nav>

      <a class="poster-story" href={latestNovelEpisode.href}>
        <span>{novelProject.title}</span>
        <strong>{latestEpisodeLabel}</strong>
      </a>
    </section>

    <section class="poster-social reveal" aria-label="SunoFox external links">
      <a href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="/music/">{musicArchive.title}</a>
      <a href="/updates/">Updates</a>
      <a href="/profile/">Profile</a>
      <a href="https://sunofox.com/">sunofox.com</a>
    </section>
  </main>
</Layout>

<style>
  .anime-home {
    --anime-bg: #050509;
    --anime-ink: #fff7fb;
    --anime-muted: #d8cfdd;
    --anime-soft: #aa9ab4;
    --anime-line: rgba(255, 247, 251, 0.16);
    --anime-accent: #ff6f9f;
    --anime-warm: #f6b86a;
    min-height: 100svh;
    overflow: hidden;
    background: var(--anime-bg);
    color: var(--anime-ink);
  }

  .poster-hero {
    position: relative;
    display: grid;
    min-height: 100svh;
    align-items: end;
    overflow: hidden;
    padding: 112px 0 34px;
    isolation: isolate;
  }

  .poster-hero::before,
  .poster-hero::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    pointer-events: none;
  }

  .poster-hero::before {
    background:
      linear-gradient(90deg, rgba(5, 5, 9, 0.92), rgba(5, 5, 9, 0.52) 42%, rgba(5, 5, 9, 0.12)),
      linear-gradient(180deg, rgba(5, 5, 9, 0.18), rgba(5, 5, 9, 0.08) 42%, rgba(5, 5, 9, 0.92));
  }

  .poster-hero::after {
    background:
      radial-gradient(circle at 26% 22%, rgba(255, 111, 159, 0.2), transparent 26rem),
      linear-gradient(rgba(255, 247, 251, 0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 247, 251, 0.028) 1px, transparent 1px);
    background-size: auto, 54px 54px, 54px 54px;
    opacity: 0.8;
  }

  .poster-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 64% 42%;
    filter: saturate(1.08) contrast(1.05);
  }

  .poster-content,
  .poster-now,
  .poster-panel,
  .poster-social {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .poster-content {
    display: grid;
    gap: 18px;
    padding-bottom: 118px;
  }

  .poster-kicker {
    margin: 0;
    color: var(--anime-warm);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0;
  }

  .poster-content h1 {
    max-width: 9ch;
    margin: 0;
    color: var(--anime-ink);
    font-size: 5.8rem;
    font-weight: 950;
    line-height: 0.94;
    letter-spacing: 0;
    overflow-wrap: anywhere;
    text-shadow: 0 0 30px rgba(255, 111, 159, 0.28);
  }

  .poster-lead {
    max-width: 420px;
    margin: 0;
    color: var(--anime-muted);
    font-size: 1.08rem;
    font-weight: 680;
    line-height: 1.75;
    word-break: keep-all;
  }

  .poster-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 4px;
  }

  .poster-button {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--anime-line);
    border-radius: 999px;
    padding: 0 18px;
    background: rgba(5, 5, 9, 0.36);
    color: var(--anime-ink);
    font-size: 0.94rem;
    font-weight: 900;
    backdrop-filter: blur(12px);
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .poster-button:hover,
  .poster-button:focus-visible {
    border-color: var(--anime-accent);
    background: rgba(255, 111, 159, 0.12);
    transform: translateY(-1px);
  }

  .poster-button-primary {
    border-color: var(--anime-accent);
    background: var(--anime-accent);
    color: #1d0711;
  }

  .poster-now {
    position: absolute;
    right: 0;
    bottom: 34px;
    left: 0;
    display: grid;
    grid-template-columns: 132px minmax(0, 1fr);
    gap: 18px;
    align-items: baseline;
    border-top: 1px solid var(--anime-line);
    padding-top: 18px;
  }

  .poster-now span,
  .poster-links span,
  .poster-story span,
  .poster-social a {
    color: var(--anime-soft);
    font-size: 0.78rem;
    font-weight: 860;
  }

  .poster-now span {
    color: var(--anime-warm);
  }

  .poster-now strong {
    color: var(--anime-ink);
    font-size: 1.28rem;
    font-weight: 950;
    line-height: 1.24;
    overflow-wrap: anywhere;
  }

  .poster-now small {
    grid-column: 2;
    color: var(--anime-soft);
    font-size: 0.9rem;
    font-weight: 720;
  }

  .poster-panel {
    display: grid;
    gap: 0;
    padding: 44px 0 0;
  }

  .poster-links {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--anime-line);
    border-bottom: 1px solid var(--anime-line);
  }

  .poster-links a {
    display: grid;
    gap: 6px;
    min-width: 0;
    min-height: 82px;
    align-content: center;
    border-right: 1px solid var(--anime-line);
    padding: 14px 16px;
  }

  .poster-links a:last-child {
    border-right: 0;
  }

  .poster-links a:hover,
  .poster-links a:focus-visible {
    background: rgba(255, 111, 159, 0.1);
  }

  .poster-links strong {
    color: var(--anime-ink);
    font-size: 1.05rem;
    font-weight: 930;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .poster-story {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    justify-content: space-between;
    border-bottom: 1px solid var(--anime-line);
    padding: 18px 0;
  }

  .poster-story strong {
    color: var(--anime-muted);
    font-size: 0.94rem;
    font-weight: 850;
    overflow-wrap: anywhere;
  }

  .poster-social {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    padding: 30px 0 78px;
  }

  .poster-social a:hover,
  .poster-social a:focus-visible {
    color: var(--anime-accent);
  }

  @media (max-width: 760px) {
    .poster-hero {
      padding-top: 82px;
    }

    .poster-hero::before {
      background:
        linear-gradient(180deg, rgba(5, 5, 9, 0.12), rgba(5, 5, 9, 0.16) 36%, rgba(5, 5, 9, 0.96)),
        linear-gradient(90deg, rgba(5, 5, 9, 0.38), transparent 68%);
    }

    .poster-bg {
      object-position: 62% 32%;
    }

    .poster-content,
    .poster-now,
    .poster-panel,
    .poster-social {
      width: calc(100% - 28px);
    }

    .poster-content {
      padding-bottom: 146px;
    }

    .poster-content h1 {
      font-size: 3.55rem;
      line-height: 0.98;
    }

    .poster-lead {
      font-size: 1rem;
      line-height: 1.65;
    }

    .poster-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .poster-button {
      width: 100%;
    }

    .poster-now {
      grid-template-columns: 1fr;
      gap: 5px;
      bottom: 26px;
      padding-top: 16px;
    }

    .poster-now strong {
      font-size: 1.08rem;
    }

    .poster-now small {
      grid-column: 1;
    }

    .poster-panel {
      padding-top: 30px;
    }

    .poster-links {
      grid-template-columns: 1fr;
    }

    .poster-links a {
      min-height: 62px;
      border-right: 0;
      border-bottom: 1px solid var(--anime-line);
      padding: 13px 0;
    }

    .poster-links a:last-child {
      border-bottom: 0;
    }

    .poster-story {
      display: grid;
      gap: 8px;
    }

    .poster-social {
      padding-bottom: 58px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .poster-button,
    .poster-links a {
      transition: none;
    }
  }
</style>
