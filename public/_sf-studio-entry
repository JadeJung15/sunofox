                  <option value="emotion">감정 표정 중심</option>
                  <option value="outfit">의상 변화 중심</option>
                  <option value="thumbnail">썸네일 임팩트 중심</option>
                </select>
              </label>
              <label class="mv-field">
                <span>가사 싱크</span>
                <select id="mv-lyric-sync">
