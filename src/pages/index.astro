---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { artistLinks, featuredStoryOst, glassNightRoseVideo, maskGoodGirlVideo, dontTakeMeAwayStoryOst } from '../data/artistContent.js';
import { archiveAlbum } from '../data/musicContent.js';
import { novelProject, publishedNovelEpisodes } from '../data/novelContent.js';

const filmography = [
  { title: '유리 밤의 장미', date: glassNightRoseVideo.date, type: 'Anime OST', image: glassNightRoseVideo.thumbnail, alt: glassNightRoseVideo.thumbnailAlt, href: glassNightRoseVideo.youtubeHref },
  { title: 'Mask of a Good Girl', date: maskGoodGirlVideo.date, type: 'Anime OST', image: maskGoodGirlVideo.thumbnail, alt: maskGoodGirlVideo.thumbnailAlt, href: maskGoodGirlVideo.youtubeHref },
  { title: 'ARCHIVE vol.1', date: archiveAlbum.releaseDate, type: 'Album', image: archiveAlbum.image, alt: archiveAlbum.imageAlt, href: archiveAlbum.externalHref },
  { title: '악녀는 첫 장에서 웃었다', date: novelProject.season.completedAt, type: 'Web Novel', image: novelProject.coverImage, alt: novelProject.coverAlt, href: '/novels/' },
  { title: '웹소설 OST｜악녀는 첫 장에서 웃었다', date: featuredStoryOst.date, type: 'Web Novel OST', image: featuredStoryOst.thumbnail, alt: featuredStoryOst.thumbnailAlt, href: featuredStoryOst.youtubeHref },
  { title: '아직 데려가지 마', date: dontTakeMeAwayStoryOst.date, type: 'Web Novel OST', image: dontTakeMeAwayStoryOst.thumbnail, alt: dontTakeMeAwayStoryOst.thumbnailAlt, href: dontTakeMeAwayStoryOst.youtubeHref }
];

const flow = [
  { icon: 'ph-music-notes', title: 'MUSIC', text: '감정과 분위기를 음악으로 표현합니다.' },
  { icon: 'ph-book-open', title: 'STORY', text: '이야기의 흐름과 인물의 서사를 잇습니다.' },
  { icon: 'ph-image', title: 'IMAGE', text: '장면의 감정과 색채를 이미지로 구현합니다.' },
  { icon: 'ph-video', title: 'VIDEO', text: '음악과 서사를 담아 몰입의 장면으로 완성합니다.' }
];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Organization', '@id': 'https://sunofox.com/#organization', name: 'SunoFox', alternateName: '수노폭스', url: 'https://sunofox.com/', sameAs: [artistLinks.youtube] },
    { '@type': 'WebSite', '@id': 'https://sunofox.com/#website', name: 'SunoFox 공식 사이트', url: 'https://sunofox.com/', inLanguage: 'ko-KR', publisher: { '@id': 'https://sunofox.com/#organization' } },
    { '@type': 'ItemList', '@id': 'https://sunofox.com/#filmography', numberOfItems: filmography.length, itemListElement: filmography.map((work, index) => ({ '@type': 'ListItem', position: index + 1, name: work.title, url: work.href })) }
  ]
};
---

<Layout
  title="SunoFox 수노폭스 | Anime OST Story Studio"
  description="SunoFox는 애니메이션 감성의 OST와 이야기 기반 음악 콘텐츠를 제작하는 채널입니다."
  image="https://sunofox.com/assets/release-desk/mask-good-girl.jpg"
  imageAlt={maskGoodGirlVideo.thumbnailAlt}
  imageWidth={1200}
  imageHeight={675}
  jsonLd={structuredData}
>
  <SiteChrome />

  <main id="main-content" class="official-home">
    <section class="official-hero" aria-labelledby="hero-title">
      <img src="/assets/release-desk/mask-good-girl.jpg" alt="" aria-hidden="true" width="1200" height="675" loading="eager" fetchpriority="high" />
      <div class="hero-copy">
        <p class="eyebrow">애니 OST 스튜디오</p>
        <h1 id="hero-title"><span>Suno</span><span>Fox</span></h1>
        <p class="hero-lead">감정을 노래하고,<br />이야기를 장면으로 남깁니다.</p>
        <div class="hero-actions">
          <a class="button button-primary" href={artistLinks.youtube} target="_blank" rel="noopener noreferrer"><i class="ph-bold ph-play" aria-hidden="true"></i>YouTube에서 듣기</a>
          <a class="button" href={glassNightRoseVideo.youtubeHref} target="_blank" rel="noopener noreferrer">최신 OST 듣기<i class="ph-bold ph-arrow-up-right" aria-hidden="true"></i></a>
        </div>
      </div>
      <a class="scroll-cue" href="#novel"><span></span><small>SCROLL</small></a>
    </section>

    <div class="chapter-flow">
      <section id="novel" class="chapter novel-section" aria-labelledby="novel-title">
        <div class="chapter-number" aria-hidden="true">02</div>
        <div class="chapter-copy">
          <p class="eyebrow">대표 소설</p>
          <h2 id="novel-title" aria-label={novelProject.title}><span class="novel-title-line">악녀는 첫 장에서</span> <span class="novel-title-line">웃었다</span></h2>
          <p>{novelProject.tagline}</p>
          <ul class="meta-list" aria-label="작품 정보"><li>장르&nbsp; {novelProject.genre}</li><li>연재&nbsp; {publishedNovelEpisodes.length}화 완결</li></ul>
          <div class="chapter-actions"><a class="button button-primary" href="/novels/">소설 읽기</a><a class="button" href={featuredStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">관련 OST<i class="ph-bold ph-arrow-up-right" aria-hidden="true"></i></a></div>
        </div>
        <figure class="chapter-image novel-image"><img src={novelProject.coverImage} alt={novelProject.coverAlt} width={novelProject.coverWidth} height={novelProject.coverHeight} loading="lazy" /></figure>
      </section>

      <section id="about" class="chapter about-section" aria-labelledby="about-title">
        <div class="chapter-number" aria-hidden="true">03</div>
        <div class="chapter-copy about-copy">
          <p class="eyebrow">채널 소개</p>
          <h2 id="about-title"><span class="about-title-line">애니 OST로 완성하는</span><span class="about-title-line">감정의 서사</span></h2>
          <p>SunoFox는 애니메이션과 소설의 장면을 음악으로 확장하는 애니 OST 스튜디오입니다.<br />이야기의 결, 인물의 감정, 장면의 온도를 사운드로 번역해 새로운 몰입을 전합니다.</p>
        </div>
        <figure class="chapter-image about-image"><img src="/assets/release-desk/mask-good-girl.jpg" alt="SunoFox의 음악과 이야기 제작 방향을 보여주는 애니메이션 키비주얼" width="1200" height="675" loading="lazy" /></figure>
        <ol class="production-flow" aria-label="SunoFox 제작 흐름">
          {flow.map((item, index) => (
            <li>
              <span class="flow-index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <div><i class={`ph-bold ${item.icon}`} aria-hidden="true"></i><strong>{item.title}</strong></div>
              <p>{item.text}</p>
              {index < flow.length - 1 && <i class="ph-bold ph-arrow-right flow-arrow" aria-hidden="true"></i>}
            </li>
          ))}
        </ol>
      </section>

      <section id="filmography" class="chapter filmography-section" aria-labelledby="filmography-title">
        <div class="chapter-number" aria-hidden="true">04</div>
        <div class="chapter-copy filmography-heading"><p class="eyebrow">필모그래피</p><h2 id="filmography-title">대표 작품</h2></div>
        <div class="filmography-grid">
          {filmography.map((work) => (
            <a class="work-card" data-filmography-card={work.title} href={work.href} target={work.href.startsWith('http') ? '_blank' : undefined} rel={work.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
              <figure><img src={work.image} alt={work.alt} width="600" height="800" loading="lazy" /></figure>
              <div><strong>{work.title}</strong><span>{work.date}&nbsp;&nbsp; {work.type}</span><small>{work.href.startsWith('http') ? '외부에서 보기' : '작품 보기'} <i class="ph-bold ph-arrow-up-right" aria-hidden="true"></i></small></div>
            </a>
          ))}
        </div>
      </section>

      <section id="studio" class="chapter studio-section" aria-labelledby="studio-title">
        <div class="chapter-number" aria-hidden="true">05</div>
        <div class="studio-panel">
          <img src="/assets/release-desk/cozy-drift.jpg" alt="SF Studio 헤드폰과 제작 데스크" width="960" height="720" loading="lazy" />
          <div><p class="eyebrow">스튜디오</p><h2 id="studio-title">SF Studio</h2><p>SunoFox의 기획실, SF Studio.<br />음악과 이야기를 만드는 공간으로 이동합니다.</p></div>
          <div class="studio-entry">
            <span><i class="ph-bold ph-arrow-right" aria-hidden="true"></i>등록된 제작자 전용</span>
            <a class="button button-primary" href="/login?next=/mv-studio">스튜디오 로그인<i class="ph-bold ph-arrow-up-right" aria-hidden="true"></i></a>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  :global(html) { scroll-behavior: smooth; scroll-padding-top: 72px; }
  .official-home { --bg:#050509; --pink:#ff5f96; --warm:#f6b86a; --ink:#fffafb; --muted:#aaa4ac; overflow:hidden; background:var(--bg); color:var(--ink); font-family:'Noto Sans KR',sans-serif; }
  .official-hero { position:relative; min-height:680px; display:flex; align-items:center; overflow:hidden; isolation:isolate; }
  .official-hero::after { position:absolute; inset:0; z-index:-1; background:linear-gradient(90deg,rgba(5,5,9,.98) 0%,rgba(5,5,9,.84) 30%,rgba(5,5,9,.18) 68%),linear-gradient(180deg,rgba(5,5,9,.08) 55%,#050509 100%); content:''; }
  .official-hero>img { position:absolute; inset:0; z-index:-2; width:100%; height:100%; object-fit:cover; object-position:65% 42%; filter:saturate(.86) contrast(1.05); }
  .hero-copy { width:min(1320px,calc(100% - 80px)); margin:0 auto; padding:100px 0 80px; }
  .eyebrow { margin:0 0 18px; color:var(--warm); font-size:14px; font-weight:800; }
  .hero-copy h1 { display:grid; margin:0; font-size:clamp(92px,10vw,150px); font-weight:900; line-height:.8; letter-spacing:-.065em; }
  .hero-copy h1 span:last-child { color:var(--pink); }
  .hero-lead { margin:36px 0 30px; font-family:'Noto Serif KR',serif; font-size:clamp(24px,2.2vw,32px); font-weight:600; line-height:1.6; }
  .hero-actions,.chapter-actions { display:flex; justify-content:flex-start; gap:16px; flex-wrap:wrap; }
  .button { min-height:52px; display:inline-flex; align-items:center; justify-content:center; gap:10px; border:1px solid rgba(255,250,251,.27); border-radius:10px; padding:0 24px; color:var(--ink); font-weight:800; transition:.2s ease; }
  .button:hover,.button:focus-visible { border-color:var(--pink); background:rgba(255,95,150,.1); transform:translateY(-2px); }
  .button-primary { border-color:var(--pink); background:var(--pink); color:#15040a; }
  .scroll-cue { position:absolute; bottom:34px; left:50%; display:grid; justify-items:center; gap:6px; color:#fff; transform:translateX(-50%); }
  .scroll-cue span { width:3px; height:42px; border-radius:3px; background:linear-gradient(transparent,var(--pink)); box-shadow:0 0 10px var(--pink); }
  .scroll-cue small { font-size:9px; }
  .chapter-flow { position:relative; width:min(1320px,calc(100% - 80px)); margin:0 auto; }
  .chapter-flow::before { position:absolute; top:120px; bottom:160px; left:36px; width:1px; background:rgba(255,255,255,.22); content:''; }
  .chapter { position:relative; display:grid; grid-template-columns:90px minmax(280px,420px) 1fr; gap:42px; min-height:0; align-items:center; padding:24px 0; }
  .chapter-number { align-self:start; position:sticky; top:100px; color:var(--pink); font-family:'Noto Serif KR',serif; font-size:64px; line-height:1; }
  .chapter-number::after { position:absolute; top:132px; left:33px; width:7px; height:7px; border-radius:50%; background:#fff; box-shadow:0 0 10px 3px var(--pink); content:''; }
  .chapter-copy { position:relative; z-index:1; }
  .chapter-copy h2,.studio-panel h2 { margin:0 0 20px; font-family:'Noto Serif KR',serif; font-size:clamp(36px,3vw,48px); line-height:1.35; letter-spacing:-.04em; }
  .about-title-line,.novel-title-line { display:block; }
  .chapter-copy>p:not(.eyebrow),.studio-panel p:not(.eyebrow) { margin:0 0 20px; max-width:36em; color:#c9c3cb; font-size:17px; line-height:1.85; word-break:keep-all; }
  .meta-list { display:flex; gap:24px; margin:28px 0; padding:0; list-style:none; color:#c2bcc4; font-size:14px; }
  .meta-list li::first-letter { color:var(--warm); }
  .chapter-image { height:440px; margin:0; overflow:hidden; border-radius:8px; }
  .chapter-image img { width:100%; height:100%; object-fit:cover; }
  .novel-image img { object-position:center 25%; }
  .about-section { grid-template-rows:auto auto; grid-template-columns:90px minmax(340px,470px) 1fr; }
  .about-image { height:350px; }
  .about-image img { object-position:center 48%; }
  .production-flow { grid-column:2/4; display:grid; grid-template-columns:repeat(4,1fr); gap:36px; margin:20px 0 0; padding:0; list-style:none; }
  .production-flow li { position:relative; min-width:0; }
  .flow-index { display:block; margin-bottom:8px; color:var(--warm); font-size:12px; font-weight:800; }
  .production-flow li>div { display:flex; align-items:center; gap:12px; color:var(--pink); font-size:17px; }
  .production-flow i { font-size:31px; }
  .production-flow p { max-width:15em; margin:10px 0 0; color:#b7b0ba; font-size:13px; line-height:1.7; word-break:keep-all; }
  .flow-arrow { position:absolute; top:31px; right:-29px; color:var(--pink); font-size:16px!important; opacity:.7; }
  .filmography-section { grid-template-rows:auto auto; grid-template-columns:90px 1fr; min-height:0; align-content:center; padding:24px 0 40px; }
  .filmography-heading { grid-column:2; align-self:end; }
  .filmography-grid { grid-column:2; display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:28px; }
  .work-card { min-width:0; color:var(--ink); }
  .work-card figure { aspect-ratio:16/10; margin:0 0 16px; overflow:hidden; border:1px solid rgba(255,255,255,.18); border-radius:8px; background:#111; }
  .work-card img { width:100%; height:100%; object-fit:cover; transition:transform .35s ease; }
  .work-card:hover img,.work-card:focus-visible img { transform:scale(1.035); }
  .work-card div { display:grid; gap:6px; }
  .work-card strong { min-height:1.5em; font-size:18px; line-height:1.5; }
  .work-card span { color:#aaa4ac; font-size:13px; line-height:1.6; }
  .work-card small { color:var(--pink); font-size:13px; font-weight:800; }
  .studio-section { min-height:0; grid-template-columns:90px 1fr; padding:24px 0 40px; }
  .studio-panel { grid-column:2; position:relative; min-height:200px; display:grid; grid-template-columns:1fr auto; align-items:center; gap:48px; overflow:hidden; border:1px solid rgba(255,255,255,.19); border-radius:8px; padding:32px 44px; isolation:isolate; }
  .studio-panel::after { position:absolute; inset:0; z-index:-1; background:linear-gradient(90deg,rgba(5,5,9,.98) 0%,rgba(5,5,9,.82) 55%,rgba(5,5,9,.45)); content:''; }
  .studio-panel>img { position:absolute; inset:0; z-index:-2; width:100%; height:100%; object-fit:cover; object-position:center 42%; filter:brightness(.28) saturate(.75); transform:scale(1.18); }
  .studio-panel h2 { margin-bottom:8px; font-family:'Noto Sans KR',sans-serif; font-weight:900; }
  .studio-entry { display:grid; justify-items:start; gap:12px; }
  .studio-entry>span { display:flex; align-items:center; gap:8px; color:var(--warm); font-size:13px; font-weight:800; }
  .studio-entry .button { min-width:220px; }

  @media (max-width:900px) {
    .official-hero { min-height:760px; }
    .hero-copy,.chapter-flow { width:min(100% - 40px,760px); }
    .chapter { grid-template-columns:70px 1fr; gap:24px; min-height:0; padding:72px 0; }
    .chapter-number { grid-row:1; font-size:54px; }
    .chapter-number::after { left:25px; top:106px; }
    .chapter-copy { grid-column:2; }
    .chapter-image { grid-column:2; height:430px; }
    .production-flow { grid-column:2; grid-template-columns:repeat(2,1fr); }
    .filmography-section { grid-template-columns:70px 1fr; }
    .filmography-grid { grid-column:2; grid-template-columns:repeat(2,minmax(0,1fr)); }
    .studio-section { grid-template-columns:70px 1fr; }
  }

  @media (max-width:600px) {
    :global(html) { scroll-padding-top:52px; }
    .official-hero { min-height:650px; align-items:flex-start; }
    .official-hero::after { background:linear-gradient(90deg,rgba(5,5,9,.94),rgba(5,5,9,.28)),linear-gradient(180deg,rgba(5,5,9,.12) 45%,#050509 100%); }
    .official-hero>img { object-position:62% 50%; }
    .hero-copy { width:100%; padding:88px 20px 60px; }
    .eyebrow { margin-bottom:10px; font-size:11px; }
    .hero-copy h1 { font-size:72px; }
    .hero-lead { margin:26px 0 20px; font-size:18px; }
    .hero-actions { gap:8px; }
    .button { min-height:44px; border-radius:7px; padding:0 14px; font-size:12px; }
    .scroll-cue { bottom:20px; }
    .chapter-flow { width:100%; }
    .chapter-flow::before { left:29px; top:62px; bottom:100px; }
    .chapter { display:grid; grid-template-columns:58px minmax(0,1fr); gap:0; padding:42px 0; }
    .chapter-number { grid-column:1; padding-left:20px; font-size:36px; }
    .chapter-number::after { top:82px; left:26px; width:6px; height:6px; }
    .chapter-copy { grid-column:2; padding:0 20px 24px 18px; }
    .chapter-copy h2,.studio-panel h2,.about-copy h2 { margin-bottom:12px; font-size:26px; line-height:1.42; }
    .novel-title-line { display:inline; }
    .chapter-copy>p:not(.eyebrow),.studio-panel p:not(.eyebrow) { margin-bottom:14px; font-size:13px; line-height:1.72; }
    .meta-list { gap:12px; margin:14px 0; font-size:10px; }
    .chapter-image { grid-column:2; width:calc(100% - 20px); height:auto; aspect-ratio:16/10; border-radius:4px; }
    .novel-image img { object-position:center 30%; }
    .about-section { grid-template-rows:auto auto auto; grid-template-columns:58px minmax(0,1fr); }
    .production-flow { grid-column:2; grid-row:2; grid-template-columns:repeat(2,minmax(0,1fr)); gap:18px 12px; margin:0; padding:0 20px 26px 18px; }
    .flow-index { margin-bottom:5px; font-size:10px; }
    .production-flow li>div { gap:7px; font-size:13px; }
    .production-flow i { font-size:22px; }
    .production-flow p { max-width:none; margin:6px 0 0; font-size:11px; line-height:1.55; }
    .flow-arrow { display:none; }
    .about-image { grid-row:3; height:auto; }
    .filmography-section { grid-template-columns:58px minmax(0,1fr); padding-bottom:48px; }
    .filmography-heading { grid-column:2; padding-bottom:12px; }
    .filmography-grid { grid-column:2; grid-template-columns:repeat(2,minmax(0,1fr)); gap:9px; padding:0 20px 0 18px; }
    .work-card { overflow:hidden; border:1px solid rgba(255,255,255,.16); border-radius:5px; background:#09090e; }
    .work-card figure { aspect-ratio:3/4; margin:0; border:0; border-radius:0; }
    .work-card div { gap:2px; padding:8px; }
    .work-card strong { min-height:3em; font-size:12px; }
    .work-card span,.work-card small { font-size:10px; }
    .studio-section { grid-template-columns:58px minmax(0,1fr); padding:0 0 54px; }
    .studio-panel { grid-column:2; min-height:210px; grid-template-columns:1fr; gap:14px; border-right:0; border-radius:5px 0 0 5px; padding:28px 20px; }
    .studio-panel>img { transform:scale(1.4); }
    .studio-entry { gap:10px; }
    .studio-entry>span { font-size:11px; }
    .studio-entry .button { width:max-content; min-width:0; }
  }

  @media (prefers-reduced-motion:reduce) { :global(html){scroll-behavior:auto} * { transition-duration:.01ms!important; animation-duration:.01ms!important; animation-iteration-count:1!important; } }
</style>
