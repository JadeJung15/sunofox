---
import SiteChrome from './SiteChrome.astro';
import Layout from '../layouts/Layout.astro';

const { page } = Astro.props;
---

<Layout title={`${page.title} | SunoFox Anime OST Studio`}>
  <SiteChrome active={page.key} />

  <main class="site-main category-page coming-soon-page">
    <section class="category-hero coming-soon-hero reveal" aria-labelledby={`${page.key}Title`}>
      <p class="section-kicker">{page.kicker}</p>
      <h1 id={`${page.key}Title`}>{page.title}</h1>
      <p>{page.body}</p>
    </section>

    <section class="category-content" aria-label={`${page.title} coming soon`}>
      <div class="coming-soon-panel reveal">
        <span>COMING SOON</span>
        <h2>{page.label}</h2>
        <p>{page.status}</p>
        <a class="micro-button" href="/">HOME</a>
      </div>
    </section>
  </main>
</Layout>
