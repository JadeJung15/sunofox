                <span>컷 다양성</span>
                <select id="mv-variety">
                  <option value="balanced">균형</option>
                  <option value="stable">안정적</option>
                  <option value="vivid">다양하게</option>
                </select>
              </label>
              <label class="mv-field">
                <span>의상 변화</span>
                <select id="mv-outfit-flex">
                  <option value="evolving">구간별 변화</option>
                  <option value="fixed">의상 고정</option>
                  <option value="free">분위기별 변화</option>
                </select>
              </label>
              </div>
            </details>
          </div>

          <details class="mv-costume-box mv-collapsible">
