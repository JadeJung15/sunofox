---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { series } from '../data/siteContent.js';
---

<Layout title="Series | SunoFox Anime OST Studio">
  <SiteChrome active="series" />

  <main class="site-main category-page">
    <section class="category-hero reveal" aria-labelledby="seriesTitle">
      <p class="section-kicker">SERIES</p>
      <h1 id="seriesTitle">SERIES</h1>
      <p>기도, 기억, 심해, 이름없는 시리즈의 방향을 정리한 공간입니다. 공개 음원은 YouTube 재생목록 허브에서 이어서 감상할 수 있습니다.</p>
    </section>

    <section class="category-content" aria-label="SunoFox signature series">
      <div class="series-grid series-grid-page">
        {series.map((item) => (
          <a
            class="series-card reveal"
            href={item.playlistHref}
            target="_blank"
            rel="noopener noreferrer"
            data-track={`series_playlist_${item.id}`}
            aria-label={`${item.ko} YouTube 재생목록 허브 열기`}
          >
            <small>{item.number}</small>
            <strong>{item.title}</strong>
            <p>{item.ko}</p>
            <span>{item.desc}</span>
            <b>{item.note}</b>
            <em>PLAYLIST HUB</em>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
