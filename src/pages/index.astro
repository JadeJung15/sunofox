---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import {
  artistLinks,
  featuredStoryOst,
  novelProject,
  structuredData
} from '../data/siteContent.js';

const wordmark = 'SUNOFOX'.split('');
const heroParticles = Array.from({ length: 42 });
const featuredOstHref = artistLinks.featuredOst;
const novelListCta = '소설 보러가기';
---

<Layout
  title="SunoFox | Music to Novel"
  description="SunoFox는 음악에서 시작한 감정을 웹소설과 장면으로 확장하는 IP 스튜디오입니다."
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  jsonLd={structuredData}
>
  <SiteChrome active="home" />

  <main class="site-main landing-main restored-home">
    <section class="hero-stage hero-stage-landing" aria-labelledby="heroTitle">
      <img
        class="home-hero-cover"
        src={novelProject.coverImage}
        alt=""
        width={novelProject.coverWidth}
        height={novelProject.coverHeight}
        aria-hidden="true"
      />

      <div class="hero-particle-layer" aria-hidden="true">
        {heroParticles.map((_, index) => (
          <span style={`--particle-index: ${index + 1}`}></span>
        ))}
      </div>

      <div class="hero-center reveal">
        <p class="hero-kicker">MUSIC TO NOVEL STUDIO</p>
        <h1 id="heroTitle" class="hero-wordmark sign-wordmark" aria-label="SUNOFOX">
          {wordmark.map((letter, index) => (
            <span aria-hidden="true" style={`--letter-index: ${index}`}>{letter}</span>
          ))}
        </h1>
        <p class="hero-tagline">
          음악에서 시작한 장면을 웹소설로 연재합니다.
        </p>
        <p class="hero-subcopy">
          첫 작품인 《{novelProject.title}》는 OST의 감정을 캐릭터와 사건으로 확장한 로맨스 판타지입니다.
        </p>
        <div class="home-hero-meta" aria-label="SunoFox current status">
          <span>WEB NOVEL</span>
          <span>{novelProject.genre}</span>
          <span>READ NOW</span>
        </div>
      </div>

      <div class="hero-side-actions" aria-label="SunoFox quick actions">
        <a class="main-button main-button-primary" href="/novels/" aria-label="소설 회차 목록으로 이동">{novelListCta}</a>
        <a class="main-button main-button-muted" href={featuredOstHref} target="_blank" rel="noopener noreferrer">OST 감상</a>
        <a class="main-button main-button-muted" href="/mv-studio">STUDIO</a>
      </div>
    </section>

    <section class="home-novel-entry reveal" aria-labelledby="homeNovelEntryTitle">
      <div>
        <p class="section-kicker">NOVEL LIST</p>
        <h2 id="homeNovelEntryTitle">{novelListCta}</h2>
        <p>《{novelProject.title}》 공개 회차를 한 곳에서 확인하고 바로 읽습니다.</p>
      </div>
      <a class="main-button main-button-primary" href="/novels/" aria-label={`${novelProject.title} 소설 목록 페이지로 이동`}>{novelListCta}</a>
    </section>

    <section class="home-ost-showcase reveal" aria-labelledby="homeOstTitle">
      <a class="home-ost-thumb" href={featuredStoryOst.href} target="_blank" rel="noopener noreferrer" aria-label={`${featuredStoryOst.title} 감상하기`}>
        <img
          src={featuredStoryOst.thumbnail}
          alt={featuredStoryOst.thumbnailAlt}
          width="480"
          height="360"
          loading="lazy"
          decoding="async"
        />
        <span>{featuredStoryOst.type}</span>
      </a>

      <div class="home-ost-copy">
        <p class="section-kicker">FEATURED OST</p>
        <h2 id="homeOstTitle">{featuredStoryOst.title}</h2>
        <p>{featuredStoryOst.summary}</p>
        <div class="home-feature-actions">
          <a class="main-button" href={featuredStoryOst.href} target="_blank" rel="noopener noreferrer">OST 감상</a>
          <a class="main-button main-button-muted" href="/music/">음악 아카이브</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
