---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { featuredStoryOst, latestNovelEpisode, novelProject } from '../data/siteContent.js';
---

<Layout
  title="페이지를 찾을 수 없습니다 | SunoFox"
  description="요청한 SunoFox 페이지를 찾을 수 없습니다. 소설 목록, 최신화, 음악 아카이브, SunoFox 소개로 이동할 수 있습니다."
  canonical="https://sunofox.com/404.html"
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  robots="noindex, follow"
>
  <SiteChrome active="home" />

  <main id="main-content" class="site-main category-page not-found-page">
    <section class="category-hero" aria-labelledby="notFoundTitle">
      <p class="section-kicker">404</p>
      <h1 id="notFoundTitle">페이지를 찾을 수 없습니다</h1>
      <p>주소가 바뀌었거나 아직 공개되지 않은 콘텐츠입니다. 아래 공식 허브에서 이어서 확인해 주세요.</p>
    </section>

    <section class="category-content not-found-panel reveal" aria-label="SunoFox 404 quick links">
      <div>
        <p class="section-kicker">QUICK LINKS</p>
        <h2>공개 콘텐츠로 이동</h2>
        <p>현재 공개 중인 웹소설, OST, 음악 아카이브, SunoFox 소개 페이지로 바로 이동할 수 있습니다.</p>
      </div>

      <div class="not-found-actions">
        <a class="main-button main-button-primary" href="/novels/">소설 보러가기</a>
        <a class="main-button main-button-muted" href={latestNovelEpisode.href}>최신화 보기</a>
        <a class="main-button main-button-muted" href={featuredStoryOst.href} target="_blank" rel="noopener noreferrer">OST 감상</a>
        <a class="main-button main-button-muted" href="/music/">음악 아카이브</a>
        <a class="main-button main-button-muted" href="/profile/">SunoFox 소개</a>
      </div>
    </section>
  </main>
</Layout>
