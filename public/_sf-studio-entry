                  <option value="">직접 설정</option>
                  <option value="premium-illustration">고화질 SF 일러스트</option>
                  <option value="short-film-flow">단편 애니 진행형</option>
                  <option value="rainy-emotion">비 오는 극장판 감성</option>
                  <option value="fantasy-ost">판타지 OST 클라이맥스</option>
                  <option value="fantasy-illustration-standard" selected>판타지 고화질 MV 표준</option>
                  <option value="stable-character">캐릭터 안정형</option>
                  <option value="wide-cinema-flow">와이드 시네마 흐름</option>
                  <option value="action-environment">액션·배경 중심</option>
                  <option value="thumbnail-impact">썸네일 임팩트</option>
                  <option value="character-world">캐릭터+세계 균형</option>
                  <option value="anti-face-grid">얼굴 그리드 방지</option>
                </select>
              </label>
              <label class="mv-field">
                <span>프롬프트 모드</span>
                <select id="mv-prompt-mode">
                  <option value="image">일러스트형</option>
                  <option value="video">영상화형</option>
