---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { featuredStoryOst, latestNovelEpisode, novelProject } from '../data/siteContent.js';
---

<Layout
  title="페이지를 찾을 수 없습니다 | SunoFox"
  description="요청한 SunoFox 페이지를 찾을 수 없습니다. 소설 목록, 최신화, 음악 아카이브, SunoFox 소개로 이동할 수 있습니다."
  canonical="https://sunofox.com/404.html"
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  robots="noindex, follow"
>
  <SiteChrome active="home" />

  <main id="main-content" class="site-main category-page anime-home not-found-page">
    <section class="category-hero not-found-hero" aria-labelledby="notFoundTitle">
      <p class="section-kicker">404 NOT FOUND</p>
      <h1 id="notFoundTitle">페이지를 찾을 수 없습니다</h1>
      <p>주소가 바뀌었거나 아직 공개되지 않은 콘텐츠입니다. SunoFox의 공개 허브에서 다시 이어가 주세요.</p>
    </section>

    <section class="category-content not-found-panel reveal" aria-label="SunoFox 404 quick links">
      <div class="not-found-copy">
        <p class="section-kicker">SUGGESTED PATH</p>
        <h2>다음 장면으로 이동</h2>
        <p>현재 공개 중인 음악 아카이브와 스토리 보드로 바로 이동할 수 있습니다.</p>
      </div>

      <div class="not-found-actions">
        <a class="main-button main-button-primary" href="/">홈으로 돌아가기</a>
        <a class="main-button main-button-muted" href="/music/">음악 아카이브</a>
        <a class="main-button main-button-muted" href="/novels/">소설 보러가기</a>
      </div>

      <nav class="not-found-secondary-links" aria-label="SunoFox secondary 404 links">
        <a href={latestNovelEpisode.href}>최신화</a>
        <a href={featuredStoryOst.href} target="_blank" rel="noopener noreferrer">OST 감상</a>
        <a href="/profile/">채널 소개</a>
      </nav>
    </section>
  </main>
</Layout>
