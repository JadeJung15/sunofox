---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { news } from '../data/siteContent.js';
---

<Layout title="News | SunoFox Anime OST Studio">
  <SiteChrome active="news" />

  <main class="site-main category-page">
    <section class="category-hero reveal" aria-labelledby="newsTitle">
      <p class="section-kicker">NEWS</p>
      <h1 id="newsTitle">NEWS</h1>
      <p>업데이트, 릴리즈, 공식 사이트 변경 사항을 한 페이지에서 확인합니다.</p>
    </section>

    <section class="category-content" aria-label="SunoFox news list">
      <div class="news-list">
        {news.map(([date, title, body]) => (
          <article class="news-row reveal">
            <time datetime={date.replaceAll('.', '-')}>{date}</time>
            <div>
              <h2>{title}</h2>
              <p>{body}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
