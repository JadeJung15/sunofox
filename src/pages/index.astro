---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import {
  artistLinks,
  latestNovelEpisode,
  latestStoryOst,
  musicArchive,
  novelProject,
  structuredData
} from '../data/siteContent.js';

const keyVisual = '/assets/release-desk/mask-good-girl.jpg';

const posterLinks = [
  { label: '채널', title: 'SunoFox 유튜브', description: '신곡과 영상 첫 공개', href: artistLinks.youtube, external: true },
  { label: '소설', title: novelProject.title, description: '완결 미니시즌 정주행', href: novelProject.season.startHref },
  { label: '음악', title: '음악 아카이브', description: 'OST와 앨범 기록', href: musicArchive.href },
  { label: '스튜디오', title: 'MV 스튜디오', description: '소유자 제작실', href: '/login?next=/mv-studio' }
];

const latestEpisodeLabel = `${latestNovelEpisode.label} · ${latestNovelEpisode.title}`;
---

<Layout
  title="SunoFox | Anime OST Studio"
  description="SunoFox는 애니메이션 감성의 OST, 웹소설, 영상 제작 흐름을 단순하고 아름답게 연결하는 공식 홈입니다."
  image={`https://sunofox.com${latestStoryOst.thumbnail}`}
  imageAlt={latestStoryOst.thumbnailAlt}
  imageWidth={1200}
  imageHeight={675}
  jsonLd={structuredData}
>
  <SiteChrome active="home" />

  <main id="main-content" class="site-main anime-home poster-home">
    <section class="poster-hero reveal" aria-labelledby="posterHomeTitle">
      <img
        class="poster-bg"
        src={keyVisual}
        alt="Mask of a Good Girl OST를 상징하는 SunoFox 애니메이션 키비주얼"
        width="1200"
        height="900"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />

      <div class="poster-shell">
        <div class="poster-content">
          <p class="poster-kicker">애니 OST 스튜디오</p>
          <div class="poster-release-meta" aria-label="SunoFox 최신 공개 정보">
            <span>스토리 OST</span>
            <span>{latestStoryOst.date}</span>
            <span>미니시즌 완결</span>
          </div>
          <h1 id="posterHomeTitle"><span>Suno</span><span>Fox</span></h1>
          <p class="poster-lead">감정을 노래하고, 이야기를 장면으로 남깁니다.</p>
          <div class="poster-actions" aria-label="SunoFox 주요 링크">
            <a class="poster-button poster-button-primary" href={latestStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">OST 듣기</a>
            <a class="poster-button" href={novelProject.season.startHref}>소설 보기</a>
          </div>
        </div>

        <a class="poster-now" href={latestStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">
          <span>지금 재생 중</span>
          <strong>{latestStoryOst.title}</strong>
          <small>{latestStoryOst.englishTitle} · {latestStoryOst.date}</small>
          <em>OST 바로 듣기</em>
        </a>
      </div>
    </section>

    <section class="poster-panel reveal" aria-label="SunoFox 추천 경로">
      <div class="poster-panel-head">
        <span>바로 이동</span>
        <strong>콘텐츠 흐름</strong>
      </div>

      <nav class="poster-links" aria-label="SunoFox 주요 경로">
        {posterLinks.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
          >
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <small>{item.description}</small>
          </a>
        ))}
      </nav>

      <a class="poster-story" href={latestNovelEpisode.href}>
        <span>최근 회차</span>
        <strong>{latestEpisodeLabel}</strong>
        <small>스토리 이어 보기</small>
      </a>
    </section>

    <section class="poster-social reveal" aria-label="SunoFox 외부 및 보조 링크">
      <a href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">유튜브</a>
      <a href="/music/">음악 아카이브</a>
      <a href="/updates/">업데이트</a>
      <a href="/profile/">채널 소개</a>
      <a href="https://sunofox.com/">공식 도메인</a>
    </section>
  </main>
</Layout>

<style>
  .anime-home {
    --anime-bg: #050509;
    --anime-ink: #fff7fb;
    --anime-muted: #d8cfdd;
    --anime-soft: #aa9ab4;
    --anime-line: rgba(255, 247, 251, 0.16);
    --anime-accent: #ff6f9f;
    --anime-warm: #f6b86a;
    min-height: 100svh;
    overflow: hidden;
    background: var(--anime-bg);
    color: var(--anime-ink);
  }

  .poster-hero {
    position: relative;
    display: grid;
    min-height: 92svh;
    align-items: center;
    overflow: hidden;
    padding: 112px 0 92px;
    isolation: isolate;
  }

  .poster-hero::before,
  .poster-hero::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    pointer-events: none;
  }

  .poster-hero::before {
    background:
      linear-gradient(90deg, rgba(5, 5, 9, 0.95), rgba(5, 5, 9, 0.62) 42%, rgba(5, 5, 9, 0.1)),
      linear-gradient(180deg, rgba(5, 5, 9, 0.2), rgba(5, 5, 9, 0.08) 42%, rgba(5, 5, 9, 0.94));
  }

  .poster-hero::after {
    background:
      radial-gradient(circle at 27% 26%, rgba(255, 111, 159, 0.24), transparent 26rem),
      radial-gradient(circle at 82% 18%, rgba(246, 184, 106, 0.16), transparent 28rem),
      linear-gradient(rgba(255, 247, 251, 0.028) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 247, 251, 0.028) 1px, transparent 1px);
    background-size: auto, auto, 54px 54px, 54px 54px;
    opacity: 0.8;
  }

  .poster-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 64% 42%;
    filter: saturate(1.12) contrast(1.08);
  }

  .poster-shell,
  .poster-panel,
  .poster-social {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
  }

  .poster-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(300px, 0.42fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: end;
  }

  .poster-content {
    display: grid;
    gap: 18px;
    min-width: 0;
    padding-top: clamp(54px, 10vh, 116px);
  }

  .poster-kicker {
    margin: 0;
    color: var(--anime-warm);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0;
  }

  .poster-release-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .poster-release-meta span {
    display: inline-flex;
    min-height: 28px;
    align-items: center;
    border: 1px solid rgba(255, 247, 251, 0.14);
    border-radius: 999px;
    padding: 0 10px;
    background: rgba(5, 5, 9, 0.32);
    color: var(--anime-soft);
    font-size: 0.75rem;
    font-weight: 820;
    backdrop-filter: blur(10px);
  }

  .poster-content h1 {
    display: grid;
    max-width: 8ch;
    margin: 0;
    color: var(--anime-ink);
    font-size: clamp(5rem, 13vw, 10.6rem);
    font-weight: 950;
    line-height: 0.82;
    letter-spacing: 0;
    overflow-wrap: anywhere;
    text-shadow: 0 0 34px rgba(255, 111, 159, 0.24);
  }

  .poster-content h1 span:last-child {
    color: var(--anime-accent);
  }

  .poster-lead {
    max-width: 420px;
    margin: 0;
    color: var(--anime-muted);
    font-size: 1.08rem;
    font-weight: 680;
    line-height: 1.75;
    word-break: keep-all;
  }

  .poster-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding-top: 4px;
  }

  .poster-button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--anime-line);
    border-radius: 999px;
    padding: 0 20px;
    background: rgba(5, 5, 9, 0.36);
    color: var(--anime-ink);
    font-size: 0.94rem;
    font-weight: 900;
    backdrop-filter: blur(12px);
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .poster-button:hover,
  .poster-button:focus-visible {
    border-color: var(--anime-accent);
    background: rgba(255, 111, 159, 0.12);
    transform: translateY(-1px);
  }

  .poster-button-primary {
    border-color: var(--anime-accent);
    background: var(--anime-accent);
    color: #1d0711;
  }

  .poster-now {
    display: grid;
    gap: 10px;
    min-width: 0;
    border: 1px solid rgba(255, 247, 251, 0.18);
    border-radius: 8px;
    padding: 20px;
    background:
      linear-gradient(145deg, rgba(255, 111, 159, 0.16), transparent 52%),
      rgba(5, 5, 9, 0.48);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(18px);
  }

  .poster-now span,
  .poster-panel-head span,
  .poster-links span,
  .poster-story span,
  .poster-social a {
    color: var(--anime-soft);
    font-size: 0.78rem;
    font-weight: 860;
  }

  .poster-now span {
    color: var(--anime-warm);
  }

  .poster-now strong {
    color: var(--anime-ink);
    font-size: clamp(1.2rem, 2.1vw, 1.7rem);
    font-weight: 950;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .poster-now small {
    color: var(--anime-soft);
    font-size: 0.9rem;
    font-weight: 720;
  }

  .poster-now em {
    display: inline-flex;
    width: fit-content;
    min-height: 32px;
    align-items: center;
    border-bottom: 1px solid rgba(255, 111, 159, 0.6);
    color: var(--anime-accent);
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 900;
  }

  .poster-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.36fr);
    gap: 16px;
    margin-top: -46px;
    padding: 0;
    position: relative;
    z-index: 2;
  }

  .poster-panel-head {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    align-items: end;
    justify-content: space-between;
  }

  .poster-panel-head strong {
    color: var(--anime-ink);
    font-size: 1.25rem;
    font-weight: 950;
    line-height: 1.2;
  }

  .poster-links {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid var(--anime-line);
    border-radius: 8px;
    background: rgba(5, 5, 9, 0.58);
    backdrop-filter: blur(18px);
  }

  .poster-links a {
    display: grid;
    gap: 6px;
    min-width: 0;
    min-height: 116px;
    align-content: center;
    border-right: 1px solid var(--anime-line);
    padding: 16px;
  }

  .poster-links a:last-child {
    border-right: 0;
  }

  .poster-links a:hover,
  .poster-links a:focus-visible {
    background: rgba(255, 111, 159, 0.12);
  }

  .poster-links strong {
    color: var(--anime-ink);
    font-size: 1.05rem;
    font-weight: 930;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .poster-links small,
  .poster-story small {
    color: var(--anime-soft);
    font-size: 0.78rem;
    font-weight: 720;
    line-height: 1.35;
    word-break: keep-all;
  }

  .poster-story {
    display: grid;
    gap: 8px;
    min-width: 0;
    align-content: center;
    border: 1px solid var(--anime-line);
    border-radius: 8px;
    padding: 18px;
    background:
      linear-gradient(160deg, rgba(246, 184, 106, 0.15), transparent 52%),
      rgba(5, 5, 9, 0.58);
    backdrop-filter: blur(18px);
  }

  .poster-story strong {
    color: var(--anime-muted);
    font-size: 1rem;
    font-weight: 850;
    overflow-wrap: anywhere;
  }

  .poster-social {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    justify-content: center;
    padding: 34px 0 78px;
  }

  .poster-social a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
  }

  .poster-social a:hover,
  .poster-social a:focus-visible {
    color: var(--anime-accent);
  }

  @media (max-width: 760px) {
    .poster-hero {
      min-height: 100svh;
      align-items: end;
      padding: 82px 0 22px;
    }

    .poster-hero::before {
      background:
        linear-gradient(180deg, rgba(5, 5, 9, 0.12), rgba(5, 5, 9, 0.16) 36%, rgba(5, 5, 9, 0.96)),
        linear-gradient(90deg, rgba(5, 5, 9, 0.38), transparent 68%);
    }

    .poster-bg {
      object-position: 56% 50%;
    }

    .poster-shell,
    .poster-panel,
    .poster-social {
      width: calc(100% - 28px);
    }

    .poster-shell {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .poster-content {
      padding-top: min(34svh, 260px);
    }

    .poster-content h1 {
      max-width: 7ch;
      font-size: 4.2rem;
      line-height: 0.88;
    }

    .poster-lead {
      font-size: 1rem;
      line-height: 1.65;
    }

    .poster-actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .poster-button {
      width: 100%;
    }

    .poster-now {
      padding: 16px;
    }

    .poster-now strong {
      font-size: 1.08rem;
    }

    .poster-now small {
      grid-column: 1;
    }

    .poster-panel {
      grid-template-columns: 1fr;
      margin-top: 0;
      padding-top: 22px;
    }

    .poster-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .poster-links a {
      min-height: 116px;
      border-bottom: 1px solid var(--anime-line);
      padding: 14px;
    }

    .poster-links a:nth-child(2n) {
      border-right: 0;
    }

    .poster-links a:nth-last-child(-n + 2) {
      border-bottom: 0;
    }

    .poster-links a:last-child {
      border-bottom: 0;
    }

    .poster-story {
      display: grid;
      gap: 8px;
    }

    .poster-social {
      padding-bottom: 58px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .poster-button,
    .poster-links a {
      transition: none;
    }
  }
</style>
