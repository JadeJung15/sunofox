              </span>
            </label>
            <div class="mv-consistency-fields" id="mv-consistency-fields">
            <div class="mv-reference-grid">
              <label class="mv-field">
                <span>캐릭터 참조 URL</span>
                <input id="mv-character-ref-url" type="url" placeholder="Midjourney Omni Reference URL">
              </label>
              <label class="mv-field">
                <span>스타일 참조 URL</span>
                <input id="mv-style-ref-url" type="url" placeholder="Midjourney Style Reference URL">
              </label>
            </div>
