---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { communityCategories, communityPosts } from '../data/siteContent.js';

const initialPostsJson = JSON.stringify(communityPosts).replace(/</g, '\\u003c');
const categoryOptions = communityCategories.filter((item) => !['all', 'notice'].includes(item.key));
---

<Layout
  title="Community | SunoFox Anime OST Studio"
  description="SunoFox 팬들이 듣고 싶은 분위기, 장르, 캐릭터 아이디어, 감상 후기를 나눌 수 있는 커뮤니티 준비 공간입니다."
  canonical="https://sunofox.com/community/"
>
  <SiteChrome active="community" />

  <main class="site-main category-page community-page">
    <section class="category-hero reveal" aria-labelledby="communityTitle">
      <p class="section-kicker">COMMUNITY</p>
      <h1 id="communityTitle">FAN BOARD</h1>
      <p>팬들이 감상, 아이디어, 듣고 싶은 분위기를 일반 게시물 리스트로 나누는 소통 공간입니다.</p>
      <div class="community-hero-actions" aria-label="Fan board quick actions">
        <a class="main-button" href="#communityPosts">BROWSE POSTS</a>
        <a class="main-button main-button-muted" href="/login?next=/community">LOGIN TO WRITE</a>
      </div>
    </section>

    <section class="category-content" aria-label="SunoFox fan board">
      <div class="community-status reveal">
        <span>OPEN BETA</span>
        <p>일반 게시물 리스트는 누구나 볼 수 있습니다. 작성은 스팸 방지를 위해 가입 신청 후 사이트 주인 승인을 받은 계정부터 이용할 수 있습니다.</p>
        <div class="community-status-actions">
          <a class="main-button" href="/community/?board=free#communityPosts">GENERAL POSTS</a>
          <a class="main-button main-button-muted" href="/signup">JOIN</a>
        </div>
      </div>

      <div class="community-layout">
        <aside class="community-categories reveal" aria-label="Fan board categories">
          {communityCategories.map((item) => (
            <button
              type="button"
              class={item.key === 'all' ? 'is-current' : undefined}
              data-community-board={item.key}
              aria-pressed={item.key === 'all' ? 'true' : 'false'}
            >
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.desc}</p>
            </button>
          ))}
        </aside>

        <section id="communityPosts" class="community-board reveal" aria-label="Fan board post list">
          <div class="community-board-head">
            <div>
              <span>POST LIST</span>
              <p class="community-board-note">SAMPLE 배지가 붙은 글은 팬게시판 운영 예시입니다. 실제 팬 글은 가입 승인 후 작성되면 같은 목록에 표시됩니다.</p>
            </div>
            <strong data-community-count>{communityPosts.length} POSTS</strong>
          </div>

          <div class="community-board-message" data-community-message hidden></div>

          <div class="community-post-list" data-community-list>
            {communityPosts.map((post) => (
              <article class="community-post-row" data-post-id={post.id}>
                <div class="community-post-meta">
                  <span>{post.category}</span>
                  <time datetime={post.date.replaceAll('.', '-')}>{post.date}</time>
                </div>
                <div class="community-post-main">
                  <h2><a href={`/community/post/?id=${encodeURIComponent(post.id)}`}>{post.title}</a></h2>
                  <p>{post.excerpt}</p>
                  <div>
                    <span>{post.author}</span>
                    <span>{post.comments} COMMENTS</span>
                    <span class={`community-status-chip ${post.status === 'SAMPLE' ? 'is-sample' : post.status === 'PINNED' ? 'is-pinned' : ''}`}>{post.status}</span>
                  </div>
                  <div class="community-post-actions">
                    <a href={`/community/post/?id=${encodeURIComponent(post.id)}`}>READ POST</a>
                  </div>
                </div>
              </article>
            ))}
          </div>

          <div id="communityWrite" class="community-write-panel" aria-label="Fan board write status">
            <div class="community-write-copy">
              <span>WRITE POST</span>
              <h2>팬 게시글 작성</h2>
              <p>승인된 계정으로 로그인하면 팬게시판에 글을 남길 수 있습니다. 모바일에서도 짧게 작성할 수 있도록 제목과 핵심 아이디어만 먼저 남겨 주세요.</p>
            </div>

            <div class="community-auth-note" role="note">
              <span>APPROVAL REQUIRED</span>
              <p>작성, 댓글, 좋아요, 신고는 가입 신청 후 사이트 주인 승인을 받은 계정에서 사용할 수 있습니다. 아직 승인 전이면 글을 읽고 아이디어를 정리해 두시면 됩니다.</p>
            </div>

            <div class="community-first-post-guide" aria-label="첫 게시글 작성 가이드">
              <strong>첫 글로 이런 이야기를 남겨 주세요</strong>
              <div>
                <span>듣고 싶은 장르</span>
                <span>캐릭터 아이디어</span>
                <span>장면 분위기</span>
                <span>곡 감상 후기</span>
              </div>
              <p>예: 비 오는 도시에서 시작해 후반부에 Symphonic DnB로 터지는 전투 OST가 듣고 싶어요.</p>
            </div>

            <form class="community-write-form" data-community-form>
              <label>
                <span>카테고리</span>
                <select name="board" required>
                  {categoryOptions.map((item) => (
                    <option value={item.key}>{item.title}</option>
                  ))}
                </select>
                <small>곡 제안, 분위기, 감상 후기 중 가장 가까운 주제를 선택해 주세요.</small>
              </label>

              <label>
                <span>제목</span>
                <input name="title" type="text" maxlength="90" required placeholder="예: 비 오는 도시 전투 OST가 듣고 싶어요" />
                <small>모바일에서는 20자 안팎의 짧은 제목이 가장 읽기 좋습니다.</small>
              </label>

              <label>
                <span>내용</span>
                <textarea name="body" rows="4" maxlength="5000" required placeholder="듣고 싶은 분위기, 장르, 캐릭터 아이디어, 감상 후기를 자유롭게 적어 주세요."></textarea>
                <small>예: 시작은 조용한 피아노, 후반은 Symphonic DnB로 터지는 장면이 좋아요.</small>
              </label>

              <p class="community-write-note">게시 후 문제가 있는 글은 운영자가 숨김 또는 삭제 처리할 수 있습니다.</p>

              <div class="community-write-actions">
                <button class="main-button" type="submit">PUBLISH POST</button>
                <a class="main-button main-button-muted" href="/login?next=/community">LOGIN</a>
                <a class="main-button main-button-muted" href="/signup">JOIN</a>
              </div>

              <p class="community-form-message" data-community-form-message role="status" aria-live="polite"></p>
            </form>

            <div class="community-published-panel" data-community-published-panel hidden>
              <span>POST READY</span>
              <h3 data-community-published-title>게시글 등록 완료</h3>
              <p>방금 작성한 글이 팬게시판 목록에 반영되었습니다. 상세 화면에서 댓글과 반응을 확인할 수 있습니다.</p>
              <div class="community-published-actions">
                <a href="/community/" data-community-published-link>방금 쓴 글 보기</a>
                <a href="#communityPosts">목록에서 확인</a>
              </div>
            </div>
          </div>
        </section>
      </div>

      <div class="community-flow reveal" aria-label="Fan board publishing flow">
        <article>
          <span>01</span>
          <strong>READ</strong>
          <p>일반 게시물, 미디어 이야기, 이벤트, 공지를 공개 리스트로 확인합니다.</p>
        </article>
        <article>
          <span>02</span>
          <strong>JOIN</strong>
          <p>가입 신청 후 승인된 계정은 팬게시판에 직접 글을 남길 수 있습니다.</p>
        </article>
        <article>
          <span>03</span>
          <strong>TALK</strong>
          <p>듣고 싶은 장르, 캐릭터 설정, 영상 감상, 작업 아이디어를 함께 모읍니다.</p>
        </article>
      </div>

      <section class="community-rules reveal" aria-label="Fan board rules">
        <div>
          <span>BOARD RULES</span>
          <h2>팬게시판 운영 기준</h2>
        </div>
        <ul>
          <li>음악 감상, 듣고 싶은 분위기, 장르, 캐릭터/세계관 아이디어를 자유롭게 남길 수 있습니다.</li>
          <li>비방, 개인정보, 광고, 도배, 저작권 침해 요청은 숨김 또는 삭제될 수 있습니다.</li>
          <li>문제가 있는 글이나 댓글은 관리자 확인 후 숨김/삭제 처리합니다.</li>
        </ul>
      </section>
    </section>
  </main>

  <div class="community-report-modal" data-community-report-modal hidden>
    <div class="community-report-card" role="dialog" aria-modal="true" aria-labelledby="communityReportTitle">
      <form data-community-report-form>
        <div class="community-report-head">
          <span>REPORT</span>
          <h2 id="communityReportTitle">신고 사유 선택</h2>
          <button type="button" data-community-report-close aria-label="신고 창 닫기">×</button>
        </div>
        <label>
          <span>신고 사유</span>
          <select name="reason" required>
            <option value="">선택해 주세요</option>
            <option value="스팸 또는 광고">스팸 또는 광고</option>
            <option value="욕설 또는 비방">욕설 또는 비방</option>
            <option value="개인정보 노출">개인정보 노출</option>
            <option value="저작권 문제">저작권 문제</option>
            <option value="부적절한 내용">부적절한 내용</option>
            <option value="기타">기타</option>
          </select>
        </label>
        <label>
          <span>상세 내용</span>
          <textarea name="detail" rows="4" maxlength="1000" placeholder="운영자가 확인할 수 있도록 필요한 내용만 간단히 적어 주세요."></textarea>
        </label>
        <div class="community-report-actions">
          <button type="button" data-community-report-cancel>취소</button>
          <button type="submit">신고 접수</button>
        </div>
      </form>
    </div>
  </div>

  <script id="communityInitialPosts" type="application/json" set:html={initialPostsJson}></script>
  <script is:inline>
    function initCommunityBoard() {
      const list = document.querySelector('[data-community-list]');
      const count = document.querySelector('[data-community-count]');
      const message = document.querySelector('[data-community-message]');
      const form = document.querySelector('[data-community-form]');
      const formMessage = document.querySelector('[data-community-form-message]');
      const publishedPanel = document.querySelector('[data-community-published-panel]');
      const publishedTitle = document.querySelector('[data-community-published-title]');
      const publishedLink = document.querySelector('[data-community-published-link]');
      const filterButtons = [...document.querySelectorAll('[data-community-board]')];
      const initialPostsNode = document.getElementById('communityInitialPosts');
      const reportModal = document.querySelector('[data-community-report-modal]');
      const reportForm = document.querySelector('[data-community-report-form]');
      const reportCloseButtons = [...document.querySelectorAll('[data-community-report-close], [data-community-report-cancel]')];
      const initialPosts = JSON.parse(initialPostsNode?.textContent || '[]');
      const allowedBoards = new Set(['all', ...filterButtons.map((button) => button.dataset.communityBoard).filter(Boolean)]);
      const emptyStates = {
        all: {
          label: 'NO POSTS',
          title: '아직 공개된 팬 게시물이 없습니다.',
          body: '승인된 계정으로 첫 인사, 감상 후기, 듣고 싶은 장르를 남기면 이 영역에 게시글이 표시됩니다. 아직 계정이 없다면 가입 신청부터 진행해 주세요.',
          action: '작성 안내 보기'
        },
        free: {
          label: 'FREE TALK',
          title: '일반 게시물이 아직 없습니다.',
          body: '처음 방문한 인사, 좋아하는 곡, SunoFox에 바라는 이야기를 편하게 남겨 주세요.',
          action: '일반 게시물 안내'
        },
        request: {
          label: 'TRACK REQUEST',
          title: '듣고 싶은 곡 제안이 아직 없습니다.',
          body: 'Anime OST, Symphonic DnB, Ethereal Pop처럼 듣고 싶은 장르와 장면을 구체적으로 적어 주세요.',
          action: '곡 아이디어 안내'
        },
        mood: {
          label: 'MOOD IDEAS',
          title: '분위기 제안이 아직 없습니다.',
          body: '비 오는 도시, 심해, 밤하늘, 전투 전 긴장감처럼 곡으로 듣고 싶은 감정을 남길 수 있습니다.',
          action: '분위기 작성 안내'
        },
        feedback: {
          label: 'FEEDBACK',
          title: '감상 후기가 아직 없습니다.',
          body: '공개된 곡, 영상, 가사, 시리즈에 대한 짧은 감상이나 개선 의견을 남겨 주세요.',
          action: '감상 후기 안내'
        },
        notice: {
          label: 'NOTICE',
          title: '표시할 공지가 없습니다.',
          body: '운영자가 새 공지를 등록하면 이곳에 고정되어 표시됩니다.',
          action: '목록 보기'
        }
      };
      let activeBoard = getBoardFromUrl();
      let pendingReport = null;
      let reportReturnFocus = null;
      let recentPostId = '';
      let communityToastTimer = 0;

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function formatDate(value) {
        if (!value) return '';
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return String(value);
        return new Intl.DateTimeFormat('ko-KR', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit'
        }).format(parsed).replace(/\s/g, '');
      }

      function normalizePost(post) {
        return {
          id: post.id || '',
          board: post.board || '',
          category: post.boardName || post.category || 'GENERAL',
          title: post.title || '',
          excerpt: post.body || post.excerpt || '',
          author: post.authorName || post.author || 'Fan',
          date: formatDate(post.createdAt || post.date),
          comments: Number(post.commentCount ?? post.comments ?? 0),
          likes: Number(post.likeCount || 0),
          status: post.pinned ? 'PINNED' : (post.status || 'PUBLISHED'),
          isSample: String(post.status || '').toUpperCase() === 'SAMPLE' || String(post.id || '').startsWith('idea-')
        };
      }

      function setMessage(text, type) {
        if (!message) return;
        message.hidden = !text;
        message.textContent = text || '';
        message.dataset.type = type || 'info';
      }

      function setFormMessage(text, type) {
        if (!formMessage) return;
        formMessage.textContent = text || '';
        formMessage.dataset.type = type || 'info';
      }

      function getCommunityActionError(error, fallback = '요청을 처리하지 못했습니다.') {
        const raw = String(error?.message || fallback).trim();
        if (/로그인/.test(raw)) {
          return '로그인이 필요합니다. 가입 승인 후 로그인하면 글 작성, 댓글, 좋아요를 사용할 수 있습니다.';
        }
        if (/승인/.test(raw)) {
          return '가입 신청 승인 후 사용할 수 있습니다. 승인 전에는 게시글 읽기만 가능합니다.';
        }
        if (/데이터베이스|연결/.test(raw)) {
          return '커뮤니티 저장소 연결을 확인하는 중입니다. 잠시 후 다시 시도해 주세요.';
        }
        return raw;
      }

      function communityToastMeta(type, title) {
        if (title) return { icon: type === 'error' ? '!' : type === 'info' ? 'i' : '✓', title };
        if (type === 'error') return { icon: '!', title: 'CHECK REQUIRED' };
        if (type === 'info') return { icon: 'i', title: 'NOTICE' };
        return { icon: '✓', title: 'POST READY' };
      }

      function showCommunityToast(text, type, title) {
        let toast = document.getElementById('communityToast');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'communityToast';
          toast.className = 'community-toast';
          document.body.appendChild(toast);
        }
        const toastType = type || 'success';
        const meta = communityToastMeta(toastType, title);
        toast.dataset.type = toastType;
        toast.setAttribute('role', toastType === 'error' ? 'alert' : 'status');
        toast.setAttribute('aria-live', toastType === 'error' ? 'assertive' : 'polite');
        toast.innerHTML = `
          <span class="community-toast-icon" aria-hidden="true">${meta.icon}</span>
          <span class="community-toast-copy">
            <strong>${escapeHtml(meta.title)}</strong>
            <span>${escapeHtml(text)}</span>
          </span>
          <button type="button" aria-label="알림 닫기">닫기</button>
        `;
        toast.hidden = false;
        window.requestAnimationFrame(() => {
          toast.classList.add('is-visible');
        });
        toast.querySelector('button')?.addEventListener('click', hideCommunityToast);
        window.clearTimeout(communityToastTimer);
        communityToastTimer = window.setTimeout(hideCommunityToast, toastType === 'error' ? 7000 : 4600);
      }

      function hideCommunityToast() {
        const toast = document.getElementById('communityToast');
        if (!toast) return;
        toast.classList.remove('is-visible');
        window.clearTimeout(communityToastTimer);
        communityToastTimer = window.setTimeout(() => {
          toast.hidden = true;
        }, 220);
      }

      function setPublishedPanel(post) {
        if (!publishedPanel) return;
        if (!post?.id) {
          publishedPanel.hidden = true;
          return;
        }
        if (publishedTitle) publishedTitle.textContent = post.title || '게시글 등록 완료';
        if (publishedLink) publishedLink.href = `/community/post/?id=${encodeURIComponent(post.id)}`;
        publishedPanel.hidden = false;
      }

      function closeReportModal(result) {
        if (!reportModal) return;
        reportModal.hidden = true;
        document.body.classList.remove('community-report-is-open');
        if (pendingReport) {
          pendingReport.resolve(result || null);
          pendingReport = null;
        }
        if (reportReturnFocus && typeof reportReturnFocus.focus === 'function') {
          reportReturnFocus.focus();
        }
        reportReturnFocus = null;
      }

      function openReportModal(button) {
        if (!reportModal || !reportForm) {
          setMessage('신고 창을 열 수 없습니다. 새로고침 후 다시 시도해 주세요.', 'error');
          return Promise.resolve(null);
        }
        if (pendingReport) closeReportModal(null);
        reportForm.reset();
        reportReturnFocus = button || document.activeElement;
        reportModal.hidden = false;
        document.body.classList.add('community-report-is-open');
        window.setTimeout(() => reportForm.querySelector('select')?.focus(), 0);
        return new Promise((resolve) => {
          pendingReport = { resolve };
        });
      }

      reportForm?.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(reportForm);
        const reason = String(data.get('reason') || '').trim();
        const detail = String(data.get('detail') || '').trim();
        if (!reason) return;
        closeReportModal({ reason, detail });
      });

      reportCloseButtons.forEach((button) => {
        button.addEventListener('click', () => closeReportModal(null));
      });

      reportModal?.addEventListener('click', (event) => {
        if (event.target === reportModal) closeReportModal(null);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && reportModal && !reportModal.hidden) {
          closeReportModal(null);
        }
      });

      function getBoardFromUrl() {
        const board = new URLSearchParams(window.location.search).get('board') || 'all';
        return allowedBoards.has(board) ? board : 'all';
      }

      function updateBoardUrl(board) {
        const nextUrl = new URL(window.location.href);
        if (board === 'all') {
          nextUrl.searchParams.delete('board');
        } else {
          nextUrl.searchParams.set('board', board);
        }
        nextUrl.hash = 'communityPosts';
        window.history.pushState({ board }, '', nextUrl);
      }

      function syncFilterButtons() {
        filterButtons.forEach((button) => {
          const current = button.dataset.communityBoard === activeBoard;
          button.classList.toggle('is-current', current);
          button.setAttribute('aria-pressed', String(current));
        });
      }

      function getFallbackPosts() {
        return activeBoard === 'all'
          ? initialPosts
          : initialPosts.filter((post) => post.board === activeBoard || String(post.category || '').toLowerCase().includes(activeBoard));
      }

      function renderPosts(posts) {
        if (!list) return;
        const normalized = posts.map(normalizePost);
        if (count) count.textContent = `${normalized.length} POSTS`;
        if (!normalized.length) {
          const state = emptyStates[activeBoard] || emptyStates.all;
          list.innerHTML = `
            <article class="community-empty community-empty-card">
              <span>${escapeHtml(state.label)}</span>
              <strong>${escapeHtml(state.title)}</strong>
              <p>${escapeHtml(state.body)}</p>
              <div class="community-empty-actions">
                <a href="#communityWrite">${escapeHtml(state.action)}</a>
                <a href="/signup">JOIN TO WRITE</a>
              </div>
            </article>
          `;
          return;
        }

        list.innerHTML = normalized.map((post) => `
          <article class="community-post-row ${post.id === recentPostId ? 'is-new' : ''}" data-post-id="${escapeHtml(post.id)}">
            <div class="community-post-meta">
              <span>${escapeHtml(post.category)}</span>
              <time datetime="${escapeHtml(String(post.date).replaceAll('.', '-'))}">${escapeHtml(post.date)}</time>
              ${post.id === recentPostId ? '<span class="community-new-chip">NEW</span>' : ''}
            </div>
            <div class="community-post-main">
              <h2>
                <a href="/community/post/?id=${encodeURIComponent(post.id)}">
                  ${escapeHtml(post.title)}
                </a>
              </h2>
              <p>${escapeHtml(post.excerpt)}</p>
              <div>
                <span>${escapeHtml(post.author)}</span>
                <span>${post.comments} COMMENTS</span>
                <span class="community-status-chip ${post.isSample ? 'is-sample' : post.status === 'PINNED' ? 'is-pinned' : ''}">${escapeHtml(post.status).toUpperCase()}</span>
              </div>
              <div class="community-post-actions">
                <a href="/community/post/?id=${encodeURIComponent(post.id)}">
                  READ POST
                </a>
                <button type="button" data-community-reaction data-post-id="${escapeHtml(post.id)}" data-value="1">
                  LIKE <strong>${post.likes}</strong>
                </button>
                <button type="button" data-community-comments-toggle data-post-id="${escapeHtml(post.id)}">
                  COMMENTS
                </button>
                <button type="button" data-community-report-post data-post-id="${escapeHtml(post.id)}">
                  REPORT
                </button>
              </div>
              <div class="community-comments" data-community-comments="${escapeHtml(post.id)}" hidden>
                <div class="community-comments-list" data-community-comments-list>
                  <p>댓글을 불러오는 중입니다.</p>
                </div>
                <form class="community-comment-form" data-community-comment-form data-post-id="${escapeHtml(post.id)}">
                  <textarea name="body" rows="3" maxlength="1200" required placeholder="댓글을 입력해 주세요. 승인된 계정만 작성할 수 있습니다."></textarea>
                  <div class="community-comment-actions">
                    <button type="submit">COMMENT</button>
                    <a href="/login?next=/community">LOGIN</a>
                    <a href="/signup">JOIN</a>
                  </div>
                </form>
                <p class="community-comment-message" data-community-comment-message role="status" aria-live="polite"></p>
              </div>
            </div>
          </article>
        `).join('');
      }

      function renderComments(panel, comments) {
        const target = panel.querySelector('[data-community-comments-list]');
        if (!target) return;
        if (!comments.length) {
          target.innerHTML = '<p>아직 댓글이 없습니다. 첫 댓글을 남겨 주세요.</p>';
          return;
        }
        target.innerHTML = comments.map((comment) => `
          <article class="community-comment-row">
            <strong>${escapeHtml(comment.authorName || 'Fan')}</strong>
            <time datetime="${escapeHtml(comment.createdAt || '')}">${escapeHtml(formatDate(comment.createdAt))}</time>
            <p>${escapeHtml(comment.body || '')}</p>
            <button type="button" data-community-report-comment data-comment-id="${escapeHtml(comment.id)}">REPORT</button>
          </article>
        `).join('');
      }

      async function submitReport({ targetType, targetId, messageTarget, button }) {
        if (!targetId || targetId.startsWith('idea-') || targetId.startsWith('notice-')) {
          const text = '예시 게시글은 신고할 수 없습니다.';
          if (messageTarget) {
            messageTarget.textContent = text;
            messageTarget.dataset.type = 'error';
          } else {
            setMessage(text, 'error');
          }
          showCommunityToast(text, 'error');
          return;
        }

        const report = await openReportModal(button);
        if (!report) return;

        if (button) button.disabled = true;
        if (messageTarget) {
          messageTarget.textContent = '신고를 접수하는 중입니다.';
          messageTarget.dataset.type = 'info';
        } else {
          setMessage('신고를 접수하는 중입니다.', 'info');
        }

        try {
          const response = await fetch('/api/community/reports', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              targetType,
              targetId,
              reason: report.reason,
              detail: report.detail
            })
          });
          const result = await response.json().catch(() => ({}));
          if (!response.ok || !result.ok) {
            throw new Error(result.message || '신고를 접수하지 못했습니다.');
          }
          const text = result.duplicate ? '이미 신고가 접수되어 있습니다.' : '신고가 접수되었습니다. 운영자가 확인하겠습니다.';
          if (messageTarget) {
            messageTarget.textContent = text;
            messageTarget.dataset.type = 'success';
          } else {
            setMessage(text, 'success');
          }
          showCommunityToast(text, 'success', result.duplicate ? 'REPORT EXISTS' : 'REPORT RECEIVED');
        } catch (error) {
          const text = getCommunityActionError(error, '신고를 접수하지 못했습니다.');
          if (messageTarget) {
            messageTarget.textContent = text;
            messageTarget.dataset.type = 'error';
          } else {
            setMessage(text, 'error');
          }
          showCommunityToast(text, 'error');
        } finally {
          if (button) button.disabled = false;
        }
      }

      async function loadComments(postId, panel) {
        const response = await fetch(`/api/community/comments?postId=${encodeURIComponent(postId)}`);
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.ok) {
          throw new Error(data.message || '댓글을 불러오지 못했습니다.');
        }
        renderComments(panel, data.comments || []);
      }

      async function loadPosts() {
        setMessage('게시글을 불러오는 중입니다.', 'info');
        try {
          const params = new URLSearchParams({
            board: activeBoard,
            limit: '30'
          });
          const response = await fetch(`/api/community/posts?${params.toString()}`);
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.ok) {
            throw new Error(data.message || '게시글을 불러오지 못했습니다.');
          }
          const serverPosts = data.posts || [];
          if (serverPosts.length) {
            renderPosts(serverPosts);
            setMessage('', 'success');
            return;
          }

          renderPosts(getFallbackPosts());
          const state = emptyStates[activeBoard] || emptyStates.all;
          setMessage(`${state.title} 현재는 SAMPLE 배지가 붙은 안내용 예시 게시글을 표시하고 있습니다.`, 'info');
        } catch (error) {
          renderPosts(getFallbackPosts());
          setMessage('현재는 SAMPLE 배지가 붙은 예시 게시글을 표시하고 있습니다. 실제 게시글은 서버 연결 상태가 안정화되면 같은 목록에 표시됩니다.', 'info');
        }
      }

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeBoard = button.dataset.communityBoard || 'all';
          syncFilterButtons();
          updateBoardUrl(activeBoard);
          loadPosts();
        });
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const submitButton = form.querySelector('button[type="submit"]');
        submitButton.disabled = true;
        setFormMessage('게시글을 등록하는 중입니다.', 'info');
        setPublishedPanel(null);

        const data = new FormData(form);
        try {
          const response = await fetch('/api/community/posts', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              board: data.get('board'),
              title: data.get('title'),
              body: data.get('body')
            })
          });
          const result = await response.json().catch(() => ({}));
          if (!response.ok || !result.ok) {
            throw new Error(result.message || '게시글을 등록하지 못했습니다.');
          }
          const createdPost = result.post || {};
          recentPostId = createdPost.id || '';
          form.reset();
          activeBoard = createdPost.board || String(data.get('board') || 'all');
          syncFilterButtons();
          updateBoardUrl(activeBoard);
          setFormMessage('등록 완료. 팬게시판 목록에서 확인할 수 있습니다.', 'success');
          showCommunityToast('등록 완료. 팬게시판 목록에서 확인할 수 있습니다.', 'success', 'POST READY');
          setPublishedPanel(createdPost);
          await loadPosts();
          const createdRow = recentPostId ? list?.querySelector(`[data-post-id="${CSS.escape(recentPostId)}"]`) : null;
          if (createdRow) {
            createdRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else if (publishedPanel) {
            publishedPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        } catch (error) {
          const text = getCommunityActionError(error, '게시글을 등록하지 못했습니다.');
          setFormMessage(text, 'error');
          showCommunityToast(text, 'error');
        } finally {
          submitButton.disabled = false;
        }
      });

      list?.addEventListener('click', async (event) => {
        const commentsButton = event.target.closest('[data-community-comments-toggle]');
        const reactionButton = event.target.closest('[data-community-reaction]');
        const postReportButton = event.target.closest('[data-community-report-post]');
        const commentReportButton = event.target.closest('[data-community-report-comment]');

        if (postReportButton) {
          await submitReport({
            targetType: 'post',
            targetId: postReportButton.dataset.postId || '',
            button: postReportButton
          });
          return;
        }

        if (commentReportButton) {
          const panel = commentReportButton.closest('.community-comments');
          await submitReport({
            targetType: 'comment',
            targetId: commentReportButton.dataset.commentId || '',
            messageTarget: panel?.querySelector('[data-community-comment-message]'),
            button: commentReportButton
          });
          return;
        }

        if (commentsButton) {
          const postId = commentsButton.dataset.postId;
          const row = commentsButton.closest('.community-post-main');
          const panel = row?.querySelector(`[data-community-comments="${CSS.escape(postId)}"]`);
          if (!postId || !panel) return;
          const opening = panel.hidden;
          panel.hidden = !opening;
          commentsButton.classList.toggle('is-active', opening);
          if (opening && !panel.dataset.loaded) {
            try {
              await loadComments(postId, panel);
              panel.dataset.loaded = 'true';
            } catch (error) {
              panel.querySelector('[data-community-comments-list]').innerHTML = `<p>${escapeHtml(error.message)}</p>`;
            }
          }
          return;
        }

        if (reactionButton) {
          const postId = reactionButton.dataset.postId;
          if (!postId) return;
          reactionButton.disabled = true;
          try {
            const response = await fetch('/api/community/reactions', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({
                postId,
                value: Number(reactionButton.dataset.value || 1)
              })
            });
            const data = await response.json().catch(() => ({}));
            if (!response.ok || !data.ok) {
              throw new Error(data.message || '추천을 처리하지 못했습니다.');
            }
            const countTarget = reactionButton.querySelector('strong');
            if (countTarget) countTarget.textContent = String(data.post?.likeCount || 0);
            reactionButton.classList.toggle('is-active', Number(data.activeValue || 0) === 1);
          } catch (error) {
            const row = reactionButton.closest('.community-post-main');
            const panel = row?.querySelector('.community-comments');
            const text = getCommunityActionError(error, '추천을 처리하지 못했습니다.');
            if (panel) {
              panel.hidden = false;
              const msg = panel.querySelector('[data-community-comment-message]');
              if (msg) {
                msg.textContent = text;
                msg.dataset.type = 'error';
              }
            }
            showCommunityToast(text, 'error');
          } finally {
            reactionButton.disabled = false;
          }
        }
      });

      list?.addEventListener('submit', async (event) => {
        const commentForm = event.target.closest('[data-community-comment-form]');
        if (!commentForm) return;
        event.preventDefault();
        const postId = commentForm.dataset.postId;
        const button = commentForm.querySelector('button[type="submit"]');
        const messageTarget = commentForm.parentElement?.querySelector('[data-community-comment-message]');
        button.disabled = true;
        if (messageTarget) {
          messageTarget.textContent = '댓글을 등록하는 중입니다.';
          messageTarget.dataset.type = 'info';
        }

        try {
          const data = new FormData(commentForm);
          const response = await fetch('/api/community/comments', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              postId,
              body: data.get('body')
            })
          });
          const result = await response.json().catch(() => ({}));
          if (!response.ok || !result.ok) {
            throw new Error(result.message || '댓글을 등록하지 못했습니다.');
          }
          commentForm.reset();
          if (messageTarget) {
            messageTarget.textContent = '댓글 등록 완료.';
            messageTarget.dataset.type = 'success';
          }
          showCommunityToast('댓글 등록 완료. 게시글 아래에서 확인할 수 있습니다.', 'success', 'COMMENT READY');
          await loadComments(postId, commentForm.closest('.community-comments'));
        } catch (error) {
          const text = getCommunityActionError(error, '댓글을 등록하지 못했습니다.');
          if (messageTarget) {
            messageTarget.textContent = text;
            messageTarget.dataset.type = 'error';
          }
          showCommunityToast(text, 'error');
        } finally {
          button.disabled = false;
        }
      });

      window.addEventListener('popstate', () => {
        activeBoard = getBoardFromUrl();
        syncFilterButtons();
        loadPosts();
      });

      syncFilterButtons();
      loadPosts();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCommunityBoard, { once: true });
    } else {
      initCommunityBoard();
    }
  </script>
</Layout>
