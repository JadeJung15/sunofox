---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { novelProject, plannedContentHubs, siteUpdates, siteUpdatesStructuredData, updateCategories } from '../data/siteContent.js';
---

<Layout
  title="SunoFox Updates | Official Log"
  description="SunoFox 공식 사이트의 웹소설, OST, Music Archive, 운영 개선 이력을 정리한 업데이트 로그입니다."
  canonical="https://sunofox.com/updates/"
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  jsonLd={siteUpdatesStructuredData}
>
  <SiteChrome active="updates" />

  <main id="main-content" class="site-main category-page updates-page">
    <section class="category-hero" aria-labelledby="updatesTitle">
      <p class="section-kicker">UPDATES</p>
      <h1 id="updatesTitle">SunoFox Updates</h1>
      <p>웹소설 공개, OST 연결, 음악 아카이브, 사이트 운영 개선 이력을 한 곳에 기록합니다.</p>
    </section>

    <section class="updates-hub-section reveal" aria-labelledby="updatesHubTitle">
      <div class="novel-section-head">
        <p class="section-kicker">NOTICE HUB</p>
        <h2 id="updatesHubTitle">운영 카테고리</h2>
        <span>{updateCategories.length}개 분류</span>
      </div>

      <div class="updates-hub-grid">
        {updateCategories.map((category) => (
          <article>
            <span>{category.label}</span>
            <strong>{category.countLabel}</strong>
            <p>{category.summary}</p>
            <a class="micro-button micro-button-muted" href={category.href}>{category.cta}</a>
          </article>
        ))}
      </div>
    </section>

    <section id="content-roadmap" class="updates-roadmap-section reveal" aria-labelledby="contentRoadmapTitle">
      <div class="novel-section-head">
        <p class="section-kicker">CONTENT HUBS</p>
        <h2 id="contentRoadmapTitle">확장 현황</h2>
        <span>{plannedContentHubs.length}개 허브</span>
      </div>

      <div class="updates-roadmap-grid">
        {plannedContentHubs.map((hub) => (
          <article class:list={['updates-roadmap-card', !hub.href && 'is-waiting']}>
            <span>{hub.status}</span>
            <strong>{hub.label}</strong>
            <p>{hub.summary}</p>
            <small class="updates-roadmap-visibility">{hub.visibility}</small>
            <p class="updates-roadmap-next">{hub.nextAction}</p>
            {hub.href ? (
              <a class="micro-button micro-button-muted" href={hub.href}>{hub.cta}</a>
            ) : (
              <span class="micro-button micro-button-muted updates-roadmap-disabled" aria-disabled="true">{hub.cta}</span>
            )}
          </article>
        ))}
      </div>
    </section>

    <section id="updates-log" class="updates-log-section reveal" aria-labelledby="updatesLogTitle">
      <div class="novel-section-head">
        <p class="section-kicker">공식 기록</p>
        <h2 id="updatesLogTitle">최근 업데이트</h2>
        <span>{siteUpdates.length}건</span>
      </div>

      <ol class="updates-log-list">
        {siteUpdates.map((item) => (
          <li>
            <div class="updates-log-meta">
              <time datetime={item.date.replaceAll('.', '-')}>{item.date}</time>
              <span>{item.type}</span>
            </div>
            <div class="updates-log-copy">
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <div class="updates-log-actions">
                {item.links.map((link) => (
                  <a href={link.href} class="micro-button micro-button-muted" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </main>
</Layout>
