---
import Layout from '../layouts/Layout.astro';
import {
  artistLinks,
  featuredStoryOst,
  latestStoryOst,
  musicArchive,
  novelProject,
  publishedNovelEpisodes,
  structuredData
} from '../data/siteContent.js';

const channelSpotlight = latestStoryOst || featuredStoryOst;
const studioTokenAsset = '/assets/brand/sunofox-studio-token.webp';

const navItems = [
  { label: 'COMPANY', href: '/profile/' },
  { label: 'PRODUCT', href: '#product' },
  { label: 'ENGINEERING', href: '#engineering' },
  { label: 'CAREERS', href: '#journey' },
  { label: 'CONTACT', href: '/updates/' }
];

const buildCards = [
  {
    label: 'YOUTUBE',
    title: 'FANS',
    body: 'YouTube에서 공개되는 Anime OST와 영상 감성을 하나의 팬 경험으로 모읍니다.',
    href: artistLinks.youtube,
    cta: 'YouTube 채널',
    external: true
  },
  {
    label: 'ARCHIVE',
    title: 'OST SHOP',
    body: `${musicArchive.videos.length}편의 큐레이션과 대표 OST를 다시 감상할 수 있는 음악 아카이브로 정리합니다.`,
    href: '/music/',
    cta: '음악 아카이브'
  }
];
---

<Layout
  title="SunoFox | Anime OST Studio"
  description="SunoFox는 이야기 기반 Anime OST와 웹소설 OST를 YouTube, 음악 아카이브, Story IP로 확장하는 스튜디오입니다."
  image={`https://sunofox.com${novelProject.coverImage}`}
  imageAlt={novelProject.coverAlt}
  imageWidth={novelProject.coverWidth}
  imageHeight={novelProject.coverHeight}
  jsonLd={structuredData}
>
  <header class="bg-header" aria-label="SunoFox reference header">
    <div class="bg-scroll-meter" aria-hidden="true"><span></span></div>
    <a class="bg-logo" href="/" aria-label="SunoFox home">
      <span aria-hidden="true"></span>
      <strong>SUNOFOX</strong>
    </a>
    <nav class="bg-nav" aria-label="Home navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <span class="bg-lang"><b>KOR</b><i></i>ENG</span>
    </nav>
    <button class="bg-menu" type="button" aria-label="메뉴 열기" aria-controls="bgMobileNav" aria-expanded="false">
      <span></span>
      <span></span>
    </button>
  </header>

  <div id="bgMobileNav" class="bg-mobile-panel" hidden>
    <nav aria-label="Mobile home navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>

  <main id="main-content" class="bg-home">
    <section class="bg-hero" aria-labelledby="heroTitle">
      <div class="bg-hero-empty" aria-hidden="true"></div>
      <div class="bg-hero-stage">
        <div class="bg-hero-lines" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="bg-hero-top">
          <p>STORY OST</p>
          <p>MEETS IP</p>
        </div>
        <h1 id="heroTitle">SUNOFOX</h1>
        <p class="bg-hero-caption">ANIME OST STUDIO</p>
      </div>
    </section>

    <section class="bg-company bg-reveal" aria-labelledby="companyTitle">
      <p class="bg-lede-brand">SunoFox는</p>
      <h2 id="companyTitle">기술과 엔터테인먼트를 결합하여<br />새로운 형태의 즐거움을 만듭니다</h2>
      <a href="/profile/">COMPANY</a>
    </section>

    <section id="product" class="bg-product bg-reveal" aria-labelledby="productTitle">
      <div class="bg-product-title">
        <p>ENTERTAINMENT</p>
        <p>MEETS TECHNOLOGY</p>
      </div>

      <div class="bg-build-head">
        <h2 id="productTitle">WHAT WE BUILD</h2>
        <p>다양한 연결 접점을 만들고 엔터테인먼트 영역을 한층 더 확장하고 있습니다.</p>
      </div>

      <div class="bg-card-grid">
        {buildCards.map((card, index) => (
          <article class="bg-card bg-tilt" style={`--card-index: ${index + 1}`}>
            <div class="bg-card-rule"></div>
            <em>{String(index + 1).padStart(2, '0')}</em>
            <span>{card.label}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
            <a href={card.href} target={card.external ? '_blank' : undefined} rel={card.external ? 'noopener noreferrer' : undefined}>
              {card.cta}
            </a>
          </article>
        ))}
      </div>

      <div class="bg-one-more">
        <p>ONE MORE THING</p>
        <div>
          <strong>AI와 제작 자동화를 활용하여 새로운 유형의 Story IP를 제작하고 있습니다.</strong>
          <a href="/novels/">{publishedNovelEpisodes.length} EPISODES</a>
        </div>
      </div>
    </section>

    <section id="engineering" class="bg-engineering bg-reveal" aria-labelledby="engineeringTitle">
      <div>
        <p>ENGINEERING</p>
        <h2 id="engineeringTitle">기술로 확장하는<br />엔터테인먼트 경험</h2>
        <span>
          민첩한 소수 제작 문화와 실효성을 중시하는 가치 아래, OST와 Story IP 제작의 고유한 챌린지를 해결해 가고 있습니다.
        </span>
        <a href="/login?next=/mv-studio">STUDIO LOGIN</a>
      </div>
      <figure>
        <img src={studioTokenAsset} alt="" width="720" height="720" loading="lazy" decoding="async" aria-hidden="true" />
      </figure>
    </section>

    <section id="journey" class="bg-journey bg-reveal" aria-labelledby="journeyTitle">
      <div class="bg-journey-bg" aria-hidden="true"></div>
      <h2 id="journeyTitle">SUNOFOX의 여정은<br />이제 막 시작되었습니다</h2>
      <p>
        최신 공개작 <strong>{channelSpotlight.title}</strong>을 시작점으로, 음악 아카이브와 《{novelProject.title}》를 하나의 세계관으로 확장합니다.
      </p>
      <a href={channelSpotlight.youtubeHref} target="_blank" rel="noopener noreferrer">LATEST RELEASE</a>
    </section>
  </main>

  <footer class="bg-footer" aria-label="SunoFox company information">
    <a href="/privacy/">개인정보처리방침</a>
    <dl>
      <div>
        <dt>대표 채널</dt>
        <dd>SunoFox YouTube</dd>
      </div>
      <div>
        <dt>운영 도메인</dt>
        <dd>sunofox.com</dd>
      </div>
      <div>
        <dt>내부 스튜디오</dt>
        <dd>/mv-studio</dd>
      </div>
      <div>
        <dt>호스팅 제공</dt>
        <dd>Cloudflare Pages</dd>
      </div>
    </dl>
    <p>Copyright ©SUNOFOX. All Rights Reserved.</p>
  </footer>
</Layout>

<style>
  :global(body:has(.bg-home)) {
    margin: 0;
    background: #111;
    color: #ffffff;
    overflow-x: hidden;
  }

  :global(body:has(.bg-home) .skip-link) {
    border-color: #009fe3;
  }

  :global(body:has(.bg-home) .site-footer) {
    display: none;
  }

  :global(body.bg-mobile-menu-open) {
    overflow: hidden;
  }

  .bg-home {
    --blue: #009fe3;
    --dark: #111111;
    --paper: #f3f4f4;
    --ink: #101112;
    --muted: rgba(255, 255, 255, 0.68);
    min-height: 100svh;
    background: var(--dark);
    color: #ffffff;
    font-family: Pretendard, Inter, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .bg-home :where(h1, h2, h3, p, a, span, strong, b, i) {
    letter-spacing: 0;
  }

  .bg-home a,
  .bg-header button {
    -webkit-tap-highlight-color: transparent;
  }

  .bg-home a:focus-visible,
  .bg-header button:focus-visible,
  .bg-mobile-panel a:focus-visible {
    outline: 2px solid var(--blue, #009fe3);
    outline-offset: 6px;
  }

  .bg-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 80;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 16px clamp(40px, 4.6vw, 64px);
    color: #ffffff;
    pointer-events: none;
  }

  .bg-scroll-meter {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    overflow: hidden;
    background: transparent;
  }

  .bg-scroll-meter span {
    display: block;
    width: 100%;
    height: 100%;
    background: #009fe3;
    transform: scaleX(var(--scroll-progress, 0));
    transform-origin: left;
  }

  .bg-logo,
  .bg-nav,
  .bg-menu {
    pointer-events: auto;
  }

  .bg-logo {
    display: grid;
    gap: 4px;
    width: 54px;
    color: #ffffff;
    text-decoration: none;
  }

  .bg-logo span,
  .bg-logo strong {
    transition: color 160ms ease, transform 160ms ease;
  }

  .bg-logo:hover span,
  .bg-logo:hover strong {
    color: #009fe3;
  }

  .bg-logo:hover strong {
    transform: translateY(2px);
  }

  .bg-logo span,
  .bg-logo span::before,
  .bg-logo span::after {
    display: block;
    height: 3px;
    background: currentColor;
    content: "";
  }

  .bg-logo span {
    position: relative;
    box-shadow: 0 7px 0 currentColor;
  }

  .bg-logo span::before,
  .bg-logo span::after {
    position: absolute;
    left: 0;
    width: 100%;
  }

  .bg-logo span::before {
    top: 14px;
  }

  .bg-logo span::after {
    top: 21px;
  }

  .bg-logo strong {
    margin-top: 22px;
    color: #ffffff;
    font-size: 0.48rem;
    font-weight: 950;
    line-height: 1;
  }

  .bg-nav {
    display: flex;
    align-items: center;
    gap: clamp(20px, 2vw, 34px);
    color: #ffffff;
    font-size: 0.92rem;
    font-weight: 950;
  }

  .bg-nav a {
    position: relative;
    color: inherit;
    text-decoration: none;
  }

  .bg-nav a::after {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -7px;
    height: 2px;
    background: #ffffff;
    content: "";
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 170ms ease;
  }

  .bg-nav a:hover::after,
  .bg-nav a:focus-visible::after {
    transform: scaleX(1);
  }

  .bg-lang {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: rgba(255, 255, 255, 0.78);
    font-style: normal;
  }

  .bg-lang b {
    padding: 4px 8px;
    background: #ffffff;
    color: #111111;
    font-size: 0.82rem;
  }

  .bg-lang i {
    display: block;
    width: 1px;
    height: 16px;
    background: rgba(255, 255, 255, 0.42);
  }

  .bg-menu {
    display: none;
    width: 28px;
    border: 0;
    background: transparent;
    padding: 0;
  }

  .bg-menu span {
    display: block;
    height: 2px;
    background: #ffffff;
    transform-origin: center;
    transition: transform 180ms ease;
  }

  .bg-menu span + span {
    margin-top: 7px;
  }

  .bg-menu.is-open span:first-child {
    transform: translateY(4.5px) rotate(24deg);
  }

  .bg-menu.is-open span:last-child {
    transform: translateY(-4.5px) rotate(-24deg);
  }

  .bg-mobile-panel {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: none;
    place-items: center;
    padding: 96px 24px 40px;
    background: rgba(17, 17, 17, 0.98);
  }

  .bg-mobile-panel.is-open {
    display: grid;
  }

  .bg-mobile-panel[hidden] {
    display: none;
  }

  .bg-mobile-panel nav {
    display: grid;
    gap: 18px;
    width: min(100%, 320px);
  }

  .bg-mobile-panel a {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding-top: 18px;
    color: #ffffff;
    font-size: 2rem;
    font-weight: 950;
    line-height: 1;
    text-decoration: none;
  }

  .bg-mobile-panel a:hover,
  .bg-mobile-panel a:focus-visible {
    color: #009fe3;
  }

  .bg-hero {
    position: relative;
    min-height: 226svh;
    overflow: hidden;
    background: #111111;
  }

  .bg-hero-empty {
    height: 105svh;
  }

  .bg-hero-stage {
    position: sticky;
    top: 0;
    height: 100svh;
    min-height: 620px;
    overflow: hidden;
    background:
      radial-gradient(circle at 80% 20%, rgba(0, 159, 227, 0.08), transparent 34rem),
      #111111;
    --hero-progress: 0;
  }

  .bg-hero-lines {
    position: absolute;
    top: clamp(24px, 4vw, 58px);
    left: 0;
    right: 0;
    display: grid;
    gap: 10px;
  }

  .bg-hero-lines span {
    display: block;
    height: clamp(5px, 0.6vw, 8px);
    background: var(--blue);
    transform-origin: left;
    animation: bgLineEnter 900ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .bg-hero-lines span:nth-child(2) {
    animation-delay: 90ms;
  }

  .bg-hero-lines span:nth-child(3) {
    animation-delay: 180ms;
  }

  .bg-hero-top {
    position: absolute;
    top: clamp(86px, 10vw, 152px);
    left: clamp(20px, 1.7vw, 28px);
    color: var(--blue);
    font-size: clamp(2.6rem, 6vw, 6rem);
    font-weight: 950;
    line-height: 1.03;
    transform: translateY(calc(var(--hero-progress) * -22px));
    transition: transform 80ms linear;
  }

  .bg-hero-top p {
    margin: 0;
    color: inherit;
  }

  .bg-hero h1 {
    position: absolute;
    left: clamp(16px, 1.6vw, 28px);
    right: 0;
    bottom: clamp(13vh, 17vh, 21vh);
    margin: 0;
    border-bottom: clamp(5px, 0.6vw, 8px) solid var(--blue);
    color: var(--blue);
    font-size: clamp(6.2rem, 18.4vw, 18rem);
    font-weight: 950;
    line-height: 0.82;
    text-transform: uppercase;
    transform: translateY(calc(var(--hero-progress) * -30px));
    transition: transform 80ms linear;
  }

  .bg-hero-caption {
    position: absolute;
    left: clamp(20px, 1.7vw, 28px);
    bottom: clamp(6vh, 8vh, 11vh);
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.92rem;
    font-weight: 950;
    opacity: calc(0.62 + var(--hero-progress) * 0.38);
  }

  .bg-company {
    display: grid;
    align-content: center;
    min-height: 92svh;
    padding: 0 clamp(20px, 7vw, 112px);
    background: #111111;
    color: #ffffff;
  }

  .bg-lede-brand {
    margin: 0;
    color: #ffffff;
    font-size: clamp(1.4rem, 2.6vw, 2.3rem);
    font-weight: 850;
  }

  .bg-company h2 {
    max-width: 980px;
    margin: 24px 0 0;
    color: #ffffff;
    font-size: clamp(2.2rem, 5.4vw, 6rem);
    font-weight: 950;
    line-height: 1.12;
    word-break: keep-all;
  }

  .bg-company a,
  .bg-engineering a,
  .bg-journey a {
    display: inline-flex;
    width: fit-content;
    min-height: 52px;
    align-items: center;
    margin-top: 42px;
    border: 1px solid currentColor;
    border-radius: 0;
    padding: 0 22px;
    color: inherit;
    font-size: 0.92rem;
    font-weight: 950;
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .bg-company a:hover,
  .bg-company a:focus-visible,
  .bg-engineering a:hover,
  .bg-engineering a:focus-visible,
  .bg-journey a:hover,
  .bg-journey a:focus-visible {
    background: #ffffff;
    color: #111111;
    transform: translateY(-2px);
  }

  .bg-product {
    background: var(--paper);
    color: var(--ink);
    padding: clamp(70px, 10vw, 150px) clamp(20px, 6vw, 96px);
  }

  .bg-product-title {
    margin-bottom: clamp(110px, 18vw, 260px);
    color: #101112;
    font-size: clamp(3.4rem, 8.6vw, 11rem);
    font-weight: 950;
    line-height: 0.92;
  }

  .bg-product-title p {
    margin: 0;
    color: inherit;
  }

  .bg-build-head {
    display: grid;
    grid-template-columns: minmax(230px, 0.42fr) minmax(0, 1fr);
    gap: 36px;
    align-items: start;
    border-top: 8px solid #101112;
    padding-top: 22px;
  }

  .bg-build-head h2 {
    margin: 0;
    color: #101112;
    font-size: clamp(2.2rem, 4.8vw, 6.5rem);
    font-weight: 950;
    line-height: 0.95;
  }

  .bg-build-head p {
    max-width: 720px;
    margin: 0;
    color: #3d454f;
    font-size: clamp(1rem, 1.5vw, 1.35rem);
    font-weight: 650;
    line-height: 1.7;
    word-break: keep-all;
  }

  .bg-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-top: 48px;
  }

  .bg-card {
    position: relative;
    display: grid;
    align-content: space-between;
    min-height: 370px;
    padding: 22px;
    border: 1px solid #c9cfd5;
    background: #ffffff;
    transform-style: preserve-3d;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .bg-card:hover {
    border-color: #101112;
    box-shadow: 0 24px 60px rgba(17, 17, 17, 0.12);
  }

  .bg-card-rule {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 8px;
    background: #101112;
  }

  .bg-card span {
    color: var(--blue);
    font-size: 0.85rem;
    font-weight: 950;
  }

  .bg-card em {
    position: absolute;
    top: 22px;
    right: 22px;
    color: rgba(16, 17, 18, 0.22);
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 950;
  }

  .bg-card h3 {
    margin: 48px 0 0;
    color: #101112;
    font-size: clamp(2.2rem, 4.2vw, 5.3rem);
    font-weight: 950;
    line-height: 0.95;
  }

  .bg-card p {
    margin: 22px 0 0;
    color: #303943;
    font-size: 1rem;
    line-height: 1.72;
    word-break: keep-all;
  }

  .bg-card a {
    width: fit-content;
    margin-top: 42px;
    color: #101112;
    font-size: 0.9rem;
    font-weight: 950;
    text-decoration: none;
    transition: color 160ms ease;
  }

  .bg-card a:hover,
  .bg-card a:focus-visible,
  .bg-one-more a:hover,
  .bg-one-more a:focus-visible,
  .bg-footer a:hover,
  .bg-footer a:focus-visible {
    color: var(--blue);
  }

  .bg-card a::after {
    display: inline-block;
    margin-left: 10px;
    content: "↗";
  }

  .bg-one-more {
    display: grid;
    grid-template-columns: minmax(220px, 0.35fr) minmax(0, 1fr);
    gap: 36px;
    margin-top: clamp(68px, 8vw, 120px);
    border-top: 1px solid #101112;
    padding-top: 24px;
  }

  .bg-one-more p,
  .bg-engineering p,
  .bg-journey p {
    margin: 0;
  }

  .bg-one-more p {
    color: #101112;
    font-size: 1rem;
    font-weight: 950;
  }

  .bg-one-more strong {
    max-width: 760px;
    color: #101112;
    font-size: clamp(1.6rem, 3.4vw, 3.8rem);
    font-weight: 950;
    line-height: 1.08;
    word-break: keep-all;
  }

  .bg-one-more div {
    display: grid;
    gap: 28px;
    justify-items: start;
  }

  .bg-one-more a {
    color: #101112;
    font-size: 0.92rem;
    font-weight: 950;
    text-decoration: none;
  }

  .bg-one-more a::after {
    display: inline-block;
    margin-left: 10px;
    content: "↗";
  }

  .bg-engineering {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.45fr);
    gap: clamp(32px, 6vw, 96px);
    align-items: center;
    min-height: 108svh;
    padding: clamp(70px, 9vw, 140px) clamp(20px, 7vw, 112px);
    background: #111111;
    color: #ffffff;
  }

  .bg-engineering h2 {
    margin: 18px 0 0;
    color: #ffffff;
    font-size: clamp(2.7rem, 6vw, 7rem);
    font-weight: 950;
    line-height: 1.06;
    word-break: keep-all;
  }

  .bg-engineering p {
    color: var(--blue);
    font-size: 1rem;
    font-weight: 950;
  }

  .bg-engineering span {
    display: block;
    max-width: 720px;
    margin-top: 28px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.08rem;
    line-height: 1.82;
    word-break: keep-all;
  }

  .bg-engineering figure {
    position: relative;
    margin: 0;
    aspect-ratio: 1;
    overflow: hidden;
    isolation: isolate;
  }

  .bg-engineering figure::before {
