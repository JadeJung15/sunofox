---
import SiteChrome from '../../components/SiteChrome.astro';
import Layout from '../../layouts/Layout.astro';
import { artistLinks, news } from '../../data/siteContent.js';

export function getStaticPaths() {
  return news.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const canonical = `https://sunofox.com${post.href}/`;
const description = post.body;
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: post.headline || post.title,
  description,
  datePublished: post.isoDate,
  dateModified: post.isoDate,
  author: {
    '@type': 'Organization',
    name: 'SunoFox',
    url: 'https://sunofox.com/'
  },
  publisher: {
    '@type': 'Organization',
    name: 'SunoFox',
    logo: {
      '@type': 'ImageObject',
      url: 'https://sunofox.com/assets/sunofox-mask-icon-512.png'
    }
  },
  mainEntityOfPage: canonical
};
---

<Layout
  title={`${post.title} | SunoFox News`}
  description={description}
  canonical={canonical}
  type="article"
  jsonLd={articleJsonLd}
>
  <SiteChrome active="news" />

  <main class="site-main category-page news-detail-page">
    <article class="news-detail" aria-labelledby="newsDetailTitle">
      <header class="news-detail-header reveal">
        <p class="section-kicker">NEWS</p>
        <time datetime={post.isoDate}>{post.date}</time>
        <h1 id="newsDetailTitle">{post.headline || post.title}</h1>
        <p>{post.body}</p>
      </header>

      <div class="news-detail-body reveal">
        {post.content.map((paragraph) => (
          <p>{paragraph}</p>
        ))}

        {post.examples && (
          <section class="news-idea-box" aria-label="팬게시판 아이디어 예시">
            <span>FAN BOARD IDEAS</span>
            {post.examples.map((example) => (
              <p>“{example}”</p>
            ))}
          </section>
        )}
      </div>

      <footer class="news-detail-actions reveal">
        <a class="main-button" href={post.cta?.href || '/news'}>{post.cta?.label || 'BACK TO NEWS'}</a>
        <a class="main-button main-button-muted" href={artistLinks.youtubeSubscribe} target="_blank" rel="noopener noreferrer">YOUTUBE</a>
        <a class="main-button main-button-muted" href="/news">NEWS LIST</a>
      </footer>
    </article>
  </main>
</Layout>
