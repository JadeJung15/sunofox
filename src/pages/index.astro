---
import Layout from '../layouts/Layout.astro';
import SiteChrome from '../components/SiteChrome.astro';
import {
  artistLinks,
  musicArchive,
  structuredData
} from '../data/siteContent.js';

const showcaseImages = {
  featured: '/assets/brand/sunofox-home-villainess-stage.png'
};

const sectionLinks = [
  {
    eyebrow: 'MUSIC ARCHIVE',
    title: 'EXPLORE MUSIC',
    text: 'Original OST, album archive, and YouTube premieres.',
    href: musicArchive.href,
    panel: 'music'
  },
  {
    eyebrow: 'STORY IP',
    title: 'DISCOVER IP',
    text: 'A story world expanded from music into episodes.',
    href: '/novels/',
    panel: 'story'
  }
];

---

<Layout
  title="SunoFox | Anime OST Studio"
  description="SunoFox는 이야기 기반 Anime OST와 웹소설 OST를 YouTube, 음악 아카이브, Story IP로 확장하는 스튜디오입니다."
  image={`https://sunofox.com${showcaseImages.featured}`}
  imageAlt="붉은 막이 열린 황실 무대에서 폭발하는 빛 앞에 선 SunoFox Story IP 대표 이미지"
  imageWidth={1456}
  imageHeight={410}
  jsonLd={structuredData}
>
  <SiteChrome active="home" />

  <main id="main-content" class="bg-home" aria-labelledby="homeTitle">
    <section class="showcase-stage" aria-label="SunoFox premium IP label">
      <div class="showcase-hero-grid">
        <div class="showcase-title">
          <p class="showcase-kicker">STORY-DRIVEN MUSIC & IP STUDIO</p>
          <h1 id="homeTitle" aria-label="SUNOFOX STORY OST MEETS IP">
            <span>SUNOFOX</span>
          </h1>
          <p class="showcase-statement">
            <span aria-hidden="true"></span>
            STORY OST MEETS IP.<br />
            MUSIC FIRST, STORY NEXT.
          </p>
        </div>

        <figure class="showcase-featured-visual" data-showcase-panel="featured">
          <img
            src={showcaseImages.featured}
            alt="붉은 막이 열린 황실 무대에서 폭발하는 빛 앞에 선 악녀는 첫 장에서 웃었다 대표 장면"
            width="1456"
            height="410"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>

      <nav class="showcase-primary-links" aria-label="SunoFox public sections">
        {sectionLinks.map((item) => (
          <a class="showcase-primary-link" href={item.href} data-showcase-panel={item.panel}>
            <span>{item.eyebrow}</span>
            <strong>{item.title}</strong>
            <em>{item.text}</em>
            <b aria-hidden="true">→</b>
          </a>
        ))}
      </nav>
    </section>

    <footer class="showcase-footer" aria-label="SunoFox footer">
      <p>© SUNOFOX. ALL RIGHTS RESERVED.</p>
      <nav aria-label="External links">
        <a href={artistLinks.youtube} target="_blank" rel="noopener noreferrer">YOUTUBE</a>
        <a href={artistLinks.soundcloud} target="_blank" rel="noopener noreferrer">SOUNDCLOUD</a>
        <a href="/updates/">UPDATES</a>
        <a href="/profile/">CONTACT</a>
      </nav>
    </footer>
  </main>
</Layout>

<style>
  :global(body:has(.bg-home)) {
    margin: 0;
    background: #020202;
    color: #ffffff;
    overflow-x: hidden;
  }

  :global(body:has(.bg-home) .skip-link) {
    border-color: #1f78ff;
  }

  :global(body:has(.bg-home) .site-footer) {
    display: none;
  }

  .bg-home {
    --bg: #020202;
    --text: #f5f5f2;
    --muted: rgba(245, 245, 242, 0.64);
    --dim: rgba(245, 245, 242, 0.38);
    --blue: #1f78ff;
    --line: rgba(245, 245, 242, 0.15);
    display: grid;
    min-height: 100svh;
    grid-template-rows: minmax(0, 1fr) auto;
    padding: clamp(18px, 1.8vw, 32px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.018), transparent 36%),
      radial-gradient(circle at 86% 22%, rgba(31, 120, 255, 0.1), transparent 25rem),
      var(--bg);
    color: var(--text);
    font-family: Pretendard, Inter, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .bg-home :where(h1, h2, h3, p, a, span, strong, b, i, small, em) {
    letter-spacing: 0;
  }

  .bg-home a:focus-visible {
    outline: 2px solid var(--blue);
    outline-offset: 6px;
  }

  .showcase-footer {
    position: relative;
    z-index: 5;
    display: grid;
    grid-template-columns: minmax(120px, 0.24fr) minmax(0, 1fr) auto;
    align-items: start;
    gap: 28px;
  }

  .showcase-footer a {
    color: #f8f8f4;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
    text-decoration: none;
  }

  .showcase-stage {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(100%, 1480px);
    min-height: min(860px, calc(100svh - 126px));
    margin-inline: auto;
    align-content: center;
    gap: clamp(28px, 4vw, 62px);
    padding-top: clamp(92px, 12vh, 132px);
    padding-bottom: clamp(34px, 5vh, 58px);
  }

  .showcase-hero-grid {
    display: grid;
    grid-template-columns: minmax(440px, 0.58fr) minmax(0, 1fr);
    gap: clamp(42px, 5vw, 78px);
    align-items: center;
  }

  .showcase-title {
    display: grid;
    gap: clamp(16px, 1.8vw, 28px);
    max-width: min(720px, 100%);
  }

  .showcase-kicker {
    width: fit-content;
    margin: 0;
    border-left: 2px solid var(--blue);
    padding-left: 16px;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(0.74rem, 0.78vw, 0.92rem);
    font-weight: 900;
    line-height: 1;
  }

  .showcase-title h1 {
    margin: 0;
    color: #f7f7f2;
    font-family: Impact, "Arial Narrow", Haettenschweiler, sans-serif;
    font-size: clamp(4.8rem, 6.8vw, 7.2rem);
    font-weight: 900;
    line-height: 0.86;
    text-transform: uppercase;
    text-shadow: 0 0 24px rgba(255, 255, 255, 0.07);
  }

  .showcase-title h1 span {
    display: block;
  }

  .showcase-statement {
    display: grid;
    grid-template-columns: 2px minmax(0, 1fr);
    gap: 18px;
    width: min(420px, 100%);
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(0.82rem, 0.86vw, 1rem);
    font-weight: 850;
    line-height: 1.42;
  }

  .showcase-statement span {
    width: 2px;
    min-height: 46px;
    background: var(--blue);
  }

  .showcase-featured-visual {
    margin: 0;
    overflow: hidden;
    background: #050505;
  }

  .showcase-featured-visual {
    aspect-ratio: 16 / 9;
    min-height: 360px;
  }

  .showcase-featured-visual img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .showcase-primary-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .showcase-primary-link {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 12px 24px;
    min-height: 132px;
    align-content: center;
    padding: clamp(22px, 2.8vw, 42px) clamp(16px, 2.6vw, 36px);
    color: #ffffff;
    text-decoration: none;
  }

  .showcase-primary-link + .showcase-primary-link {
    border-left: 1px solid var(--line);
  }

  .showcase-primary-link span,
  .showcase-primary-link em {
    display: block;
    color: rgba(255, 255, 255, 0.52);
    font-style: normal;
    font-size: 0.82rem;
    font-weight: 850;
    line-height: 1.45;
  }

  .showcase-primary-link span {
    grid-column: 1 / 2;
    color: var(--blue);
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1;
  }

  .showcase-primary-link strong {
    grid-column: 1 / 2;
    color: #ffffff;
    font-size: clamp(1.85rem, 2.8vw, 3.45rem);
    font-weight: 900;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .showcase-primary-link em {
    grid-column: 1 / 2;
    max-width: 420px;
  }

  .showcase-primary-link b {
    grid-column: 2;
    grid-row: 1 / 4;
    align-self: center;
  }

  .showcase-primary-link b {
    color: #ffffff;
    font-size: 1rem;
    transform: translateX(0);
    transition: transform 160ms ease;
  }

  .showcase-primary-link:hover b,
  .showcase-primary-link:focus-visible b {
    transform: translateX(5px);
  }

  .showcase-footer {
    border-top: 1px solid var(--line);
    padding-top: 20px;
    color: var(--dim);
  }

  .showcase-footer p {
    grid-column: 1;
    margin: 0;
    color: rgba(255, 255, 255, 0.36);
    font-size: 0.68rem;
    font-weight: 800;
  }

  .showcase-footer nav {
    display: flex;
    grid-column: 2 / 4;
    justify-content: flex-end;
    gap: clamp(42px, 6vw, 118px);
  }

  .showcase-footer a {
    color: rgba(255, 255, 255, 0.46);
    font-size: 0.7rem;
  }

  .showcase-footer a:hover,
  .showcase-footer a:focus-visible,
  .showcase-primary-link:hover,
  .showcase-primary-link:focus-visible {
    color: #ffffff;
  }

  @media (max-width: 1120px) {
    .showcase-hero-grid {
      grid-template-columns: 1fr;
    }

    .showcase-featured-visual {
      min-height: 0;
    }
  }

  @media (max-width: 760px) {
    .bg-home {
      display: block;
      min-height: 100svh;
      padding: 18px;
    }

    .showcase-footer {
      grid-template-columns: 1fr auto;
    }

    .showcase-stage {
      min-height: auto;
      gap: 34px;
      padding-top: 92px;
      padding-bottom: 34px;
    }

    .showcase-title {
      gap: 14px;
    }

    .showcase-title h1 {
      font-size: clamp(4.2rem, 22vw, 6.6rem);
      line-height: 0.86;
    }

    .showcase-kicker {
      font-size: 0.72rem;
    }

    .showcase-statement {
      font-size: 0.78rem;
    }

    .showcase-featured-visual {
      aspect-ratio: 1.65 / 1;
      min-height: 0;
    }

    .showcase-primary-links {
      grid-template-columns: 1fr;
    }

    .showcase-primary-link {
      min-height: 0;
      padding: 24px 0;
    }

    .showcase-primary-link + .showcase-primary-link {
      border-top: 1px solid var(--line);
      border-left: 0;
    }

    .showcase-footer {
      gap: 18px;
      padding-top: 18px;
    }

    .showcase-footer p,
    .showcase-footer nav {
      grid-column: 1 / 3;
    }

    .showcase-footer nav {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px 26px;
      justify-content: start;
    }
  }

  @media (max-width: 390px) {
    .showcase-title h1 {
      font-size: clamp(3.7rem, 20vw, 5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-primary-link b {
      transition: none;
    }
  }
</style>
