---
import SiteChrome from '../../components/SiteChrome.astro';
import Layout from '../../layouts/Layout.astro';
import { archiveAlbum, archiveAlbumStructuredData } from '../../data/siteContent.js';
---

<Layout
  title={`${archiveAlbum.title} | SunoFox`}
  description={archiveAlbum.summary}
  canonical="https://sunofox.com/music/archive-vol-1/"
  image={`https://sunofox.com${archiveAlbum.image}`}
  imageAlt={archiveAlbum.imageAlt}
  imageWidth={512}
  imageHeight={512}
  jsonLd={archiveAlbumStructuredData}
>
  <SiteChrome active="music" />

  <main id="main-content" class="site-main anime-home album-detail-page">
    <section class="album-detail-hero reveal" aria-labelledby="albumTitle">
      <a class="album-back-link" href="/music/">음악 아카이브</a>

      <figure class="album-cover-mark">
        <img src={archiveAlbum.image} alt={archiveAlbum.imageAlt} width="512" height="512" loading="eager" decoding="async" />
        <figcaption>{archiveAlbum.type} · {archiveAlbum.releaseDate}</figcaption>
      </figure>

      <div class="album-detail-copy">
        <p class="section-kicker">앨범 기록</p>
        <h1 id="albumTitle">{archiveAlbum.title}</h1>
        <p class="album-detail-summary">{archiveAlbum.summary}</p>

        <dl class="album-meta-grid">
          {archiveAlbum.facts.map((fact) => (
            <div>
              <dt>{fact.label}</dt>
              <dd>{fact.value}</dd>
            </div>
          ))}
        </dl>

        <nav class="album-platform-links" aria-label={`${archiveAlbum.title} 감상 링크`}>
          {archiveAlbum.links.map((link) => (
            <a
              class:list={['music-platform-link', link.platform && `is-${link.platform}`]}
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${archiveAlbum.title} ${link.label}에서 듣기`}
            >
              <span aria-hidden="true">{link.icon}</span>
              <strong>{link.label}</strong>
            </a>
          ))}
        </nav>

        <div class="album-detail-actions">
          <a class="main-button main-button-muted" href="/music/">음악 아카이브</a>
        </div>
      </div>
    </section>

    <section class="album-note-section reveal" aria-labelledby="albumNoteTitle">
      <div>
        <p class="section-kicker">ALBUM NOTE</p>
        <h2 id="albumNoteTitle">기록으로 남긴 사운드</h2>
      </div>
      <div class="album-note-copy">
        {archiveAlbum.intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <section class="album-track-section reveal" aria-labelledby="albumTracksTitle">
      <div class="novel-section-head">
        <p class="section-kicker">TRACKS</p>
        <h2 id="albumTracksTitle">수록곡</h2>
        <span>{archiveAlbum.tracks.length} tracks</span>
      </div>

      <ol class="album-track-grid">
        {archiveAlbum.tracks.map((track) => (
          <li>
            <span>{track.position}</span>
            <strong>{track.title}</strong>
            <em>{archiveAlbum.artist}</em>
          </li>
        ))}
      </ol>
    </section>

  </main>
</Layout>
