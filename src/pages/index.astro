---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { artistLinks, structuredData } from '../data/siteContent.js';

const wordmark = 'SUNOFOX'.split('');
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <SiteChrome active="home" />

  <main class="site-main landing-main">
    <section class="hero-stage hero-stage-landing" aria-labelledby="heroTitle">
      <div class="hero-center reveal">
        <p class="hero-kicker">ANIME OST STUDIO</p>
        <h1 id="heroTitle" class="hero-wordmark sign-wordmark" aria-label="SUNOFOX">
          {wordmark.map((letter, index) => (
            <span aria-hidden="true" style={`--letter-index: ${index}`}>{letter}</span>
          ))}
        </h1>
        <p class="hero-tagline">
          Animation soundtracks painted with emotion.
        </p>
      </div>

      <div class="hero-side-actions" aria-label="SunoFox quick actions">
        <a class="main-button" href="/profile" data-track="home_profile">PROFILE</a>
        <a class="main-button main-button-muted" href={artistLinks.youtubeSubscribe} target="_blank" rel="noopener noreferrer" data-track="home_youtube_subscribe">SUBSCRIBE</a>
      </div>

      <p class="landing-note">SCROLL DOWN</p>
    </section>
  </main>
</Layout>
