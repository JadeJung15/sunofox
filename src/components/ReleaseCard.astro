---
const { release } = Astro.props;
const youtubeHref = release.youtubeId
  ? `https://www.youtube.com/watch?v=${release.youtubeId}`
  : release.playlistHref || release.links.youtubePlaylists || release.links.youtube;
const youtubeLabel = release.youtubeId ? 'YouTube' : 'Playlist';
const trackKey = release.title.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
---

<article class="release-card reveal">
  <a class="release-cover" href={youtubeHref} target="_blank" rel="noopener noreferrer" aria-label={`${release.title} YouTube에서 듣기`}>
    <img
      src={release.image}
      alt={`${release.title} album artwork`}
      loading="lazy"
      onerror="this.onerror=null; this.src='/assets/sf-studio-icon-512.png'; this.classList.add('release-cover-fallback');"
    />
    <span>PLAY</span>
  </a>

  <div class="release-body">
    <p>{release.tag}</p>
    <h3>{release.title}</h3>
    <span>{release.ko}</span>
    <small>{release.desc}</small>
  </div>

  <div class="release-actions" aria-label={`${release.title} platform links`}>
    <a href={youtubeHref} target="_blank" rel="noopener noreferrer" data-track={`release_${trackKey}_youtube`}>{youtubeLabel}</a>
    <a href={release.links.spotify} target="_blank" rel="noopener noreferrer" data-track={`release_${trackKey}_spotify`}>Spotify</a>
    <a href={release.links.melon} target="_blank" rel="noopener noreferrer" data-track={`release_${trackKey}_melon`}>Melon</a>
    <a href={release.links.appleMusic} target="_blank" rel="noopener noreferrer" data-track={`release_${trackKey}_apple`}>Apple</a>
  </div>
</article>
