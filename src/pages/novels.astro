---
import SiteChrome from '../components/SiteChrome.astro';
import Layout from '../layouts/Layout.astro';
import { featuredStoryOst, novelProject, publishedNovelEpisodes, novelStructuredData } from '../data/siteContent.js';
---

<Layout title={`${novelProject.title} | SunoFox 수노폭스`} description={novelProject.shortSummary} canonical="https://sunofox.com/novels/" image={`https://sunofox.com${novelProject.coverImage}`} imageAlt={novelProject.coverAlt} imageWidth={novelProject.coverWidth} imageHeight={novelProject.coverHeight} jsonLd={novelStructuredData}>
  <SiteChrome />
  <main id="main-content" class="novel-catalog">
    <section class="novel-catalog-hero" aria-labelledby="novel-page-title">
      <figure><img src={novelProject.coverImage} alt={novelProject.coverAlt} width={novelProject.coverWidth} height={novelProject.coverHeight} loading="eager" fetchpriority="high" /></figure>
      <div><p class="catalog-kicker">대표 웹소설 · 6화 완결</p><h1 id="novel-page-title">{novelProject.title}</h1><p>{novelProject.summary}</p><dl><div><dt>장르</dt><dd>{novelProject.genre}</dd></div><div><dt>작가</dt><dd>{novelProject.author}</dd></div><div><dt>공개 회차</dt><dd>{publishedNovelEpisodes.length}화</dd></div></dl><div class="catalog-actions"><a href={publishedNovelEpisodes[0].href}>1화부터 읽기</a><a href={featuredStoryOst.youtubeHref} target="_blank" rel="noopener noreferrer">관련 OST</a></div></div>
    </section>
    <section class="episode-catalog" aria-labelledby="episode-title"><p class="catalog-kicker">EPISODES</p><h2 id="episode-title">회차 목록</h2><ol>{publishedNovelEpisodes.map((episode) => <li><a href={episode.href}><span>{episode.label}</span><strong>{episode.title}</strong><small>{episode.readTime}</small></a></li>)}</ol></section>
  </main>
</Layout>

<style>
  .novel-catalog{min-height:100vh;background:#050509;color:#fffafb;padding:140px max(24px,calc((100vw - 1120px)/2)) 100px;font-family:'Noto Sans KR',sans-serif}.novel-catalog-hero{display:grid;grid-template-columns:minmax(260px,400px) 1fr;gap:clamp(40px,8vw,100px);align-items:center}.novel-catalog figure{aspect-ratio:3/4;margin:0;overflow:hidden;border-radius:8px}.novel-catalog img{width:100%;height:100%;object-fit:cover}.catalog-kicker{color:#f6b86a;font-size:13px;font-weight:800}.novel-catalog h1,.novel-catalog h2{font-family:'Noto Serif KR',serif}.novel-catalog h1{margin:12px 0 24px;font-size:clamp(42px,6vw,78px);line-height:1.25}.novel-catalog-hero>div>p:not(.catalog-kicker){max-width:650px;color:#b7b0ba;font-size:17px;line-height:1.9;word-break:keep-all}.novel-catalog dl{display:flex;gap:30px;margin:34px 0}.novel-catalog dl div{display:grid;gap:6px}.novel-catalog dt{color:#88818b;font-size:12px}.novel-catalog dd{margin:0;font-weight:700}.catalog-actions{display:flex;gap:10px}.catalog-actions a{min-height:48px;display:inline-flex;align-items:center;border:1px solid #ff5f96;border-radius:7px;padding:0 20px;background:#ff5f96;color:#12040a;font-weight:800}.catalog-actions a:last-child{background:transparent;color:#fff}.episode-catalog{margin-top:110px}.episode-catalog h2{margin:8px 0 28px;font-size:42px}.episode-catalog ol{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:0;padding:0;list-style:none}.episode-catalog a{min-height:92px;display:grid;grid-template-columns:52px 1fr auto;align-items:center;gap:14px;border:1px solid rgba(255,255,255,.14);border-radius:7px;padding:16px 20px;color:#fff}.episode-catalog a:hover,.episode-catalog a:focus-visible{border-color:#ff5f96;background:rgba(255,95,150,.07)}.episode-catalog span{color:#ff5f96;font-weight:800}.episode-catalog small{color:#88818b}@media(max-width:720px){.novel-catalog{padding:90px 20px 70px}.novel-catalog-hero{grid-template-columns:1fr;gap:30px}.novel-catalog figure{width:min(76vw,320px)}.novel-catalog h1{font-size:36px}.novel-catalog-hero>div>p:not(.catalog-kicker){font-size:14px}.novel-catalog dl{gap:18px;flex-wrap:wrap}.episode-catalog{margin-top:70px}.episode-catalog ol{grid-template-columns:1fr}.episode-catalog a{grid-template-columns:44px 1fr}.episode-catalog small{grid-column:2}}
</style>
